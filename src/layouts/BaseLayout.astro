---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  transparentNav?: boolean;
  /** Prevent indexing — use ONLY for redirect/transaction pages (style-quiz, booking-confirmed) */
  noindex?: boolean;
  /** Pass a Service schema object to inject Service structured data on service detail pages */
  serviceSchema?: {
    name: string;
    description: string;
    url: string;
    price?: string;
  };
}

const {
  title,
  description = 'Staples & Statements — Wardrobe styling by Danielle Marie. Elevate your personal style with expert archetype-based styling services.',
  ogImage = '/images/og-default.webp',
  transparentNav = false,
  noindex = false,
  serviceSchema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// ── Structured Data (JSON-LD) ────────────────────────────────
// LocalBusiness schema — included on every page for brand authority
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://staplesandstatements.com/#business',
  name: 'Staples & Statements',
  description: 'Expert wardrobe styling and archetype-based personal style guidance by Danielle Marie.',
  url: 'https://staplesandstatements.com',
  logo: 'https://staplesandstatements.com/favicon.svg',
  image: 'https://staplesandstatements.com/images/og-default.webp',
  email: 'hello@staplesandstatements.com',
  founder: {
    '@type': 'Person',
    name: 'Danielle Marie Holman',
    jobTitle: 'Wardrobe Stylist & Creative Director',
    sameAs: [
      'https://instagram.com/littledanniii',
      'https://tiktok.com/@staplesandstatementsss',
    ],
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'San Diego',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'City', name: 'San Diego' },
    { '@type': 'Country', name: 'United States' },
  ],
  serviceType: [
    'Wardrobe Styling',
    'Personal Styling',
    'Color Analysis',
    'Virtual Styling',
  ],
  priceRange: 'FREE – $$$',
  sameAs: [
    'https://instagram.com/littledanniii',
    'https://tiktok.com/@staplesandstatementsss',
    'https://shopltk.com/explore/Staplesandstatementsss',
  ],
};

// Service schema — only injected on individual service pages
// For offers: only emit a numeric price when the price string starts with $ and a number,
// e.g. "$50" → "50", "FREE" → "0", "$55/hr" or "~15%" → omit offers (not a fixed price)
function extractNumericPrice(p: string): string | null {
  if (!p) return null;
  const upper = p.toUpperCase();
  if (upper === 'FREE') return '0';
  // Match strings that open with "$" followed by digits (fixed price, not hourly or %)
  const fixed = p.match(/^\$(\d+(?:\.\d+)?)\s*$/);
  if (fixed) return fixed[1];
  return null; // hourly, %, approximate — skip offers
}

const serviceJsonLd = serviceSchema
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: serviceSchema.name,
      description: serviceSchema.description,
      url: serviceSchema.url,
      provider: { '@id': 'https://staplesandstatements.com/#business' },
      ...(serviceSchema.price && extractNumericPrice(serviceSchema.price) !== null
        ? {
            offers: {
              '@type': 'Offer',
              price: extractNumericPrice(serviceSchema.price),
              priceCurrency: 'USD',
              availability: 'https://schema.org/InStock',
            },
          }
        : {}),
    })
  : null;

// GA4 Measurement ID — replace with actual ID from Google Analytics
// See TRACK1-MANUAL-SETUP.md Step 8 for setup instructions
const GA4_ID = 'G-XXXXXXXXXX';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Staples & Statements" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured Data: LocalBusiness (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <!-- Structured Data: Service (service detail pages only) -->
    {serviceJsonLd && <script type="application/ld+json" set:html={serviceJsonLd} />}

    <!-- Google Fonts: Cormorant Garamond + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <!-- Page transitions (SPA-like cross-fades between all pages) -->
    <ViewTransitions />

    <!-- Google Analytics 4
         TODO: Replace G-XXXXXXXXXX with actual Measurement ID from GA4
         See TRACK1-MANUAL-SETUP.md Step 8 -->
    {GA4_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script define:vars={{ GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-background text-text">
    <Nav transparentNav={transparentNav} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- ── Floating Action Buttons (FABs) ──────────────────────── -->
    <!-- Scroll-to-top + Quick-menu — appear after 300px scroll    -->
    <div id="fab-group" class="fixed bottom-6 right-6 z-40 flex flex-col items-end gap-3"
         style="opacity: 0; transform: translateY(16px); pointer-events: none;
                transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);">

      <!-- Quick-menu panel (hidden by default, opens above FABs) -->
      <div id="fab-menu-panel"
           class="mb-2 bg-primary/85 backdrop-blur-md border border-white/15 rounded-lg shadow-lg overflow-hidden"
           style="opacity: 0; transform: translateY(8px) scale(0.95); pointer-events: none;
                  transition: opacity calc(var(--dur) * 0.6) var(--ease),
                              transform calc(var(--dur) * 0.6) var(--ease);">
        <nav class="py-2 px-1" aria-label="Quick navigation">
          <ul class="flex flex-col">
            <li><a href="/" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Home</a></li>
            <li><a href="/services" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Services</a></li>
            <li><a href="/archetypes" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Archetypes</a></li>
            <li><a href="/clients" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Clients</a></li>
            <li><a href="/about" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">About</a></li>
            <li><a href="/shop" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Shop</a></li>
            <li><a href="/contact" class="block px-5 py-2.5 font-body text-xs tracking-widest uppercase text-white/70 hover:text-white hover:bg-white/8 transition-colors duration-200">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Scroll-to-top button -->
      <button
        id="fab-scroll-top"
        type="button"
        aria-label="Scroll to top"
        class="w-11 h-11 flex items-center justify-center rounded-full
               bg-primary/80 backdrop-blur-sm border border-white/15
               text-white/70 hover:text-white hover:scale-110 hover:shadow-[0_0_20px_rgba(184,151,126,0.25)]
               transition-all duration-300 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 15l-6-6-6 6"/>
        </svg>
      </button>

      <!-- Quick-menu button -->
      <button
        id="fab-menu-btn"
        type="button"
        aria-label="Quick navigation menu"
        aria-expanded="false"
        class="w-11 h-11 flex items-center justify-center rounded-full
               bg-primary/80 backdrop-blur-sm border border-white/15
               text-white/70 hover:text-white hover:scale-110 hover:shadow-[0_0_20px_rgba(184,151,126,0.25)]
               transition-all duration-300 cursor-pointer"
      >
        <svg id="fab-menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="4" cy="4" r="1"/><circle cx="12" cy="4" r="1"/><circle cx="20" cy="4" r="1"/>
          <circle cx="4" cy="12" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="20" cy="12" r="1"/>
          <circle cx="4" cy="20" r="1"/><circle cx="12" cy="20" r="1"/><circle cx="20" cy="20" r="1"/>
        </svg>
        <svg id="fab-menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="hidden">
          <path d="M18 6L6 18"/><path d="M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- FAB click-outside overlay (invisible, catches clicks to close menu) -->
    <div id="fab-overlay" class="fixed inset-0 z-[39]" style="display: none;"></div>
  </body>
</html>

<!--
  ── Animation Engine ──────────────────────────────────────────
  Runs on every page (initial load + ViewTransitions navigations).
  Speed: change --dur in global.css to rescale the whole system.
  ──────────────────────────────────────────────────────────────
-->
<script>
  function initAnimations() {
    // ── IntersectionObserver ───────────────────────────────────
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('s-on');
          io.unobserve(entry.target);
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px 0px 0px' }
    );

    // Returns true if the element is already visible in the viewport.
    // Elements in the viewport on load get no entrance animation — show immediately.
    // Must be at least as inclusive as the observer's threshold to prevent gap zones
    // where an element gets opacity:0 but the observer never fires.
    function inViewport(el: Element): boolean {
      const r = el.getBoundingClientRect();
      return r.bottom > 0 && r.top < window.innerHeight;
    }

    function observe(el: Element, cls: string, delay = 0) {
      if (inViewport(el)) return; // already visible — skip
      el.classList.add(cls);
      if (delay > 0) (el as HTMLElement).style.setProperty('--d', String(delay));
      io.observe(el);
    }

    // ── Section headings: fade + rise ─────────────────────────
    // Skip the first section (hero) — it animates via view-transition.
    const sections = Array.from(document.querySelectorAll<HTMLElement>('section'));
    sections.forEach((section, si) => {
      if (si === 0) return;

      // Heading group (eyebrow + h2 + subtitle)
      section.querySelectorAll<HTMLElement>('h1, h2, h3').forEach((h, hi) => {
        observe(h, 's-r-h', hi * 0.12);
      });

      // Accent lines / ornaments
      section.querySelectorAll<HTMLElement>('.w-8.h-px, .w-8.h-0\\.5').forEach((line) => {
        observe(line, 's-r-line', 0);
      });

      // Body text blocks directly under .text-center (section intro paragraphs)
      section.querySelectorAll<HTMLElement>('.text-center > p').forEach((p, pi) => {
        observe(p, 's-r', (pi + 0.5) * 0.12);
      });
    });

    // ── Grid children: staggered cascade reveal ───────────────
    // Delay per card: 0.13 × --dur ≈ 98ms at the default 0.75s speed.
    // Capped at index 7 so large grids (portfolio, archetype grid) don't
    // make the last cards feel abandoned — they catch up and finish together.
    document.querySelectorAll<HTMLElement>('[class*="grid-cols"]').forEach((grid) => {
      const items = Array.from(grid.children) as HTMLElement[];
      if (items.length < 2) return;
      items.forEach((child, i) => {
        // Skip if already has a reveal class (heading system got it first)
        if (child.classList.contains('s-r') || child.classList.contains('s-r-h')) return;
        observe(child, 's-r', Math.min(i, 7) * 0.13);
      });
    });

    // ── Flex row blocks (feature rows, CTA pairs) ─────────────
    document.querySelectorAll<HTMLElement>('.flex.flex-col.md\\:flex-row, .flex.flex-col.lg\\:flex-row').forEach((row) => {
      // Only reveal the container, not individual flex children (too noisy)
      const section = row.closest('section');
      const si = sections.indexOf(section as HTMLElement);
      if (si === 0) return;
      observe(row, 's-r', 0.1);
    });

    // ── Portrait/hero images: clip-path wipe reveal ────────────────────
    // Apply wipe reveal to images inside .img-frame wrappers (about page portraits,
    // service page images, guide covers) — these are editorial standalone images.
    // Grid mosaic images (img-frame-grid) keep the standard fade reveal.
    // .no-reveal: opt-out for images that must be guaranteed visible (e.g. inside
    // overflow-hidden parents where IntersectionObserver can be unreliable)
    document.querySelectorAll<HTMLElement>('.img-frame img:not(.no-reveal)').forEach((img, i) => {
      if (inViewport(img)) return;
      img.classList.remove('s-r-img');   // remove fade if it was already added
      observe(img, 's-r-wipe', i * 0.1);
    });

    // ── Image skeletons: shimmer until loaded ──────────────────
    document.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
      if (img.complete && img.naturalWidth > 0) return; // already loaded
      const wrap = img.parentElement;
      if (!wrap) return;

      wrap.classList.add('s-sk');
      img.classList.add('s-r-img');

      const finish = () => {
        wrap.classList.remove('s-sk');
        if (!inViewport(img)) {
          io.observe(img); // let the scroll-reveal handle it
        } else {
          img.classList.add('s-on'); // already visible — just show
        }
      };
      img.addEventListener('load',  finish, { once: true });
      img.addEventListener('error', () => { wrap.classList.remove('s-sk'); img.classList.remove('s-r-img'); }, { once: true });
    });
  }

  // Re-run on every page (initial load + each ViewTransitions navigation)
  document.addEventListener('astro:page-load', initAnimations);
</script>

<script>
  // ── Canvas grain texture ───────────────────────────────────────────────────
  // Applies grain as CSS background-image on flat-color background sections.
  //
  // Navigation fix: Astro ViewTransitions replaces <head> content on soft
  // navigation — the dynamically-injected #grain-style element is removed.
  // Solution: generate the canvas ONCE (saved in closure), then use
  // astro:page-load to re-inject the <style> on every navigation if removed.
  //
  // Intensity: --grain in global.css. Alpha scale = level * 7 (half of old 15).
  // Blur: 1.5px (up from 1px) — more frosted, less sharp digital static.

  (function() {
    if (window.matchMedia('(prefers-contrast: more)').matches) return;

    const level = Math.max(0, parseFloat(
      getComputedStyle(document.documentElement).getPropertyValue('--grain').trim()
    ) || 1);
    if (level === 0) return;

    // ── Generate grain canvas ONCE ─────────────────────────────────────────
    // Saved in closure — re-used on every page navigation without re-computing.
    const SIZE = 256;
    const ALPHA_SCALE = level * 7;  // halved: was 15, now 7 per level unit

    const canvas = document.createElement('canvas');
    canvas.width = canvas.height = SIZE;
    const ctx  = canvas.getContext('2d')!;
    const img  = ctx.createImageData(SIZE, SIZE);
    const data = img.data;

    for (let i = 0; i < data.length; i += 4) {
      const bright    = Math.random() > 0.5;
      data[i]         = bright ? 255 : 0;
      data[i + 1]     = bright ? 255 : 0;
      data[i + 2]     = bright ? 255 : 0;
      data[i + 3]     = Math.random() * ALPHA_SCALE;
    }
    ctx.putImageData(img, 0, 0);

    // Soften with 1.5px blur — more frosted, less sharp
    const soft = document.createElement('canvas');
    soft.width = soft.height = SIZE;
    const sCtx = soft.getContext('2d')!;
    sCtx.filter = 'blur(1.5px)';
    sCtx.drawImage(canvas, 0, 0);
    const grainUrl = soft.toDataURL('image/png');

    // Pre-build the CSS string once
    const bg = ['bg-primary','bg-primary-light','bg-background','bg-surface','bg-surface-dark'];
    const targets = [...bg.map(c => `section.${c}`), ...bg.map(c => `footer.${c}`)].join(',');
    const reset = 'input,textarea,select,button,[role="button"],[role="combobox"]';
    const cssText =
      `${targets}{background-image:url('${grainUrl}');background-repeat:repeat;background-size:256px 256px}` +
      `${reset}{background-image:none}`;

    // ── Inject (or re-inject) the style tag ───────────────────────────────
    // Called on initial load AND after every ViewTransitions navigation because
    // Astro's head-swap removes dynamically-injected elements from <head>.
    function injectGrainStyle() {
      if (document.getElementById('grain-style')) return;  // already present
      const style = document.createElement('style');
      style.id = 'grain-style';
      style.textContent = cssText;
      document.head.appendChild(style);
    }

    // Initial load
    injectGrainStyle();
    // Re-inject after every soft navigation (ViewTransitions removes it)
    document.addEventListener('astro:page-load', injectGrainStyle);
  })();
</script>

<script>
  // ── Floating Action Buttons (FABs) ────────────────────────────────────────
  // Scroll-to-top + Quick-menu. Appears after 300px scroll.
  // ViewTransitions-compatible: re-initializes inside astro:page-load.
  // Uses AbortController to cleanly tear down listeners on re-init.

  let fabController: AbortController | null = null;

  function initFabs(): void {
    const fabGroup   = document.getElementById('fab-group')        as HTMLElement | null;
    const scrollBtn  = document.getElementById('fab-scroll-top')   as HTMLButtonElement | null;
    const menuBtn    = document.getElementById('fab-menu-btn')     as HTMLButtonElement | null;
    const menuPanel  = document.getElementById('fab-menu-panel')   as HTMLElement | null;
    const overlay    = document.getElementById('fab-overlay')      as HTMLElement | null;
    const iconOpen   = document.getElementById('fab-menu-icon-open')  as HTMLElement | null;
    const iconClose  = document.getElementById('fab-menu-icon-close') as HTMLElement | null;

    if (!fabGroup || !scrollBtn || !menuBtn || !menuPanel || !overlay) return;

    // Tear down previous listeners
    fabController?.abort();
    fabController = new AbortController();
    const signal = fabController.signal;

    // Show FABs once the user has scrolled past the first viewport
    // (i.e. past the hero / first section)
    const SCROLL_SHOW = window.innerHeight;
    let fabVisible  = false;
    let menuOpen    = false;
    let ticking     = false;

    // ── Show/hide FAB group based on scroll position ────────────
    function updateFabVisibility(): void {
      const shouldShow = window.scrollY > SCROLL_SHOW;
      if (shouldShow === fabVisible) { ticking = false; return; }
      fabVisible = shouldShow;

      if (shouldShow) {
        fabGroup.style.opacity        = '1';
        fabGroup.style.transform      = 'translateY(0)';
        fabGroup.style.pointerEvents  = 'auto';
      } else {
        fabGroup.style.opacity        = '0';
        fabGroup.style.transform      = 'translateY(16px)';
        fabGroup.style.pointerEvents  = 'none';
        // Close menu if open when FABs hide
        if (menuOpen) closeMenu();
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateFabVisibility);
        ticking = true;
      }
    }, { passive: true, signal });

    // Initialize on load
    updateFabVisibility();

    // ── Scroll to top ───────────────────────────────────────────
    scrollBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }, { signal });

    // ── Quick menu open/close ───────────────────────────────────
    function openMenu(): void {
      menuOpen = true;
      menuBtn.setAttribute('aria-expanded', 'true');
      menuPanel.style.opacity       = '1';
      menuPanel.style.transform     = 'translateY(0) scale(1)';
      menuPanel.style.pointerEvents = 'auto';
      overlay.style.display         = 'block';
      if (iconOpen)  iconOpen.classList.add('hidden');
      if (iconClose) iconClose.classList.remove('hidden');
    }

    function closeMenu(): void {
      menuOpen = false;
      menuBtn.setAttribute('aria-expanded', 'false');
      menuPanel.style.opacity       = '0';
      menuPanel.style.transform     = 'translateY(8px) scale(0.95)';
      menuPanel.style.pointerEvents = 'none';
      overlay.style.display         = 'none';
      if (iconOpen)  iconOpen.classList.remove('hidden');
      if (iconClose) iconClose.classList.add('hidden');
    }

    menuBtn.addEventListener('click', () => {
      if (menuOpen) closeMenu(); else openMenu();
    }, { signal });

    overlay.addEventListener('click', closeMenu, { signal });

    // Close on Escape key
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    }, { signal });

    // Close menu when a nav link inside it is clicked
    menuPanel.addEventListener('click', (e: Event) => {
      if ((e.target as Element).closest('a')) closeMenu();
    }, { signal });
  }

  document.addEventListener('astro:page-load', initFabs);
</script>

