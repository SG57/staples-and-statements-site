<style>
  /* ── Slide states ─────────────────────────────────────────── */
  .quiz-slide {
    pointer-events: none;
    will-change: transform, opacity;
  }

  .quiz-slide-active {
    position: relative;
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
    z-index: 1;
  }

  /* Off-screen positions for animation origin */
  .quiz-slide-next {
    opacity: 0;
    transform: translateX(40px);
  }

  .quiz-slide-prev {
    opacity: 0;
    transform: translateX(-40px);
  }

  /* ── Chip selected state ──────────────────────────────────── */
  .quiz-chip[aria-checked="true"] {
    background: rgba(184, 151, 126, 0.15);
    border-color: rgba(184, 151, 126, 0.4);
    transform: scale(1.02);
    box-shadow: 0 0 16px rgba(184, 151, 126, 0.12);
  }

  .quiz-chip[aria-checked="true"] .quiz-chip-check {
    background: rgba(184, 151, 126, 0.85);
    color: rgba(255, 255, 255, 1);
  }

  /* ── Calculating overlay shimmer ────────────────────────── */
  @keyframes quiz-shimmer-pulse {
    0%   { width: 20%; opacity: 0.5; }
    50%  { width: 80%; opacity: 1; }
    100% { width: 20%; opacity: 0.5; }
  }

  .quiz-shimmer-bar {
    animation: quiz-shimmer-pulse 1.5s ease-in-out infinite;
  }

  /* ── Per-archetype entrance animations ─────────────────── */

  /* Feminine: The Siren — warm glow from bottom, scale up */
  @keyframes siren-entrance {
    0%   { opacity: 0; transform: scale(0.85) translateY(30px); filter: brightness(1.3) blur(4px); }
    60%  { opacity: 1; transform: scale(1.02) translateY(-4px); filter: brightness(1.1) blur(0px); }
    100% { opacity: 1; transform: scale(1) translateY(0); filter: brightness(1) blur(0px); }
  }
  .quiz-entrance-the-siren .quiz-result-primary {
    animation: siren-entrance 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Muse — gentle float down from above */
  @keyframes muse-entrance {
    0%   { opacity: 0; transform: translateY(-40px); filter: blur(3px); }
    50%  { opacity: 0.7; transform: translateY(6px); filter: blur(0px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .quiz-entrance-the-muse .quiz-result-primary {
    animation: muse-entrance 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Warrior — sharp slide from left, crisp */
  @keyframes warrior-entrance {
    0%   { opacity: 0; transform: translateX(-60px) scaleX(0.95); }
    70%  { opacity: 1; transform: translateX(4px) scaleX(1.01); }
    100% { opacity: 1; transform: translateX(0) scaleX(1); }
  }
  .quiz-entrance-the-warrior .quiz-result-primary {
    animation: warrior-entrance 600ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Enchantress — dark shimmer, slow reveal */
  @keyframes enchantress-entrance {
    0%   { opacity: 0; transform: scale(1.05); filter: brightness(0.3) blur(6px); }
    40%  { opacity: 0.5; filter: brightness(0.6) blur(3px); }
    70%  { opacity: 0.9; transform: scale(1.01); filter: brightness(0.9) blur(1px); }
    100% { opacity: 1; transform: scale(1); filter: brightness(1) blur(0px); }
  }
  .quiz-entrance-the-enchantress .quiz-result-primary {
    animation: enchantress-entrance 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Creator — playful bounce-in */
  @keyframes creator-entrance {
    0%   { opacity: 0; transform: scale(0.6) rotate(-3deg); }
