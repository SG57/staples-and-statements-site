---
/**
 * ArchetypeQuiz.astro — Interactive style archetype quiz wizard
 *
 * Split-screen editorial layout: mood image left, questions right.
 * 7 questions per gender, multi-select answer chips, animated transitions,
 * cinematic results reveal with per-archetype entrance animations,
 * triptych image display, and sharing. Fully self-contained — no external deps.
 */

interface Props {
  gender: 'feminine' | 'masculine';
  quizId: string;
}

const { gender, quizId } = Astro.props;
const isFeminine = gender === 'feminine';
const otherGender = isFeminine ? 'masculine' : 'feminine';
const questionCount = 7;

/* ── Quiz data ─────────────────────────────────────────────────── */

const feminineQuestions = [
  {
    id: 1,
    text: 'The energy I express most naturally is:',
    image: '/images/archetypes/the-siren-1.webp',
    options: [
      { letter: 'A', text: 'Seductive, bold, captivating' },
      { letter: 'B', text: 'Soft, dreamy, ethereal' },
      { letter: 'C', text: 'Driven, powerful, assertive' },
      { letter: 'D', text: 'Mysterious, alluring, magnetic' },
      { letter: 'E', text: 'Artistic, expressive, imaginative' },
      { letter: 'F', text: 'Nurturing, grounding, abundant' },
      { letter: 'G', text: 'Kind, peaceful, gentle' },
    ],
  },
  {
    id: 2,
    text: 'I feel most confident when I wear:',
    image: '/images/archetypes/the-muse-1.webp',
    options: [
      { letter: 'A', text: 'Form-fitted pieces that highlight my curves' },
      { letter: 'B', text: 'Flowy silhouettes and soft fabrics' },
      { letter: 'C', text: 'Structured, clean-lined outfits' },
      { letter: 'D', text: 'Deep colors and intricate details' },
      { letter: 'E', text: 'Statement pieces or creative combinations' },
      { letter: 'F', text: 'Luxe, elevated basics' },
      { letter: 'G', text: 'Light colors and airy fabrics' },
    ],
  },
  {
    id: 3,
    text: 'My natural presence feels:',
    image: '/images/archetypes/the-warrior-1.webp',
    options: [
      { letter: 'A', text: 'Fiery' },
      { letter: 'B', text: 'Soft' },
      { letter: 'C', text: 'Commanding' },
      { letter: 'D', text: 'Intense' },
      { letter: 'E', text: 'Playful' },
      { letter: 'F', text: 'Warm' },
      { letter: 'G', text: 'Calm' },
    ],
  },
  {
    id: 4,
    text: 'My ideal date-night look is:',
    image: '/images/archetypes/the-enchantress-1.webp',
    options: [
      { letter: 'A', text: 'Red dress, heels, and a bold lip' },
      { letter: 'B', text: 'Slip dress, soft curls, glowy makeup' },
      { letter: 'C', text: 'Sleek trousers, blazer, minimal jewelry' },
      { letter: 'D', text: 'Dark lace, smoky eyes, layered jewelry' },
      { letter: 'E', text: 'Mixed textures, unexpected pop of color' },
      { letter: 'F', text: 'Silk blouse, gold jewelry, tailored trousers' },
      { letter: 'G', text: 'Pastels, dainty jewelry, natural makeup' },
    ],
  },
  {
    id: 5,
    text: 'My dream closet is full of:',
    image: '/images/archetypes/the-creator-1.webp',
    options: [
      { letter: 'A', text: 'Sultry silhouettes' },
      { letter: 'B', text: 'Romantic fabrics' },
      { letter: 'C', text: 'Power pieces' },
      { letter: 'D', text: 'Dark glamour' },
      { letter: 'E', text: 'Creative staples' },
      { letter: 'F', text: 'High-quality neutrals' },
      { letter: 'G', text: 'Angelic simplicity' },
    ],
  },
  {
    id: 6,
    text: 'I make decisions based on:',
    image: '/images/archetypes/the-empress-1.webp',
    options: [
      { letter: 'A', text: 'Desire' },
      { letter: 'B', text: 'Emotion' },
      { letter: 'C', text: 'Logic' },
      { letter: 'D', text: 'Intuition' },
      { letter: 'E', text: 'Inspiration' },
      { letter: 'F', text: 'Stability' },
      { letter: 'G', text: 'Harmony' },
    ],
  },
  {
    id: 7,
    text: 'People often describe my vibe as:',
    image: '/images/archetypes/the-angelic-one-1.webp',
    options: [
      { letter: 'A', text: 'Magnetic' },
      { letter: 'B', text: 'Dreamy' },
      { letter: 'C', text: 'Strong' },
      { letter: 'D', text: 'Intriguing' },
      { letter: 'E', text: 'Unforgettable' },
      { letter: 'F', text: 'Elegant' },
      { letter: 'G', text: 'Sweet' },
    ],
  },
];

const masculineQuestions = [
  {
    id: 1,
    text: 'When you get dressed, what matters most to you beneath the surface? Feeling ...',
    image: '/images/archetypes/the-protector-1.webp',
    options: [
      { letter: 'A', text: 'Grounded, capable and ready for whatever the day brings' },
      { letter: 'B', text: 'Unrestricted, expressive and able to move freely through the world' },
      { letter: 'C', text: 'Intentional, composed and like your outer appearance reflects inner clarity' },
      { letter: 'D', text: 'Emotionally attuned to your current mood, inner shifts or creative state' },
      { letter: 'E', text: 'Fully aligned \u2014 like your outfit disappears and you just feel like yourself' },
    ],
  },
  {
    id: 2,
    text: 'If your style changes often, it\u2019s usually because ...',
    image: '/images/archetypes/the-maverick-1.webp',
    options: [
      { letter: 'A', text: 'You adapt to your environment & dress for reliability + function' },
      { letter: 'B', text: 'You resist repetition & crave freedom, novelty + movement' },
      { letter: 'C', text: 'You refine your look over time, adjusting details rather than reinventing yourself' },
      { letter: 'D', text: 'You experience life in phases & your style evolves alongside your inner world' },
      { letter: 'E', text: 'Your style integrates many influences & shifts without losing coherence' },
    ],
  },
  {
    id: 3,
    text: 'How do people most often experience your presence when you enter a room?',
    image: '/images/archetypes/the-architect-1.webp',
    options: [
      { letter: 'A', text: 'Steady, grounding & reassuring' },
      { letter: 'B', text: 'Energetic, intriguing & hard to predict' },
      { letter: 'C', text: 'Focused, sharp & intentional' },
      { letter: 'D', text: 'Intense, layered & emotionally resonant' },
      { letter: 'E', text: 'Calm, self-possessed & centered' },
    ],
  },
  {
    id: 4,
    text: 'When you shop for clothes, what pulls you in first?',
    image: '/images/archetypes/the-alchemist-1.webp',
    options: [
      { letter: 'A', text: 'Quality, durability & pieces that feel dependable over time' },
      { letter: 'B', text: 'Unusual details, statement items, or things that feel different from the norm' },
      { letter: 'C', text: 'Clean lines, thoughtful construction & architectural shapes' },
      { letter: 'D', text: 'Texture, contrast, mood & depth \u2014 how something feels more than how it looks' },
      { letter: 'E', text: 'Pieces that immediately feel right, even if you can\u2019t explain why' },
    ],
  },
  {
    id: 5,
    text: 'Your relationship to trends can best be described as ...',
    image: '/images/archetypes/the-sovereign-1.webp',
    options: [
      { letter: 'A', text: 'Mostly indifferent \u2014 you prefer timelessness over novelty' },
      { letter: 'B', text: 'Playful \u2014 you enjoy bending or remixing trends on your own terms' },
      { letter: 'C', text: 'Strategic \u2014 you adopt trends selectively if they align with your vision' },
      { letter: 'D', text: 'Curious \u2014 you explore trends as a form of self-expression or experimentation' },
      { letter: 'E', text: 'Detached \u2014 trends don\u2019t define you, & you don\u2019t react strongly to them' },
    ],
  },
  {
    id: 6,
    text: 'You feel most confident when your appearance communicates ...',
    image: '/images/archetypes/ensemble-masculine-hero.webp',
    options: [
      { letter: 'A', text: 'Capability, reliability & quiet strength' },
      { letter: 'B', text: 'Freedom, individuality & openness' },
      { letter: 'C', text: 'Competence, intention & clarity' },
      { letter: 'D', text: 'Emotional depth, creativity or internal movement' },
      { letter: 'E', text: 'Alignment \u2014 nothing feels forced & everything feels natural' },
    ],
  },
  {
    id: 7,
    text: 'When you think about your style identity overall, it feels ...',
    image: '/images/archetypes/ensemble-masculine-cards.webp',
    options: [
      { letter: 'A', text: 'Steady & rooted \u2014 you know what works and return to it' },
      { letter: 'B', text: 'Versatile & hard to pin down \u2014 labels feel limiting' },
      { letter: 'C', text: 'Defined & purposeful \u2014 your style has a clear through line' },
      { letter: 'D', text: 'Fluid & evolving \u2014 your style mirrors your internal transformations' },
      { letter: 'E', text: 'Integrated & whole \u2014 all parts of you are allowed to coexist' },
    ],
  },
];

const questions = isFeminine ? feminineQuestions : masculineQuestions;

/* Archetype metadata for results display (with descriptions) */
const feminineArchetypesMeta: Record<string, { name: string; icon: string; color: string; slug: string; desc: string }> = {
  A: { name: 'The Siren', icon: '\u25C9', color: '#8c4a3e', slug: 'the-siren',
       desc: 'Confident, magnetic, and irresistibly alluring. Your style celebrates every curve and commands every room.' },
  B: { name: 'The Muse', icon: '\u2726', color: '#c9b8d4', slug: 'the-muse',
       desc: 'Romantic, ethereal, and endlessly creative. Your style is poetry in motion.' },
  C: { name: 'The Warrior', icon: '\u25B2', color: '#5a5a5a', slug: 'the-warrior',
       desc: 'Bold, structured, and completely unapologetic. You dress with intention and leave an impression.' },
  D: { name: 'The Enchantress', icon: '\u25C8', color: '#4a3d5c', slug: 'the-enchantress',
       desc: 'Dark, magnetic, and mysterious. Your style draws people in before you say a word.' },
  E: { name: 'The Creator', icon: '\u25D0', color: '#6b8c6e', slug: 'the-creator',
       desc: 'Eclectic, expressive, and artistically fearless. Your style is wearable art — and the rules don\'t apply.' },
  F: { name: 'The Empress', icon: '\u265B', color: '#8b6b4a', slug: 'the-empress',
       desc: 'Nurturing, grounding, and abundantly elegant. You dress with quiet confidence — luxe elevated basics and warm neutrals that radiate stability and grace.' },
  G: { name: 'The Angelic One', icon: '\u2727', color: '#e8ddd4', slug: 'the-angelic-one',
       desc: 'Pure, luminous, and timelessly beautiful. Your style radiates grace and effortless softness.' },
};

const masculineArchetypesMeta: Record<string, { name: string; icon: string; color: string; slug: string; desc: string }> = {
  A: { name: 'The Protector', icon: '\u25C6', color: '#2c3e50', slug: 'the-protector',
       desc: 'Grounded, capable, and quietly strong. You dress to feel steady and ready for life — not to impress, but to be prepared for whatever comes.' },
  B: { name: 'The Maverick', icon: '\u25C7', color: '#2d1b33', slug: 'the-maverick',
       desc: 'Driven by freedom, individuality, and self-expression. Fashion is a playground, not a rule book — you evolve with curiosity and refuse to blend in.' },
  C: { name: 'The Architect', icon: '\u25FC', color: '#1a1a2e', slug: 'the-architect',
       desc: 'Intentional, precise, and deeply aware of the power of presentation. Every choice is considered, every detail calculated — nothing is accidental.' },
  D: { name: 'The Alchemist', icon: '\u25CE', color: '#4a2d3e', slug: 'the-alchemist',
       desc: 'Style as emotional language. You move through phases, moods, and transformation — your wardrobe reflects inner depth and personal evolution.' },
  E: { name: 'The Sovereign', icon: '\u2B21', color: '#1a3a2a', slug: 'the-sovereign',
       desc: 'Fully aligned — your style feels effortless, grounded, and quietly powerful. You\'re not chasing trends or identities; you\'re expressing a fully formed sense of self.' },
};

const archetypesMeta = isFeminine ? feminineArchetypesMeta : masculineArchetypesMeta;
---

<div
  class="quiz-root overflow-hidden"
  id={`quiz-${quizId}`}
  data-gender={gender}
  data-quiz-id={quizId}
  data-questions={JSON.stringify(questions)}
  data-archetypes={JSON.stringify(archetypesMeta)}
>
  <!-- ── QUIZ BODY: split-screen layout ────────────────────── -->
  <div class="quiz-body flex flex-col md:flex-row w-full h-[calc(100dvh-6rem)] max-h-[calc(100dvh-6rem)] overflow-hidden rounded-sm border border-white/10">

    <!-- LEFT: mood image panel — compact on mobile to preserve answer space -->
    <div class="quiz-image-panel relative w-full md:w-[35%] h-[12dvh] md:h-auto shrink-0 overflow-hidden bg-primary">
      {questions.map((q, i) => (
        <img
          src={q.image}
          alt={`Question ${q.id} mood`}
          class:list={[
            'quiz-mood-img absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)]',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-q-img={i}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      ))}
      <!-- Gradient overlay for image panel -->
      <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:via-transparent md:to-primary/30 pointer-events-none"></div>
      <!-- Question counter overlay on mobile -->
      <div class="quiz-q-badge absolute top-4 left-4 md:hidden font-body text-xs tracking-widest uppercase text-white/80 bg-black/40 backdrop-blur-sm px-3 py-1.5 rounded-sm">
        <span class="quiz-q-current">1</span> / {questionCount}
      </div>
    </div>

    <!-- RIGHT: question + answers panel -->
    <div class="quiz-content-panel relative flex-1 flex flex-col bg-primary/95 backdrop-blur-sm p-4 md:p-8 overflow-y-auto overflow-x-hidden quiz-hide-scrollbar">

      <!-- Progress: live region -->
      <div class="sr-only" aria-live="polite" id={`quiz-${quizId}-live`}>
        Question 1 of {questionCount}
      </div>

      <!-- Top bar: question counter + close/restart controls -->
      <div class="flex items-center justify-between mb-3">
        <div class="font-body text-xs tracking-widest uppercase text-white/50">
          Question <span class="quiz-q-current text-accent">1</span> of {questionCount}
        </div>
        <div class="flex items-center gap-3">
          <button
            type="button"
            class="quiz-btn-restart font-body text-[11px] tracking-wider uppercase text-white/30
                   hover:text-accent cursor-pointer transition-colors duration-200"
            aria-label="Start over"
            title="Start over"
          >
            Restart
          </button>
          <button
            type="button"
            class="quiz-btn-close-x w-7 h-7 flex items-center justify-center rounded-full
                   text-white/30 hover:text-white hover:bg-white/10 cursor-pointer
                   transition-all duration-200"
            aria-label="Close quiz and return to archetypes"
            title="Close quiz"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Hide the old desktop-only counter since we unified it above -->
      <div class="hidden">
        Question <span class="quiz-q-current text-accent">1</span> of {questionCount}
      </div>

      <!-- Question slides container -->
      <div class="quiz-slides relative flex-1">
        {questions.map((q, i) => (
          <div
            class:list={[
              'quiz-slide absolute inset-0 flex flex-col',
              i === 0 ? 'quiz-slide-active' : 'quiz-slide-next',
            ]}
            data-slide={i}
            role="group"
            aria-label={`Question ${q.id} of ${questionCount}`}
          >
            <h3 class="font-heading text-white text-lg md:text-xl lg:text-2xl font-semibold leading-snug mb-3 md:mb-5 max-w-lg">
              {q.text}
            </h3>

            <div
              class:list={[
                'quiz-options grid gap-1.5 md:gap-2',
                q.options.length <= 5
                  ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-2'
                  : 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
              ]}
              role="group"
              aria-label={`Answer options for question ${q.id}`}
            >
              {q.options.map((opt) => (
                <button
                  type="button"
                  class="quiz-chip group/chip relative flex flex-col items-center justify-center text-center
                         px-2 py-2 md:px-3 md:py-3 min-h-[44px] md:min-h-[56px]
                         bg-white/5 backdrop-blur-sm border border-white/10
                         hover:bg-white/10 hover:border-white/20 hover:scale-[1.02]
                         transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]
                         focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2
                         cursor-pointer select-none"
                  role="checkbox"
                  aria-checked="false"
                  data-letter={opt.letter}
                  data-q={i}
                >
                  <!-- Checkmark indicator (top-right, shown when selected) -->
                  <span class="quiz-chip-check absolute top-1.5 right-1.5 w-4 h-4 flex items-center justify-center
                               rounded-full bg-accent/0 text-white/0 text-[10px] leading-none
                               transition-all duration-200">
                    &#10003;
                  </span>
                  <span class="font-heading text-xl md:text-2xl leading-none text-accent/70 mb-1.5
                               group-hover/chip:text-accent transition-colors duration-200">
                    {opt.letter}
                  </span>
                  <span class="font-body text-xs md:text-sm text-white/70 leading-snug
                               group-hover/chip:text-white/90 transition-colors duration-200">
                    {opt.text}
                  </span>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation bar -->
      <div class="quiz-nav flex items-center justify-between mt-auto pt-3 border-t border-white/10">
        <!-- Back button -->
        <button
          type="button"
          class="quiz-btn-back font-body text-sm text-white/50 hover:text-white
                 transition-colors duration-200 flex items-center gap-1.5 cursor-pointer
                 disabled:opacity-0 disabled:pointer-events-none disabled:cursor-default
                 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
          disabled
          aria-label="Previous question"
        >
          <span aria-hidden="true">&larr;</span> Back
        </button>

        <!-- Progress dots -->
        <div class="quiz-dots flex items-center gap-2" role="tablist" aria-label="Quiz progress">
          {Array.from({ length: questionCount }).map((_, i) => (
            <button
              type="button"
              class:list={[
                'quiz-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]',
                'cursor-pointer hover:scale-150 hover:bg-accent/60',
                'disabled:cursor-default disabled:hover:scale-100 disabled:hover:bg-white/20',
                'focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2',
                i === 0
                  ? 'bg-accent scale-125 shadow-[0_0_8px_rgba(184,151,126,0.5)]'
                  : 'bg-white/20',
              ]}
              data-dot={i}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Question ${i + 1}`}
              tabindex={i === 0 ? 0 : -1}
              disabled={i > 0}
            />
          ))}
        </div>

        <!-- Next / See Results button -->
        <button
          type="button"
          class="quiz-btn-next font-body text-sm text-accent hover:text-accent-light
                 transition-colors duration-200 flex items-center gap-1.5 cursor-pointer
                 disabled:opacity-30 disabled:pointer-events-none disabled:cursor-default
                 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
          disabled
          aria-label="Next question"
        >
          <span class="quiz-btn-next-label">Next</span> <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── CALCULATING OVERLAY ─────────────────────────────── -->
  <div class="quiz-calculating hidden" aria-label="Calculating your result">
    <div class="flex flex-col items-center justify-center h-[calc(100dvh-6rem)] max-h-[calc(100dvh-6rem)] bg-primary">
      <!-- "Discovering" text -->
      <p class="quiz-calc-text font-heading text-white text-2xl md:text-3xl mb-8 opacity-0">
        Discovering your archetype...
      </p>
      <!-- Shimmer bar -->
      <div class="quiz-shimmer-track w-64 h-px bg-white/10 rounded-full overflow-hidden">
        <div class="quiz-shimmer-bar h-full bg-accent rounded-full"></div>
      </div>
    </div>
  </div>

  <!-- ── TEASER WORDS OVERLAY ────────────────────────────── -->
  <div class="quiz-teaser hidden" aria-label="Teaser words">
    <div class="flex items-center justify-center h-[calc(100dvh-6rem)] max-h-[calc(100dvh-6rem)] bg-primary">
      <span class="quiz-teaser-word font-heading text-white text-4xl md:text-6xl opacity-0"></span>
    </div>
  </div>

  <!-- ── "YOU ARE" REVEAL TEXT ────────────────────────────── -->
  <div class="quiz-youare hidden" aria-label="You are reveal">
    <div class="flex items-center justify-center h-[calc(100dvh-6rem)] max-h-[calc(100dvh-6rem)] bg-primary">
      <span class="quiz-youare-text font-body text-accent text-sm md:text-base tracking-widest uppercase opacity-0">You are...</span>
    </div>
  </div>

  <!-- ── RESULTS VIEW ──────────────────────────────────────── -->
  <div class="quiz-results hidden h-[calc(100dvh-6rem)] max-h-[calc(100dvh-6rem)] overflow-y-auto overflow-x-hidden quiz-hide-scrollbar" aria-label="Your style archetype result">
    <div class="flex flex-col items-center text-center py-8 md:py-12 px-6">

      <p class="font-body text-xs tracking-widest uppercase text-accent mb-4">Your Style Archetype</p>
      <div class="w-12 h-px bg-accent mb-6"></div>

      <!-- Primary archetype card with triptych -->
      <div class="quiz-result-primary w-full max-w-3xl mb-6">
        <!-- Triptych: 3 images, center larger -->
        <div class="quiz-triptych hidden md:grid grid-cols-[1fr_1.2fr_1fr] gap-2 mb-6">
          <div class="relative aspect-[3/4] overflow-hidden rounded-sm">
            <img class="quiz-result-img-1 absolute inset-0 w-full h-full object-cover object-center" src="" alt="" loading="lazy" />
          </div>
          <div class="relative aspect-[3/4] overflow-hidden rounded-sm">
            <img class="quiz-result-img-2 absolute inset-0 w-full h-full object-cover object-center" src="" alt="" loading="lazy" />
            <!-- Gradient overlay for center image -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent pointer-events-none"></div>
            <!-- Archetype color accent line -->
            <div class="quiz-result-accent-line absolute top-0 left-0 right-0 h-1"></div>
          </div>
          <div class="relative aspect-[3/4] overflow-hidden rounded-sm">
            <img class="quiz-result-img-3 absolute inset-0 w-full h-full object-cover object-center" src="" alt="" loading="lazy" />
          </div>
        </div>
        <!-- Single image on mobile -->
        <div class="quiz-single-img md:hidden relative w-full max-w-sm mx-auto aspect-[3/4] overflow-hidden rounded-sm mb-6">
          <img class="quiz-result-img-mobile absolute inset-0 w-full h-full object-cover object-center" src="" alt="" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent pointer-events-none"></div>
          <div class="quiz-result-accent-line-mobile absolute top-0 left-0 right-0 h-1"></div>
        </div>

        <!-- Archetype icon + name -->
        <div class="flex items-center justify-center gap-3 mb-3">
          <span class="quiz-result-icon text-3xl md:text-4xl text-accent"></span>
          <h3 class="quiz-result-name font-heading text-white text-4xl md:text-5xl font-semibold"></h3>
        </div>

        <!-- Description as pull-quote -->
        <blockquote class="quiz-result-desc font-body text-white/70 text-base md:text-lg leading-relaxed max-w-xl mx-auto italic border-l-2 border-accent/40 pl-4 text-left"></blockquote>
