    75%  { transform: scale(0.97) rotate(-0.5deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  .quiz-entrance-the-creator .quiz-result-primary {
    animation: creator-entrance 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Empress — regal rise from below, smooth */
  @keyframes empress-entrance {
    0%   { opacity: 0; transform: translateY(50px) scale(0.95); }
    60%  { opacity: 1; transform: translateY(-6px) scale(1.01); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .quiz-entrance-the-empress .quiz-result-primary {
    animation: empress-entrance 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Feminine: The Angelic One — soft glow/halo, light fade-in */
  @keyframes angelic-entrance {
    0%   { opacity: 0; transform: scale(0.95); filter: brightness(1.6) blur(8px); }
    50%  { opacity: 0.7; filter: brightness(1.3) blur(3px); }
    80%  { opacity: 0.95; transform: scale(1.01); filter: brightness(1.1) blur(0px); }
    100% { opacity: 1; transform: scale(1); filter: brightness(1) blur(0px); }
  }
  .quiz-entrance-the-angelic-one .quiz-result-primary {
    animation: angelic-entrance 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Masculine: The Protector — solid ground-up slide */
  @keyframes protector-entrance {
    0%   { opacity: 0; transform: translateY(40px); }
    70%  { opacity: 1; transform: translateY(-3px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .quiz-entrance-the-protector .quiz-result-primary {
    animation: protector-entrance 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Masculine: The Maverick — dynamic rotate + slide */
  @keyframes maverick-entrance {
    0%   { opacity: 0; transform: translateX(50px) rotate(4deg) scale(0.9); }
    60%  { opacity: 1; transform: translateX(-5px) rotate(-1deg) scale(1.02); }
    100% { opacity: 1; transform: translateX(0) rotate(0deg) scale(1); }
  }
  .quiz-entrance-the-maverick .quiz-result-primary {
    animation: maverick-entrance 600ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Masculine: The Architect — precise geometric slide-in */
  @keyframes architect-entrance {
    0%   { opacity: 0; transform: translateY(-30px) scaleY(0.9); clip-path: inset(0 0 100% 0); }
    60%  { opacity: 1; clip-path: inset(0 0 0% 0); }
    100% { opacity: 1; transform: translateY(0) scaleY(1); clip-path: inset(0 0 0% 0); }
  }
  .quiz-entrance-the-architect .quiz-result-primary {
    animation: architect-entrance 600ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Masculine: The Alchemist — morphing dissolve-in */
  @keyframes alchemist-entrance {
    0%   { opacity: 0; transform: scale(1.1) rotate(1deg); filter: blur(10px) saturate(0.3); }
    40%  { opacity: 0.5; filter: blur(5px) saturate(0.6); }
    70%  { opacity: 0.9; transform: scale(1.01) rotate(0deg); filter: blur(1px) saturate(0.9); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); filter: blur(0px) saturate(1); }
  }
  .quiz-entrance-the-alchemist .quiz-result-primary {
    animation: alchemist-entrance 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Masculine: The Sovereign — quiet scale from center */
  @keyframes sovereign-entrance {
    0%   { opacity: 0; transform: scale(0.9); }
    60%  { opacity: 1; transform: scale(1.015); }
    100% { opacity: 1; transform: scale(1); }
  }
  .quiz-entrance-the-sovereign .quiz-result-primary {
    animation: sovereign-entrance 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* ── Results card entrance (generic fallback) ───────────── */
  .quiz-result-entering .quiz-result-primary {
    animation: quiz-result-card-in 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes quiz-result-card-in {
    from {
      opacity: 0;
      transform: scale(0.9) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .quiz-result-entering .quiz-result-name {
    animation: quiz-result-name-in 600ms cubic-bezier(0.16, 1, 0.3, 1) 300ms both;
  }

  @keyframes quiz-result-name-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Toast visible state ──────────────────────────────────── */
  .quiz-toast-visible {
    opacity: 1 !important;
    transform: translate(-50%, 0) !important;
    pointer-events: auto !important;
  }

  /* ── Hide scrollbars while keeping scroll functional ──────── */
  .quiz-hide-scrollbar {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }
  .quiz-hide-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  /* ── Reduced motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .quiz-slide,
    .quiz-slide-active,
    .quiz-slide-next,
    .quiz-slide-prev {
      transition: none !important;
      animation: none !important;
    }

    .quiz-mood-img {
      transition: none !important;
    }

    .quiz-chip {
      transition: none !important;
    }

    .quiz-dot {
      transition: none !important;
    }

    .quiz-result-entering .quiz-result-primary,
    .quiz-result-entering .quiz-result-name {
      animation: none !important;
    }

    .quiz-shimmer-bar {
      animation: none !important;
    }

    /* Disable all per-archetype entrance animations */
    .quiz-entrance-the-siren .quiz-result-primary,
    .quiz-entrance-the-muse .quiz-result-primary,
    .quiz-entrance-the-warrior .quiz-result-primary,
    .quiz-entrance-the-enchantress .quiz-result-primary,
    .quiz-entrance-the-creator .quiz-result-primary,
    .quiz-entrance-the-empress .quiz-result-primary,
    .quiz-entrance-the-angelic-one .quiz-result-primary,
    .quiz-entrance-the-protector .quiz-result-primary,
    .quiz-entrance-the-maverick .quiz-result-primary,
    .quiz-entrance-the-architect .quiz-result-primary,
    .quiz-entrance-the-alchemist .quiz-result-primary,
    .quiz-entrance-the-sovereign .quiz-result-primary {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script>
  /**
   * ArchetypeQuiz runtime — manages question navigation, answer selection,
   * scoring, cinematic results reveal, URL hash sharing, and all animations.
   *
   * Each quiz instance is self-contained, keyed by data-quiz-id.
   */
  document.querySelectorAll<HTMLElement>('.quiz-root').forEach((root) => {
    const quizId = root.dataset.quizId!;
    const gender = root.dataset.gender as 'feminine' | 'masculine';
    const questions: Array<{
      id: number;
      text: string;
      image: string;
      options: Array<{ letter: string; text: string }>;
    }> = JSON.parse(root.dataset.questions!);
    const archetypesMeta: Record<string, { name: string; icon: string; color: string; slug: string; desc: string }> =
      JSON.parse(root.dataset.archetypes!);

    const TOTAL = questions.length;
    const EASE_OUT = 'cubic-bezier(0.16, 1, 0.3, 1)';
    const SLIDE_DURATION = 400;
    const IMAGE_DURATION = 600;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Teaser words per archetype ─────────────────────── */
    const feminineTeaserWords: Record<string, string[]> = {
      A: ['Bold', 'Captivating', 'Magnetic'],
      B: ['Soft', 'Dreamy', 'Ethereal'],
      C: ['Driven', 'Powerful', 'Commanding'],
      D: ['Mysterious', 'Alluring', 'Intense'],
      E: ['Expressive', 'Playful', 'Unforgettable'],
      F: ['Nurturing', 'Grounding', 'Elegant'],
      G: ['Kind', 'Peaceful', 'Gentle'],
    };

    const masculineTeaserWords: Record<string, string[]> = {
      A: ['Steady', 'Capable', 'Grounded'],
      B: ['Free', 'Unpredictable', 'Expressive'],
      C: ['Precise', 'Intentional', 'Calculated'],
      D: ['Deep', 'Transformative', 'Layered'],
      E: ['Aligned', 'Effortless', 'Centered'],
    };

    const teaserWords = gender === 'feminine' ? feminineTeaserWords : masculineTeaserWords;

    /* ── State ─────────────────────────────────────────────── */
    let currentQ = 0;
    let animating = false;
    const answers = new Map<number, Set<string>>();
    const visited = new Set<number>([0]);

    /* ── DOM refs ──────────────────────────────────────────── */
    const quizBody     = root.querySelector<HTMLElement>('.quiz-body')!;
    const resultsView  = root.querySelector<HTMLElement>('.quiz-results')!;
    const slides       = root.querySelectorAll<HTMLElement>('.quiz-slide');
    const moodImgs     = root.querySelectorAll<HTMLImageElement>('.quiz-mood-img');
    const dots         = root.querySelectorAll<HTMLButtonElement>('.quiz-dot');
    const btnBack      = root.querySelector<HTMLButtonElement>('.quiz-btn-back')!;
    const btnNext      = root.querySelector<HTMLButtonElement>('.quiz-btn-next')!;
    const nextLabel    = root.querySelector<HTMLElement>('.quiz-btn-next-label')!;
    const qCurrentEls  = root.querySelectorAll<HTMLElement>('.quiz-q-current');
    const liveRegion   = document.getElementById(`quiz-${quizId}-live`)!;

    /* Cinematic reveal refs */
    const calculatingEl = root.querySelector<HTMLElement>('.quiz-calculating')!;
    const calcText      = root.querySelector<HTMLElement>('.quiz-calc-text')!;
    const teaserEl      = root.querySelector<HTMLElement>('.quiz-teaser')!;
    const teaserWord    = root.querySelector<HTMLElement>('.quiz-teaser-word')!;
    const youareEl      = root.querySelector<HTMLElement>('.quiz-youare')!;
    const youareText    = root.querySelector<HTMLElement>('.quiz-youare-text')!;

    /* Results refs */
    const resultImg1       = root.querySelector<HTMLImageElement>('.quiz-result-img-1');
    const resultImg2       = root.querySelector<HTMLImageElement>('.quiz-result-img-2');
    const resultImg3       = root.querySelector<HTMLImageElement>('.quiz-result-img-3');
    const resultImgMobile  = root.querySelector<HTMLImageElement>('.quiz-result-img-mobile');
    const resultAccentLine = root.querySelector<HTMLElement>('.quiz-result-accent-line');
    const resultAccentLineMobile = root.querySelector<HTMLElement>('.quiz-result-accent-line-mobile');
    const resultIcon      = root.querySelector<HTMLElement>('.quiz-result-icon')!;
    const resultName      = root.querySelector<HTMLElement>('.quiz-result-name')!;
    const resultDesc      = root.querySelector<HTMLElement>('.quiz-result-desc')!;
    const resultSecondary = root.querySelector<HTMLElement>('.quiz-result-secondary')!;
    const resultSecIcon   = root.querySelector<HTMLElement>('.quiz-result-sec-icon')!;
    const resultSecName   = root.querySelector<HTMLElement>('.quiz-result-sec-name')!;
    const resultSecDesc   = root.querySelector<HTMLElement>('.quiz-result-sec-desc')!;
    const btnShare        = root.querySelector<HTMLButtonElement>('.quiz-btn-share')!;
    const btnShop         = root.querySelector<HTMLAnchorElement>('.quiz-btn-shop')!;
    const btnSwitch       = root.querySelector<HTMLButtonElement>('.quiz-btn-switch')!;
    const btnRetake       = root.querySelector<HTMLButtonElement>('.quiz-btn-retake')!;
    const btnBackToCards  = root.querySelector<HTMLButtonElement>('.quiz-btn-back-to-cards')!;
    const btnRestart      = root.querySelector<HTMLButtonElement>('.quiz-btn-restart')!;
    const btnCloseX       = root.querySelector<HTMLButtonElement>('.quiz-btn-close-x')!;
    const toast           = root.querySelector<HTMLElement>('.quiz-toast')!;

    /* ── Helpers ───────────────────────────────────────────── */

    /** Promise-based setTimeout for async sequences */
    function wait(ms: number): Promise<void> {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    function updateQCounter() {
      qCurrentEls.forEach(el => { el.textContent = String(currentQ + 1); });
      liveRegion.textContent = `Question ${currentQ + 1} of ${TOTAL}`;
    }

    function updateDots() {
      dots.forEach((dot, i) => {
        const isCurrent = i === currentQ;
        const isVisited = visited.has(i);
        const hasAnswer = answers.has(i) && answers.get(i)!.size > 0;

        dot.disabled = !isVisited;
        dot.setAttribute('aria-selected', String(isCurrent));
        dot.tabIndex = isCurrent ? 0 : -1;

        // Styling
        dot.className = 'quiz-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2';

        if (isCurrent) {
          dot.classList.add('bg-accent', 'scale-125');
          dot.style.boxShadow = '0 0 8px rgba(184,151,126,0.5)';
        } else if (hasAnswer) {
          dot.classList.add('bg-accent/60');
          dot.style.boxShadow = '';
        } else if (isVisited) {
          dot.classList.add('bg-white/35');
          dot.style.boxShadow = '';
        } else {
          dot.classList.add('bg-white/20');
          dot.style.boxShadow = '';
        }
      });
    }

    function updateNav() {
      btnBack.disabled = currentQ === 0;
      const hasSelection = answers.has(currentQ) && answers.get(currentQ)!.size > 0;
      btnNext.disabled = !hasSelection;

      if (currentQ === TOTAL - 1) {
        nextLabel.textContent = 'See Results';
        btnNext.setAttribute('aria-label', 'See your results');
      } else {
        nextLabel.textContent = 'Next';
        btnNext.setAttribute('aria-label', 'Next question');
      }
    }

    function updateChipStates(slideIndex: number) {
      const slide = slides[slideIndex];
      if (!slide) return;
      const selected = answers.get(slideIndex) ?? new Set<string>();
      slide.querySelectorAll<HTMLButtonElement>('.quiz-chip').forEach(chip => {
        const letter = chip.dataset.letter!;
        const isSelected = selected.has(letter);
        chip.setAttribute('aria-checked', String(isSelected));
      });
    }

    /* ── Slide transition ──────────────────────────────────── */

    async function goToQuestion(target: number, direction: 'forward' | 'back') {
      if (animating || target === currentQ || target < 0 || target >= TOTAL) return;
      animating = true;

      const outSlide = slides[currentQ];
      const inSlide  = slides[target];

      const outX = direction === 'forward' ? '-40px' : '40px';
      const inX  = direction === 'forward' ? '40px'  : '-40px';

      if (reducedMotion) {
        outSlide.classList.remove('quiz-slide-active');
        outSlide.classList.add(direction === 'forward' ? 'quiz-slide-prev' : 'quiz-slide-next');
        inSlide.classList.remove('quiz-slide-next', 'quiz-slide-prev');
        inSlide.classList.add('quiz-slide-active');
      } else {
        // Animate out current slide
        const outAnim = outSlide.animate(
          [
            { opacity: 1, transform: 'translateX(0)' },
            { opacity: 0, transform: `translateX(${outX})` },
          ],
          { duration: SLIDE_DURATION, easing: EASE_OUT, fill: 'forwards' }
        );

        // Animate in new slide
        inSlide.classList.remove('quiz-slide-next', 'quiz-slide-prev');
        inSlide.style.opacity = '0';
        inSlide.style.transform = `translateX(${inX})`;
        inSlide.classList.add('quiz-slide-active');

        // Small stagger for the incoming slide
        await new Promise(r => setTimeout(r, 80));

        const inAnim = inSlide.animate(
          [
            { opacity: 0, transform: `translateX(${inX})` },
            { opacity: 1, transform: 'translateX(0)' },
          ],
          { duration: SLIDE_DURATION, easing: EASE_OUT, fill: 'forwards' }
        );

        await Promise.all([outAnim.finished, inAnim.finished]);

        // Clean up animation states
        outAnim.cancel();
        inAnim.cancel();

        outSlide.classList.remove('quiz-slide-active');
        outSlide.classList.add(direction === 'forward' ? 'quiz-slide-prev' : 'quiz-slide-next');
        outSlide.style.opacity = '';
        outSlide.style.transform = '';

        inSlide.style.opacity = '';
        inSlide.style.transform = '';
      }

      // Crossfade mood images
      moodImgs.forEach((img, i) => {
        img.style.opacity = i === target ? '1' : '0';
      });

      currentQ = target;
      visited.add(currentQ);

      updateQCounter();
      updateDots();
      updateNav();
      updateChipStates(currentQ);

      // Focus first chip in new question for keyboard users
      const firstChip = inSlide.querySelector<HTMLButtonElement>('.quiz-chip');
      if (firstChip) {
        // Delay focus slightly to let transition settle
        setTimeout(() => firstChip.focus({ preventScroll: true }), reducedMotion ? 0 : 100);
      }

      animating = false;
    }

    /* ── Scoring ───────────────────────────────────────────── */

    function calculateResults(): { primary: string; secondary: string | null } {
      const counts = new Map<string, number>();
      for (const [, letters] of answers) {
        for (const letter of letters) {
          counts.set(letter, (counts.get(letter) ?? 0) + 1);
        }
      }

      const sorted = [...counts.entries()].sort((a, b) => b[1] - a[1]);
      const primary = sorted[0]?.[0] ?? 'A';
      const secondary = sorted.length > 1 && sorted[1][1] >= 2 ? sorted[1][0] : null;

      return { primary, secondary };
    }

    /* ── Populate Results Data ─────────────────────────────── */

    function populateResults(primary: string, secondary: string | null) {
      const pMeta = archetypesMeta[primary];
      if (!pMeta) return;

      // Triptych images
      if (resultImg1) resultImg1.src = `/images/archetypes/${pMeta.slug}-1.webp`;
      if (resultImg2) resultImg2.src = `/images/archetypes/${pMeta.slug}-2.webp`;
      if (resultImg3) resultImg3.src = `/images/archetypes/${pMeta.slug}-3.webp`;
      if (resultImgMobile) {
        resultImgMobile.src = `/images/archetypes/${pMeta.slug}-1.webp`;
        resultImgMobile.alt = pMeta.name;
      }
      if (resultImg1) resultImg1.alt = `${pMeta.name} look 1`;
      if (resultImg2) resultImg2.alt = `${pMeta.name} look 2`;
      if (resultImg3) resultImg3.alt = `${pMeta.name} look 3`;

      // Accent lines
      if (resultAccentLine) resultAccentLine.style.backgroundColor = pMeta.color;
      if (resultAccentLineMobile) resultAccentLineMobile.style.backgroundColor = pMeta.color;

      resultIcon.textContent = pMeta.icon;
      resultName.textContent = pMeta.name;
      resultDesc.textContent = pMeta.desc;

      // Populate secondary
      if (secondary) {
        const sMeta = archetypesMeta[secondary];
        if (sMeta) {
          resultSecIcon.textContent = sMeta.icon;
          resultSecName.textContent = sMeta.name;
          resultSecDesc.textContent = sMeta.desc;
          resultSecondary.classList.remove('hidden');
        }
      } else {
        resultSecondary.classList.add('hidden');
      }

      // Shop link: link to the archetype's page on the site
      btnShop.href = `/archetypes/${pMeta.slug}`;

      // Update URL hash for sharing
      const hashParts = ['#quiz', gender, pMeta.slug];
      if (secondary) {
        const sMeta = archetypesMeta[secondary];
        if (sMeta) hashParts.push(sMeta.slug);
      }
      history.replaceState(null, '', hashParts.join('/'));
    }

    /* ── Cinematic Results Reveal ──────────────────────────── */

    async function showResults() {
      const { primary, secondary } = calculateResults();
      const pMeta = archetypesMeta[primary];
      if (!pMeta) return;

      // Populate all results data first (while hidden)
      populateResults(primary, secondary);

      // If reduced motion, skip the cinematic sequence
      if (reducedMotion) {
        quizBody.classList.add('hidden');
        resultsView.classList.remove('hidden');
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }

      // ── Phase 1: Calculating overlay (1.5s) ──
      quizBody.classList.add('hidden');
      calculatingEl.classList.remove('hidden');
      root.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // Fade in the calculating text
      await wait(100);
      calcText.style.transition = 'opacity 400ms ease-out';
      calcText.style.opacity = '1';

      await wait(1500);

      // Fade out calculating
      calcText.style.opacity = '0';
      await wait(300);
      calculatingEl.classList.add('hidden');

      // ── Phase 2: Teaser words (3 words x ~600ms each) ──
      const words = teaserWords[primary] || ['Bold', 'Unique', 'You'];
      teaserEl.classList.remove('hidden');

      for (const word of words) {
        teaserWord.textContent = word;
        // Fade in
        teaserWord.style.transition = 'opacity 200ms ease-out';
        teaserWord.style.opacity = '1';
        await wait(500); // hold (200ms fade-in + 300ms hold)
        // Fade out
        teaserWord.style.opacity = '0';
        await wait(200);
      }

      teaserEl.classList.add('hidden');

      // ── Phase 3: "You are..." text (500ms) ──
      youareEl.classList.remove('hidden');
      await wait(50);
      youareText.style.transition = 'opacity 250ms ease-out';
      youareText.style.opacity = '1';
      await wait(500);
      youareText.style.opacity = '0';
      await wait(200);
      youareEl.classList.add('hidden');

      // ── Phase 4: Archetype entrance ──
      // Apply per-archetype entrance class
      const entranceClass = `quiz-entrance-${pMeta.slug}`;
      resultsView.classList.add(entranceClass);
      resultsView.classList.remove('hidden');

      // Clean up entrance class after animation completes
      await wait(1200);
      resultsView.classList.remove(entranceClass);
    }

    /* ── Reset Quiz ────────────────────────────────────────── */

    function resetQuiz() {
      answers.clear();
      visited.clear();
      visited.add(0);
      currentQ = 0;
      animating = false;

      // Reset all chips
      root.querySelectorAll<HTMLButtonElement>('.quiz-chip').forEach(chip => {
        chip.setAttribute('aria-checked', 'false');
      });

      // Reset slides
      slides.forEach((slide, i) => {
        slide.classList.remove('quiz-slide-active', 'quiz-slide-next', 'quiz-slide-prev');
        slide.classList.add(i === 0 ? 'quiz-slide-active' : 'quiz-slide-next');
        slide.style.opacity = '';
        slide.style.transform = '';
      });

      // Reset images
      moodImgs.forEach((img, i) => {
        img.style.opacity = i === 0 ? '1' : '0';
      });

      // Hide results & cinematic overlays, show quiz
      resultsView.classList.add('hidden');
      calculatingEl.classList.add('hidden');
      teaserEl.classList.add('hidden');
      youareEl.classList.add('hidden');
      quizBody.classList.remove('hidden');

      // Reset cinematic element opacities
      calcText.style.opacity = '0';
      teaserWord.style.opacity = '0';
      youareText.style.opacity = '0';

      updateQCounter();
      updateDots();
      updateNav();

      // Clear hash
      history.replaceState(null, '', window.location.pathname + window.location.search);

      root.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* ── Event bindings ────────────────────────────────────── */

    // Answer chip clicks
    root.querySelectorAll<HTMLButtonElement>('.quiz-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const qIndex = parseInt(chip.dataset.q!, 10);
        const letter = chip.dataset.letter!;

        if (!answers.has(qIndex)) answers.set(qIndex, new Set());
        const selected = answers.get(qIndex)!;

        if (selected.has(letter)) {
          selected.delete(letter);
        } else {
          selected.add(letter);
        }

        chip.setAttribute('aria-checked', String(selected.has(letter)));
        updateNav();
        updateDots();
      });

      // Keyboard support: Space and Enter to toggle
      chip.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') {
          e.preventDefault();
          chip.click();
        }
      });
    });

    // Next button
    btnNext.addEventListener('click', () => {
      if (currentQ === TOTAL - 1) {
        showResults();
      } else {
        goToQuestion(currentQ + 1, 'forward');
      }
    });

    // Back button
    btnBack.addEventListener('click', () => {
      goToQuestion(currentQ - 1, 'back');
    });

    // Dot navigation
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (!visited.has(i)) return;
        const dir = i > currentQ ? 'forward' : 'back';
        goToQuestion(i, dir);
      });
    });

    // Share button
    btnShare.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        toast.classList.add('quiz-toast-visible');
        setTimeout(() => toast.classList.remove('quiz-toast-visible'), 2500);
      } catch {
        // Fallback for older browsers
        const input = document.createElement('input');
        input.value = window.location.href;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        toast.classList.add('quiz-toast-visible');
        setTimeout(() => toast.classList.remove('quiz-toast-visible'), 2500);
      }
    });

    // Retake button (on results screen)
    btnRetake.addEventListener('click', resetQuiz);

    // Back to archetypes button (on results screen)
    btnBackToCards.addEventListener('click', () => {
      resetQuiz();
      root.dispatchEvent(new CustomEvent('quiz:exit', { bubbles: true }));
    });

    // Restart button (top bar, during quiz) — resets to Q1
    btnRestart.addEventListener('click', resetQuiz);

    // Close X button (top bar, during quiz) — exits quiz entirely
    btnCloseX.addEventListener('click', () => {
      resetQuiz();
      root.dispatchEvent(new CustomEvent('quiz:exit', { bubbles: true }));
    });

    // Switch to other gender quiz
    btnSwitch.addEventListener('click', () => {
      const otherGender = gender === 'feminine' ? 'masculine' : 'feminine';
      // Dispatch event for the page to handle the gender switch
      root.dispatchEvent(new CustomEvent('quiz:switch-gender', {
        bubbles: true,
        detail: { targetGender: otherGender },
      }));
    });

    /* ── Hash-based result restore ─────────────────────────── */

    function checkHashResults() {
      const hash = window.location.hash;
      if (!hash) return;

      // Pattern: #quiz/feminine/the-siren or #quiz/feminine/the-siren/the-muse
      const match = hash.match(/^#quiz\/(feminine|masculine)\/([\w-]+)(?:\/([\w-]+))?$/);
      if (!match) return;

      const [, hashGender, primarySlug, secondarySlug] = match;
      if (hashGender !== gender) return;

      // Find letter for primary slug
      let primaryLetter: string | null = null;
      let secondaryLetter: string | null = null;

      for (const [letter, meta] of Object.entries(archetypesMeta)) {
        if (meta.slug === primarySlug) primaryLetter = letter;
        if (secondarySlug && meta.slug === secondarySlug) secondaryLetter = letter;
      }

      if (!primaryLetter) return;

      // Populate the result display directly (skip cinematic for hash-restore)
      populateResults(primaryLetter, secondaryLetter);

      quizBody.classList.add('hidden');
      resultsView.classList.remove('hidden');

      // Make the quiz container visible and scroll to it
      const container = root.closest('[id$="-quiz-container"]') as HTMLElement | null;
      if (container) {
        container.classList.remove('hidden');
        // Also hide the cards grid
        const gridSection = container.closest('.relative.z-10')?.querySelector('.grid') as HTMLElement | null;
        if (gridSection) gridSection.classList.add('hidden');
      }

      requestAnimationFrame(() => {
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    // Check on load
    checkHashResults();

    /* ── Initialize ────────────────────────────────────────── */
    updateNav();
    updateDots();
  });
</script>
