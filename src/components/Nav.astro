---
interface Props {
  transparentNav?: boolean;
}

const { transparentNav = false } = Astro.props;

// Three-column centered layout: [left] [brand mark] [right]
// "Home" removed — logo IS the home link.
// Left: credibility stack — who she is · what she does · proof of work
const leftItems = [
  { label: 'About',    href: '/about'    },
  { label: 'Services', href: '/services' },
  { label: 'Clients',  href: '/clients'  },
];

// Right: discovery/action stack — the framework · buy · book
const rightItems = [
  { label: 'Archetypes', href: '/archetypes' },
  { label: 'Shop',       href: '/shop'       },
  { label: 'Contact',    href: '/contact'    },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-nav"
  class:list={[
    'z-50 border-b',
    transparentNav
      ? 'absolute top-0 left-0 right-0 nav-transparent border-transparent'
      : 'relative bg-background/95 backdrop-blur-sm border-surface-dark',
  ]}
>
  <nav class="mx-auto max-w-7xl px-6 lg:px-8" aria-label="Primary navigation">

    <!-- ── Desktop: three-column centered layout ─────────── -->
    <!-- grid-cols-[1fr_auto_1fr]: equal wings, brand mark naturally centered -->
    <div class="hidden lg:grid lg:grid-cols-[1fr_auto_1fr] items-center h-20">

      <!-- Left items -->
      <ul class="flex items-center gap-8">
        {leftItems.map((item) => {
          const isActive = currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class="nav-link font-body text-xs tracking-widest uppercase"
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Center: brand mark -->
      <a
        href="/"
        class="nav-brand font-heading text-2xl font-semibold tracking-wide px-10 whitespace-nowrap"
        aria-label="Staples & Statements — Home"
      >
        Staples & Statements
      </a>

      <!-- Right items -->
      <ul class="flex items-center gap-8 justify-end">
        {rightItems.map((item) => {
          const isActive = currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class="nav-link font-body text-xs tracking-widest uppercase"
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

    </div>

    <!-- ── Mobile: logo left, hamburger right ─────────────── -->
    <div class="flex items-center justify-between h-16 lg:hidden">
      <a
        href="/"
        class="nav-brand font-heading text-xl font-semibold tracking-wide"
        aria-label="Staples & Statements — Home"
      >
        Staples & Statements
      </a>

      <button
        id="mobile-menu-btn"
        type="button"
        class="flex flex-col justify-center items-center w-11 h-11 gap-1.5"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span id="bar-top"    class="nav-bar block w-6 h-0.5 transition-all duration-300 origin-center"></span>
        <span id="bar-mid"    class="nav-bar block w-6 h-0.5 transition-all duration-300"></span>
        <span id="bar-bottom" class="nav-bar block w-6 h-0.5 transition-all duration-300 origin-center"></span>
      </button>
    </div>

    <!-- ── Mobile menu ─────────────────────────────────────── -->
    <div id="mobile-menu" class="lg:hidden hidden">
      <ul class="flex flex-col pb-6 pt-2 gap-1">
        {[...leftItems, ...rightItems].map((item) => {
          const isActive = currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block py-3 px-2 font-body text-sm tracking-widest uppercase transition-colors duration-200 border-l-2',
                  isActive
                    ? 'text-accent font-medium border-accent bg-surface/50'
                    : 'text-text-muted hover:text-primary border-transparent hover:border-secondary-light hover:bg-surface/30',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>

  </nav>
</header>

<!-- No spacer needed — nav is in normal document flow (non-transparent) or
     absolute-positioned over the hero (transparent). -->

<script>
  // ── Mobile menu ─────────────────────────────────────────────────────────
  // Uses astro:page-load so this re-runs after every ViewTransitions navigation.
  // dataset.menuInitialized guards against duplicate listeners on the persistent
  // nav element (layout components are not re-rendered, just script-re-run).

  function initMobileMenu(): void {
    const menuBtn    = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
    const mobileMenu = document.getElementById('mobile-menu')    as HTMLElement | null;
    const barTop     = document.getElementById('bar-top')        as HTMLElement | null;
    const barMid     = document.getElementById('bar-mid')        as HTMLElement | null;
    const barBottom  = document.getElementById('bar-bottom')     as HTMLElement | null;

    if (!menuBtn || !mobileMenu) return;

    // Prevent duplicate listeners on the persistent nav element
    if (menuBtn.dataset.menuInitialized === 'true') return;
    menuBtn.dataset.menuInitialized = 'true';

    function closeMenu(): void {
      menuBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.add('hidden');
      if (barTop && barMid && barBottom) {
        barTop.style.transform    = '';
        barMid.style.opacity      = '';
        barBottom.style.transform = '';
      }
    }

    menuBtn.addEventListener('click', () => {
      const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
      const willOpen = !isOpen;

      menuBtn.setAttribute('aria-expanded', String(willOpen));
      mobileMenu.classList.toggle('hidden', !willOpen);

      // Animate hamburger → X and back with explicit CSS
      if (barTop && barMid && barBottom) {
        if (willOpen) {
          barTop.style.transform    = 'translateY(8px) rotate(45deg)';
          barMid.style.opacity      = '0';
          barBottom.style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          barTop.style.transform    = '';
          barMid.style.opacity      = '';
          barBottom.style.transform = '';
        }
      }
    });

    // Escape key closes open menu and returns focus to hamburger button
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuBtn.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        menuBtn.focus();
      }
    });
  }

  // ── Scroll behavior: transparent-to-solid restore ───────────────────────
  // Single rAF-throttled scroll listener handles:
  //   nav-scrolled  — warm drop shadow + background restore on transparent pages
  //
  // Nav is ALWAYS visible (no hide/show). The nav-hidden class is never applied.
  //
  // Uses AbortController so the listener is cleanly replaced on re-init
  // (important if this somehow runs more than once via page-load).

  let scrollController: AbortController | null = null;

  function initScrollBehavior(): void {
    const nav = document.getElementById('site-nav') as HTMLElement | null;
    if (!nav) return;

    // Tear down previous scroll listener if re-running
    scrollController?.abort();
    scrollController = new AbortController();

    let ticking = false;

    function updateNav(): void {
      const y = window.scrollY;

      // Scrolled state: shadow + transparent-nav background restore
      nav.classList.toggle('nav-scrolled', y > 80);

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateNav);
        ticking = true;
      }
    }, { passive: true, signal: scrollController.signal });

    updateNav(); // Initialize on load (handles pre-scrolled state)
  }

  // Run on every page load (initial + ViewTransitions navigations)
  document.addEventListener('astro:page-load', () => {
    initMobileMenu();
    initScrollBehavior();
  });
</script>
