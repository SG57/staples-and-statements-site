---
/**
 * Marquee — continuously scrolling brand identity band.
 *
 * Variants:
 *   "dark"  (default) — bg-primary, white text. Bridges dark hero → light content.
 *   "light"           — bg-surface, muted text. Subtle rhythm strip.
 *
 * Edge fade mask gives the text an infinite-horizon feel (emerges from nothing,
 * recedes to nothing). Hover pauses. prefers-reduced-motion stops the animation.
 *
 * How it works:
 *   1. One set of items is rendered in .marquee-seed (invisible, measures natural width).
 *   2. On load, JS measures the seed width, calculates how many copies are needed
 *      to always exceed viewport width, clones them into .marquee-track, and sets
 *      --marquee-set-width to the exact pixel width of one logical set.
 *   3. The animation translates by exactly --marquee-set-width — one full set scrolls
 *      out while the next identical set takes its place. Perfectly seamless on any
 *      viewport width, including ultrawide.
 */

interface Props {
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;

const items = [
  'Staples & Statements',
  'Wardrobe Styling',
  'Style Archetypes',
  'Personal Color Analysis',
  'San Diego · Virtual',
];
---

<div
  class:list={[
    'marquee-band overflow-hidden select-none',
    variant === 'dark'
      ? 'bg-primary border-y border-white/[0.07] py-3.5'
      : 'bg-surface border-y border-surface-dark py-3',
  ]}
  aria-hidden="true"
>
  <!-- Edge fade mask — text appears to emerge from and disappear into infinity -->
  <div class="marquee-fade-mask">

    <!-- Seed: one set of items, used to measure natural width. Hidden after JS clones. -->
    <div class="marquee-seed" style="display:flex;flex-wrap:nowrap;width:max-content;align-items:center;">
      {items.map((item) => (
        <>
          <span
            class:list={[
              'marquee-item font-body text-[0.65rem] tracking-[0.2em] uppercase',
              variant === 'dark' ? 'text-white/38' : 'text-text-light',
            ]}
          >
            {item}
          </span>
          <span
            class:list={[
              'marquee-sep',
              variant === 'dark' ? 'text-accent/60' : 'text-accent/50',
            ]}
            aria-hidden="true"
          >
            ✦
          </span>
        </>
      ))}
    </div>

    <!-- Track: JS populates this with enough cloned sets to fill 2× viewport -->
    <div class="marquee-track"></div>

  </div>
</div>

<style>
  /* Fade mask: text fades at both horizontal edges */
  .marquee-fade-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    overflow: hidden;
  }

  /* Track: flex row, no wrap. Animation offset set via --marquee-set-width by JS. */
  .marquee-track {
    display: flex;
    flex-wrap: nowrap;
    width: max-content;
    align-items: center;
    gap: 0;
    animation: marquee-scroll var(--marquee-dur, 36s) linear infinite;
    will-change: transform;
  }

  /* Pause on hover — editorial convention, respects the viewer */
  .marquee-band:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    padding: 0 1.75rem;
    white-space: nowrap;
  }

  .marquee-sep {
    font-size: 0.45rem;
    flex-shrink: 0;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-1 * var(--marquee-set-width, 50%))); }
  }

  /* Reduced motion: stop scrolling entirely */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>

<script>
  function initMarquee(band: HTMLElement) {
    const seed  = band.querySelector<HTMLElement>('.marquee-seed');
    const track = band.querySelector<HTMLElement>('.marquee-track');
    if (!seed || !track) return;

    // Measure the natural width of one set of items
    const setWidth = seed.offsetWidth;
    if (setWidth === 0) return;

    const vw = window.innerWidth;

    // We need at least 2 logical sets (so one scrolls out while the other fills in).
    // Each logical set must be >= viewport width so there's never a gap.
    const copiesPerSet = Math.max(1, Math.ceil(vw / setWidth));
    const totalCopies  = copiesPerSet * 2; // 2 logical sets

    // Build the track content by cloning the seed's children
    const fragment = document.createDocumentFragment();
    for (let i = 0; i < totalCopies; i++) {
      for (const child of Array.from(seed.children)) {
        fragment.appendChild(child.cloneNode(true));
      }
    }
    track.appendChild(fragment);

    // One logical set = copiesPerSet × setWidth. The animation scrolls exactly that far.
    const logicalSetWidth = copiesPerSet * setWidth;
    track.style.setProperty('--marquee-set-width', `${logicalSetWidth}px`);

    // Scale duration so scroll speed stays constant regardless of content width.
    // Base: 36s for the original ~single-set width. Speed = setWidth / 36.
    const speed    = setWidth / 36; // px/s
    const duration = logicalSetWidth / speed;
    track.style.setProperty('--marquee-dur', `${duration.toFixed(1)}s`);

    // Hide the seed — its job is done
    seed.style.display = 'none';
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.marquee-band').forEach(initMarquee);
  });
</script>
