---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Staples & Statements"
  description="The page you're looking for doesn't exist. Let's get you back on track."
>
  <section class="flex items-center justify-center min-h-[70vh] px-6 py-20 bg-background">
    <div class="text-center max-w-lg">
      <p class="font-heading text-8xl font-semibold text-surface-dark">404</p>
      <div class="mt-4 w-8 h-px bg-accent mx-auto"></div>
      <h1 class="mt-6 font-heading text-4xl text-primary">This page doesn't exist.</h1>
      <p class="mt-4 font-body text-text-muted text-base leading-relaxed">
        The link you followed may be outdated, or the page may have moved. Let's get you back to something useful.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-primary-light transition-colors duration-200"
        >
          Go Home
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center px-8 py-4 border border-surface-dark text-text-muted font-body text-sm tracking-widest uppercase hover:border-secondary hover:text-primary transition-colors duration-200"
        >
          View Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
