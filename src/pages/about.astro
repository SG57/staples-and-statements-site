---
import BaseLayout from '../layouts/BaseLayout.astro';

const calendlyURL = '/contact';

---

<BaseLayout
  title="About Danielle Marie — Staples & Statements"
  description="Meet Danielle Marie, wardrobe stylist and creative director behind Staples & Statements. Learn about her archetype-based approach to personal style."
  transparentNav={true}
>

  <!-- ── HERO — Single static banner ── -->
  <section class="relative overflow-hidden bg-primary" aria-label="About hero">
    <div class="relative min-h-[70svh] lg:min-h-[60vh] flex flex-col">

      <!-- Hero image -->
      <img src="/images/hero-banners/cinematic-2.webp" alt="Danielle Marie — wardrobe stylist"
           class="absolute inset-0 w-full h-full object-cover" loading="eager" width="1920" height="1080" />

      <!-- Top scrim for nav legibility -->
      <div class="absolute top-0 left-0 right-0 h-24 lg:h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, transparent 100%)"></div>

      <!-- Bottom scrim for text legibility -->
      <div class="absolute bottom-0 left-0 right-0 h-[65%] lg:h-[55%] pointer-events-none z-[5]"
           style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.15) 65%, transparent 100%)"></div>

      <!-- Hero text overlay -->
      <div class="absolute inset-0 flex items-end justify-start px-6 lg:px-20 pb-10 sm:pb-14 lg:pb-16 pt-20 z-10">
        <div class="max-w-xl">
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3 text-bloom-xs">The Woman Behind the Wardrobe</p>
          <h1 class="font-heading text-white text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.05] tracking-tight text-bloom">
            Danielle Marie
          </h1>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PORTRAIT + INTRO ──────────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="About Danielle">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">

        <!-- Portrait -->
        <div class="relative">
          <!-- Add photo: public/images/about-danielle.webp — professional portrait -->
          <div class="aspect-[3/4] relative overflow-hidden bg-surface-dark img-frame">
            <img
              src="/images/about-danielle.webp"
              alt="Danielle Marie, wardrobe stylist and creative director"
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="eager"
              width="600"
              height="800"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent pointer-events-none"></div>
          </div>
          <!-- Credential badge -->
          <div class="absolute bottom-6 left-6 right-6 bg-primary/90 backdrop-blur-sm p-5">
            <p class="font-heading text-white text-xl font-semibold">Danielle Marie Holman</p>
            <p class="font-body text-white/60 text-sm mt-1">Wardrobe Stylist & Creative Director</p>
            <div class="mt-4 flex flex-col gap-2.5">

              <!-- Instagram -->
              <a href="https://instagram.com/littledanniii" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2.5 text-white/45 hover:text-accent transition-colors duration-300">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <span class="font-body text-xs tracking-wide">@littledanniii</span>
              </a>

              <!-- TikTok -->
              <a href="https://tiktok.com/@staplesandstatementsss" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2.5 text-white/45 hover:text-accent transition-colors duration-300">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
                <span class="font-body text-xs tracking-wide">@staplesandstatementsss</span>
              </a>

              <!-- Email -->
              <a href="mailto:hello@staplesandstatements.com"
                 class="inline-flex items-center gap-2.5 text-white/45 hover:text-accent transition-colors duration-300">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <span class="font-body text-xs tracking-wide">danielle.marie@staplesandstatements.com</span>
              </a>

            </div>
          </div>
        </div>

        <!-- Story text -->
        <div class="lg:pt-4">
          <div class="w-8 h-px bg-accent mb-8"></div>

          <h2 class="font-heading text-primary text-3xl lg:text-4xl font-semibold mb-6 leading-tight">
            Style is a language.<br />Danielle helps you speak it fluently.
          </h2>

          <div class="space-y-5 font-body text-text-muted text-base leading-relaxed">
            <p>
              Danielle Marie has been obsessed with clothes since before she had the vocabulary to explain why. Growing up surrounded by fashion — the editorial spreads, the department store rituals, the way a perfectly chosen outfit could transform how someone carried themselves — she understood intuitively that style wasn't vanity. It was communication.
            </p>
            <p>
              That instinct sharpened through years in high-end retail, where she developed a trained eye for proportion, fabric, and the subtle mechanics of why certain pieces work and others don't. She learned how to read bodies, understand color theory in practice, and — most importantly — how to translate what someone <em>wanted</em> to project into an actual, wearable wardrobe.
            </p>
            <p>
              The launch of Staples & Statements formalized what had always been her natural gift: helping people discover and inhabit their authentic style identity. Not a trend. Not a borrowed aesthetic. Theirs.
            </p>
            <p>
              Today, Danielle works with clients across San Diego and virtually nationwide — from first-time styling clients finding their footing to executives and entrepreneurs who understand that how they show up matters.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PHILOSOPHY ────────────────────────────────────── -->
  <section class="py-20 px-6 bg-primary" aria-label="Styling philosophy" data-compact-super="The Approach" data-compact-title="The Archetype Framework" data-compact-theme="dark">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">The Approach</p>
          <h2 class="font-heading text-white text-4xl lg:text-5xl font-semibold leading-tight">
            The Archetype Framework
          </h2>
          <p class="mt-6 font-body text-white/70 text-base leading-relaxed">
            Danielle's signature approach to styling is organized around the 7 Feminine Archetypes — a framework for understanding personal style identity that goes deeper than trends or body types.
          </p>
          <p class="mt-4 font-body text-white/70 text-base leading-relaxed">
            Your archetype is the underlying aesthetic DNA of your personal style. It reflects how you want to feel, how you want to be perceived, and what kind of visual story your wardrobe tells. When you dress in alignment with your archetype, getting dressed becomes effortless rather than exhausting.
          </p>
          <p class="mt-4 font-body text-white/70 text-base leading-relaxed">
            When Danielle shared this framework publicly, tens of thousands of women recognized themselves in it immediately — because it resonates with something real, not a trend.
          </p>
          <div class="mt-8">
            <a
              href="/archetypes"
              class="inline-flex items-center gap-2 font-body text-sm tracking-widest uppercase text-accent hover:text-accent-light transition-colors border-b border-accent pb-0.5"
            >
              Discover Your Archetype →
            </a>
          </div>
        </div>

        <!-- Secondary portrait / action shot -->
        <div class="relative">
          <!-- Archetype framework cover image -->
          <div class="aspect-square relative overflow-hidden bg-primary-light img-frame">
            <img
              src="/images/archetype-framework-cover.webp"
              alt="The Staples & Statements style archetype framework"
              class="absolute inset-0 w-full h-full object-cover no-reveal"
              loading="eager"
              width="600"
              height="600"
              onerror="this.style.display='none'"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── VALUES ────────────────────────────────────────── -->
  <section class="py-20 px-6 bg-surface" aria-label="Styling values" data-compact-super="The Principles" data-compact-title="What Danielle Believes" data-compact-theme="surface">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col items-center text-center mb-14">
        <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
        <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3 text-center">The Principles</p>
        <h2 class="font-heading text-primary text-4xl">What Danielle Believes</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {[
          {
            number: "01",
            heading: "Style is personal, never prescriptive.",
            body: "There is no universally 'correct' way to dress. Danielle's job is to help you find YOUR style — not impose someone else's aesthetic onto your life.",
          },
          {
            number: "02",
            heading: "Every body is a good body for great style.",
            body: "The work is about dressing your actual self with knowledge, intention, and confidence — not dressing for a hypothetical future body or an impossible standard.",
          },
          {
            number: "03",
            heading: "A great wardrobe is a tool, not a luxury.",
            body: "How you show up affects your confidence, your credibility, and the opportunities available to you. The investment in your wardrobe is an investment in yourself.",
          },
        ].map((value) => (
          <div class="p-8 bg-background img-frame-card">
            <p class="font-heading text-5xl font-semibold text-surface-dark mb-4">{value.number}</p>
            <h3 class="font-heading text-xl font-semibold text-primary mb-3">{value.heading}</h3>
            <p class="font-body text-text-muted text-sm leading-relaxed">{value.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="py-20 lg:py-28 px-6 bg-background" aria-label="Start your style journey">
    <div class="mx-auto max-w-3xl flex flex-col items-center text-center">
      <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
      <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3 text-center">The First Step</p>
      <h2 class="font-heading text-primary text-4xl lg:text-5xl">
        Ready to start your style journey?
      </h2>
      <p class="mt-5 font-body text-text-muted text-lg leading-relaxed max-w-lg mx-auto">
        Every client engagement begins with a free 20-minute consultation. It's a conversation — no pressure, no commitment — just clarity on where you are and where you want to be.
      </p>
      <a
        href={calendlyURL}
        class="mt-10 inline-flex items-center justify-center px-10 py-5 bg-primary text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-primary-light transition-colors duration-200"
      >
        Book Your Free Consultation
      </a>
    </div>
  </section>

</BaseLayout>
