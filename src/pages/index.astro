---
import BaseLayout from '../layouts/BaseLayout.astro';
import Marquee from '../components/Marquee.astro';
import { getCollection } from 'astro:content';
import { featuredGuides } from '../data/guides';
import { readdirSync } from 'fs';
import { join } from 'path';

// Scan hero-banners directory at build time
let heroBannerImages: string[] = [];
try {
  const dir = join(process.cwd(), 'public/images/hero-banners');
  heroBannerImages = readdirSync(dir)
    .filter(f => f.endsWith('.webp'))
    .sort()
    .map(f => `/images/hero-banners/${f}`);
} catch { /* folder doesn't exist yet — graceful fallback */ }

// Pick 6 random unique starting images at build time — no two cells start
// with the same image, and the set changes on every deploy.
function sampleUnique(arr: string[], n: number): string[] {
  const shuffled = [...arr];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled.slice(0, n);
}
const heroStart = heroBannerImages.length >= 6
  ? sampleUnique(heroBannerImages, 6)
  : [...heroBannerImages, ...heroBannerImages, ...heroBannerImages].slice(0, 6);

const allServices = await getCollection('services', ({ data }) => data.status === 'active');
const featuredServices = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .filter(s => s.data.featured)
  .slice(0, 4);

const allTestimonials = await getCollection('testimonials');
const featuredTestimonials = allTestimonials
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allArchetypes = await getCollection('archetypes', ({ data }) => data.gender === 'feminine');
const featuredArchetypes = allArchetypes
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const calendlyURL = '/contact';
---

<BaseLayout
  title="Staples & Statements — Wardrobe Styling by Danielle Marie"
  description="Expert wardrobe styling and archetype-based personal style guidance by Danielle Marie. Book a free consultation in San Diego or virtually."
  transparentNav={true}
>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-primary" aria-label="Hero">
    <!-- Transparent nav: no spacer in the flow, hero starts at top of viewport.
         Desktop: hero = 100vh - marquee (~2.75rem) so marquee peeks in first view.
         Mobile: 100svh so hero fills the screen exactly (svh = small viewport height,
         accounts for mobile browser chrome). Mosaic fills the frame, text overlays
         at the bottom with a cinematic gradient scrim for legibility. -->
    <div class="relative min-h-[100svh] lg:min-h-[calc(100vh-3rem)] flex flex-col lg:flex-row">

      <!--
        Mosaic hero grid — auto-cycling carousel
        Each cell has two stacked images (layer-a / layer-b) that crossfade.
        The client script picks random images from the full hero-banners pool,
        staggers the cells so they never all change at once, and cycles every 12s.
        Initial images are set here for fast first paint (no JS required).

        Mobile: 2-column, 2-row grid. Cell 0 is row-span-1 (equal with cells 1/2).
        The mosaic is absolutely positioned to fill the hero, with the text overlaid.
        Desktop: 3-column, 2-row grid. Cell 0 is row-span-2 (tall portrait).
      -->
      <div id="hero-mosaic" class="absolute inset-0 grid grid-cols-2 grid-rows-2 lg:grid-cols-3 lg:grid-rows-2 gap-0.5 w-full h-full">

        <!-- Cell 0 — portrait on desktop (2 rows), equal cell on mobile (1 row) -->
        <div data-hero-cell="0" class="col-span-1 row-span-1 lg:row-span-2 relative overflow-hidden bg-secondary/30 img-frame-grid">
          <img data-layer="a" src={heroStart[0]} alt="Wardrobe styling by Danielle Marie"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" width="600" height="900" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-primary/60 pointer-events-none"></div>
        </div>

        <!-- Cell 1 -->
        <div data-hero-cell="1" class="col-span-1 row-span-1 relative overflow-hidden bg-secondary/20 img-frame-grid">
          <img data-layer="a" src={heroStart[1]} alt="Editorial styling"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" width="400" height="300" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>

        <!-- Cell 2 -->
        <div data-hero-cell="2" class="col-span-1 row-span-1 relative overflow-hidden bg-primary-light img-frame-grid">
          <img data-layer="a" src={heroStart[2]} alt="Personal styling session"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" width="400" height="300" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>

        <!-- Cell 3 — visible on both mobile (fills 2×2 grid) and desktop -->
        <div data-hero-cell="3" class="col-span-1 row-span-1 relative overflow-hidden bg-secondary/40 img-frame-grid">
          <img data-layer="a" src={heroStart[3]} alt="Luxury personal styling"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" width="400" height="300" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>

        <!-- Cell 4 — desktop only -->
        <div data-hero-cell="4" class="hidden lg:block col-span-1 row-span-1 relative overflow-hidden bg-secondary/20 img-frame-grid">
          <img data-layer="a" src={heroStart[4]} alt="Editorial wardrobe styling"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="lazy" width="400" height="300" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>

        <!-- Cell 5 — desktop only -->
        <div data-hero-cell="5" class="hidden lg:block col-span-1 row-span-1 relative overflow-hidden bg-primary-light img-frame-grid">
          <img data-layer="a" src={heroStart[5]} alt="Style archetype styling"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="lazy" width="400" height="300" />
          <img data-layer="b" src="" alt="" aria-hidden="true"
               class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>

      </div>

      <!-- Nav-hood scrim: dark gradient covering the top of the hero.
           Guarantees nav link legibility regardless of image brightness.
           z-[5] sits above mosaic images but below hero text (z-10).
           Mobile: shorter (h-24) + slightly stronger. Desktop: taller (h-40). -->
      <div class="absolute top-0 left-0 right-0 h-24 lg:h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, transparent 100%)"></div>

      <!-- Bottom scrim: gradient that ensures hero text is always readable
           over the mosaic images. Covers bottom ~55% of the hero. -->
      <div class="absolute bottom-0 left-0 right-0 h-[60%] lg:h-[50%] pointer-events-none z-[5]"
           style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.45) 35%, rgba(0,0,0,0.15) 65%, transparent 100%)"></div>

      <!-- Hero text overlay — always overlaid on the mosaic (both mobile + desktop).
           Mobile: pinned to bottom with generous safe area above the fold.
           Desktop: vertically centered on the left side. -->
      <div class="absolute inset-0 flex items-end lg:items-center justify-start px-6 lg:px-20 pb-10 sm:pb-14 lg:pb-0 pt-20 z-10">
        <div class="max-w-lg">
          <div class="w-8 h-px bg-accent mb-4 lg:mb-6"></div>
          <h1 class="font-heading text-white text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.05] tracking-tight text-bloom">
            Your wardrobe,<br /><em class="not-italic text-accent">elevated.</em>
          </h1>
          <p class="mt-4 lg:mt-6 font-body text-white/80 text-base sm:text-lg leading-relaxed max-w-sm text-bloom-sm">
            Expert wardrobe styling and archetype-based personal style guidance by Danielle Marie.
          </p>
          <div class="mt-6 lg:mt-8 flex flex-col sm:flex-row gap-3">
            <a
              href={calendlyURL}
              class="inline-flex items-center justify-center px-7 sm:px-8 py-3.5 sm:py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
            >
              Book Free Consultation
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center px-7 sm:px-8 py-3.5 sm:py-4 border border-white/40 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/10 transition-colors duration-200"
            >
              Explore Services
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HERO CAROUSEL SCRIPT ────────────────────────── -->
  <script define:vars={{ heroBannerImages }}>
    // ── Hero mosaic — cinematic crossfade + Ken Burns + ZERO duplicates ──
    //
    // CRITICAL: no two cells may EVER show the same image simultaneously.
    //
    // Strategy: pure index-based tracking. Every image is identified by its
    // integer index in the IMAGES array — no string matching, no path
    // normalization, no URL resolution. A boolean[] tracks which indices
    // are currently on-screen. checkOut() picks from available indices only.
    // checkIn() frees them. Impossible to desync.
    //
    // Ken Burns: each cell slowly scales 1.0 → 1.08 during its hold period,
    // resetting on each crossfade for continuous cinematic motion.

    const IMAGES   = heroBannerImages;
    const HOLD_MS  = 12_000;
    const FADE_MS  = 1500;
    const STAGGER  = 2_200;
    const KB_SCALE = 1.08;   // Ken Burns zoom target

    if (IMAGES.length < 2) {
      // nothing to cycle
    } else if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {

      // ── Index pool ────────────────────────────────────────────────────
      const inUse = new Array(IMAGES.length).fill(false);

      // Map filename → IMAGES index for initial HTML → index resolution
      const fileIndex = {};
      IMAGES.forEach((path, i) => {
        const name = path.split('/').pop();
        fileIndex[name] = i;
        fileIndex[path] = i;   // also map full path
      });

      function srcToIndex(src) {
        if (!src) return -1;
        if (fileIndex[src] !== undefined) return fileIndex[src];
        const name = src.split('/').pop();
        return fileIndex[name] !== undefined ? fileIndex[name] : -1;
      }

      function checkOut() {
        const free = [];
        for (let i = 0; i < IMAGES.length; i++) {
          if (!inUse[i]) free.push(i);
        }
        if (free.length === 0) return -1;
        const pick = free[Math.floor(Math.random() * free.length)];
        inUse[pick] = true;
        return pick;
      }

      function checkIn(idx) {
        if (idx >= 0 && idx < IMAGES.length) inUse[idx] = false;
      }

      // ── Register initial images ───────────────────────────────────────
      const cells = [...document.querySelectorAll('[data-hero-cell]')];
      const cellIdx = [];   // which IMAGES index each cell currently shows

      cells.forEach((cell, i) => {
        const layerA = cell.querySelector('[data-layer="a"]');
        const src = layerA ? layerA.getAttribute('src') : '';
        const idx = srcToIndex(src);
        if (idx >= 0) inUse[idx] = true;
        cellIdx[i] = idx;
      });

      // ── Ken Burns helper ──────────────────────────────────────────────
      function applyKenBurns(img) {
        img.style.transition = `transform ${HOLD_MS}ms ease-in-out, opacity ${FADE_MS}ms ease-in-out`;
        img.style.transform  = `scale(${KB_SCALE})`;
      }
      function resetKenBurns(img) {
        // Remove transition so scale resets instantly (no visible snap-back)
        img.style.transition = 'none';
        img.style.transform  = 'scale(1)';
        // Force reflow so the reset takes effect before we re-enable transition
        img.offsetHeight;
      }

      // ── Kick off Ken Burns on initial visible images ──────────────────
      requestAnimationFrame(() => {
        cells.forEach(cell => {
          const a = cell.querySelector('[data-layer="a"]');
          if (a) {
            a.style.transition = `transform ${HOLD_MS}ms ease-in-out, opacity ${FADE_MS}ms ease-in-out`;
            a.style.transform  = `scale(${KB_SCALE})`;
          }
        });
      });

      // ── Cycle a cell ──────────────────────────────────────────────────
      function startCell(cell, ci, startDelay) {
        const layerA = cell.querySelector('[data-layer="a"]');
        const layerB = cell.querySelector('[data-layer="b"]');
        if (!layerA || !layerB) return;

        let frontIsA = true;

        function nextImage() {
          const front = frontIsA ? layerA : layerB;
          const back  = frontIsA ? layerB : layerA;

          const nextIdx = checkOut();
          if (nextIdx < 0) {
            setTimeout(nextImage, HOLD_MS);
            return;
          }

          // Prep the back layer: reset scale, load new image, keep hidden
          resetKenBurns(back);
          back.style.opacity = '0';
          back.src = IMAGES[nextIdx];

          const doFade = () => {
            // Safety: if the back image has no pixels, don't hide the front
            if (!back.naturalWidth) {
              checkIn(nextIdx);
              setTimeout(nextImage, 500);
              return;
            }

            // Crossfade: show back, hide front
            back.style.transition = `transform ${HOLD_MS}ms ease-in-out, opacity ${FADE_MS}ms ease-in-out`;
            back.style.opacity    = '1';
            back.style.transform  = `scale(${KB_SCALE})`;
            front.style.opacity   = '0';

            // Release old image back to pool
            checkIn(cellIdx[ci]);
            cellIdx[ci] = nextIdx;

            frontIsA = !frontIsA;
            setTimeout(nextImage, HOLD_MS);
          };

          if (back.complete && back.naturalWidth > 0) {
            doFade();
          } else {
            back.onload  = doFade;
            back.onerror = () => {
              // Image failed — release it and retry IMMEDIATELY with a different one
              checkIn(nextIdx);
              setTimeout(nextImage, 500);
            };
          }
        }

        setTimeout(nextImage, startDelay + HOLD_MS);
      }

      // Wait for first paint then start staggered cycling
      requestAnimationFrame(() => {
        cells.forEach((cell, i) => {
          startCell(cell, i, i * STAGGER);
        });
      });
    }
  </script>

  <!-- ── MARQUEE — brand identity band ────────────────── -->
  <Marquee variant="dark" />

  <!-- ── SERVICES PREVIEW ──────────────────────────────── -->
  <section class="py-24 lg:py-32 px-6 bg-background" aria-label="Services preview"
           data-compact-super="What We Offer" data-compact-title="Styling Services" data-compact-theme="light">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-4">
        <div>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3"><span class="text-secondary mr-2">01 /</span>What We Offer</p>
          <h2 class="font-heading text-primary">Styling Services</h2>
        </div>
        <a
          href="/services"
          class="font-body text-sm tracking-widest uppercase text-text-muted hover:text-primary transition-colors border-b border-current pb-0.5 self-start md:self-auto"
        >
          View All Services →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredServices.map((service) => (
          <a
            href={`/services/${service.data.slug}`}
            class="group block bg-surface p-7 hover:bg-surface-dark transition-colors duration-200 img-frame-card"
          >
            <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3">{service.data.price}</p>
            <h3 class="font-heading text-xl font-semibold text-primary mb-3 group-hover:text-accent transition-colors">
              {service.data.title}
            </h3>
            <p class="font-body text-sm text-text-muted leading-relaxed">
              {service.data.shortDescription ?? service.data.perfectFor}
            </p>
            <div class="mt-5 flex items-center gap-2 font-body text-xs tracking-widest uppercase text-accent-text">
              <span>View Service Details</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ARCHETYPE TEASE ───────────────────────────────── -->
  <section class="py-24 lg:py-32 px-6 bg-primary" aria-label="Style archetypes"
           data-compact-super="The Framework" data-compact-title="Discover Your Style Archetype"
           data-compact-tagline="Every great wardrobe starts with knowing who you are."
           data-compact-theme="dark">
    <div class="mx-auto max-w-7xl">
      <div class="text-center mb-14">
        <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
        <p class="font-body text-xs tracking-widest uppercase text-accent mb-3 text-center"><span class="text-accent/40 mr-2">02 /</span>The Framework</p>
        <h2 class="font-heading text-white text-3xl sm:text-4xl lg:text-5xl">Discover Your Style Archetype</h2>
        <p class="mt-5 font-body text-white/60 text-lg max-w-xl mx-auto leading-relaxed">
          Every great wardrobe starts with knowing who you are. Danielle's 7 Feminine Archetypes framework is the foundation of every styling engagement.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
        {featuredArchetypes.map((archetype) => (
          <a
            href="/archetypes"
            class="group flex flex-col bg-primary-light p-8 hover:bg-accent/10 border border-white/5 hover:border-accent/30 transition-colors duration-300 img-frame-card"
          >
            <!-- Icon + name on same line -->
            <div class="flex items-center gap-3 mb-5">
              <span class="text-2xl text-accent/60 group-hover:text-accent transition-colors duration-300">
                {archetype.data.icon ?? '✦'}
              </span>
              <h3 class="font-heading text-white text-xl font-semibold group-hover:text-accent transition-colors duration-300">
                {archetype.data.name}
              </h3>
            </div>
            <!-- Description -->
            <p class="font-body text-white/60 text-sm leading-relaxed flex-1 mb-6">
              {archetype.data.description}
            </p>
            <!-- CTA -->
            <div class="flex items-center gap-2 font-body text-xs tracking-widest uppercase text-accent/60 group-hover:text-accent transition-colors duration-300">
              <span>Discover Your Type</span>
              <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center">
        <a
          href="/archetypes"
          class="inline-flex items-center justify-center px-10 py-4 border border-accent text-accent font-body text-sm tracking-widest uppercase hover:bg-accent hover:text-white transition-colors duration-200"
        >
          Explore the Archetypes →
        </a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ──────────────────────────────────── -->
  <section class="py-24 lg:py-32 px-6 bg-background" aria-label="Client testimonials"
           data-compact-super="Client Stories" data-compact-title="Client Stories" data-compact-theme="light">
    <div class="mx-auto max-w-7xl">
      <div class="text-center mb-14">
        <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
        <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3 text-center"><span class="text-secondary mr-2">03 /</span>Client Stories</p>
      </div>

      <!-- 3-column testimonial card grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
        {featuredTestimonials.map((t) => {
          const quote = t.body.trim().replace(/^"|"$/g, '');
          return (
            <div class="bg-surface border border-surface-dark p-7 flex flex-col img-frame-card">
              <!-- Decorative quote mark -->
              <div class="font-heading text-4xl text-accent/25 leading-none mb-4 select-none" aria-hidden="true">"</div>
              <!-- Quote — clamped to 4 lines so all cards align -->
              <p class="font-body text-sm text-text-muted leading-relaxed line-clamp-4 flex-1 italic">
                {quote}
              </p>
              <!-- Attribution -->
              <div class="flex items-center gap-3 mt-6 pt-5 border-t border-surface-dark">
                <div class="w-9 h-9 rounded-full overflow-hidden shrink-0 ring-1 ring-surface-dark">
                  <img
                    src={`/images/testimonials/${t.data.name.toLowerCase()}.webp`}
                    alt={t.data.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    onerror="this.parentElement.style.display='none'"
                  />
                </div>
                <div>
                  <p class="font-heading text-base font-semibold text-primary leading-tight">{t.data.name}</p>
                  {t.data.service && (
                    <a
                      href={`/services/${t.data.service}`}
                      class="font-body text-[10px] tracking-widest uppercase text-accent hover:text-primary transition-colors"
                    >
                      {t.data.service.replace(/-/g, ' ')}
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- CTA to full client stories page -->
      <div class="text-center">
        <a
          href="/clients"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-surface-dark text-text-muted font-body text-xs tracking-widest uppercase hover:border-primary hover:text-primary transition-colors duration-200"
        >
          Read All Client Stories →
        </a>
      </div>
    </div>
  </section>

  <!-- ── INSTAGRAM GRID ────────────────────────────────── -->
  <section class="py-24 lg:py-32 px-6 bg-surface" aria-label="Instagram portfolio"
           data-compact-super="Portfolio" data-compact-title="From the Feed" data-compact-theme="surface">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
        <div>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3">Portfolio</p>
          <h2 class="font-heading text-primary">From the Feed</h2>
          <p class="mt-2 font-body text-text-muted text-sm">52,000+ followers • @littledanniii</p>
        </div>
        <a
          href="https://instagram.com/littledanniii"
          target="_blank"
          rel="noopener noreferrer"
          class="font-body text-sm tracking-widest uppercase text-text-muted hover:text-primary transition-colors border-b border-current pb-0.5 self-start md:self-auto"
        >
          Follow on Instagram →
        </a>
      </div>
      <!-- Portfolio grid — local images linked to specific Instagram posts
           Each image slowly pans up/down at a different speed + staggered start
           so the grid feels alive and cinematic, never mechanical. -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-2">
        {[
          { img: 1, post: 'https://www.instagram.com/p/DURBEbyEu3-/', dur: 30, delay: 0 },
          { img: 2, post: 'https://www.instagram.com/p/DUMH5sVkiHD/', dur: 38, delay: -14 },
          { img: 3, post: 'https://www.instagram.com/p/DU2AVX5Edqc/', dur: 26, delay: -6 },
          { img: 4, post: 'https://www.instagram.com/p/DV_gbajESNR/', dur: 42, delay: -22 },
          { img: 5, post: 'https://www.instagram.com/p/DVeOiP4jxqN/', dur: 34, delay: -10 },
          { img: 6, post: 'https://www.instagram.com/p/DQe3MoAj5Gi/', dur: 28, delay: -19 },
        ].map(({ img, post, dur, delay }) => (
          <a
            href={post}
            target="_blank"
            rel="noopener noreferrer"
            class="relative overflow-hidden aspect-[3/4] bg-surface-dark group ig-post-cell img-frame"
            aria-label={`View this post on Instagram`}
          >
            <img
              src={`/images/portfolio-${img}.webp`}
              alt={`Styling portfolio image ${img}`}
              class="ig-post-img"
              style={`animation-duration: ${dur}s; animation-delay: ${delay}s;`}
              loading="lazy"
              width="400"
              height="600"
            />
            <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/20 transition-colors duration-300 pointer-events-none"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style is:global>
    @keyframes ig-pan {
      from { transform: translateY(0%); }
      to   { transform: translateY(-25%); }
    }
    .ig-post-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 150%;            /* extra headroom for pan travel */
      object-fit: cover;
      object-position: top center;
      will-change: transform;
      animation: ig-pan ease-in-out infinite alternate;
    }
    .ig-post-cell:hover .ig-post-img {
      animation-play-state: paused;
    }
    @media (prefers-reduced-motion: reduce) {
      .ig-post-img {
        animation: none;
        height: 100%;
      }
    }
  </style>

