---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { readdirSync } from 'fs';
import { join } from 'path';

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allServices = await getCollection('services');
const servicesMap = Object.fromEntries(allServices.map(s => [s.data.slug, s.data.title]));

const calendlyURL = '/contact';

// Pre-render all testimonial bodies
const rendered = await Promise.all(
  testimonials.map(async (t) => {
    const { Content } = await render(t);
    return { t, Content };
  })
);

// Scan ALL banner directories for mosaic hero pool
let clientBannerImages: string[] = [];
try {
  const dirs = [
    { path: 'public/images/hero-banners', prefix: '/images/hero-banners/' },
    { path: 'public/images/service-banners', prefix: '/images/service-banners/' },
    { path: 'public/images/about-banners', prefix: '/images/about-banners/' },
  ];
  for (const { path: dir, prefix } of dirs) {
    try {
      const full = join(process.cwd(), dir);
      clientBannerImages.push(...readdirSync(full).filter(f => f.endsWith('.webp')).map(f => prefix + f));
    } catch {}
  }
} catch {}

function sampleUnique(arr: string[], n: number): string[] {
  const shuffled = [...arr];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled.slice(0, n);
}

const hasMosaic = clientBannerImages.length >= 2;
const heroStart = hasMosaic
  ? sampleUnique(clientBannerImages, 6)
  : [];
---

<BaseLayout
  title="Client Experiences — Staples & Statements"
  description="Real results from real clients. Read testimonials from Danielle Marie's wardrobe styling clients and discover what a styling transformation looks like."
  transparentNav={hasMosaic}
>

  <!-- ── PAGE HEADER ────────────────────────────────────── -->
  {hasMosaic ? (
  <section class="relative overflow-hidden bg-primary" aria-label="Clients header">
    <div class="relative min-h-[60svh] lg:min-h-[50vh] flex flex-col">

      <div id="clients-hero-mosaic" class="absolute inset-0 grid grid-cols-2 grid-rows-2 lg:grid-cols-3 lg:grid-rows-2 gap-0.5 w-full h-full">
        <div data-clients-cell="0" class="col-span-1 row-span-1 lg:row-span-2 relative overflow-hidden bg-secondary/30 img-frame-grid">
          <img data-layer="a" src={heroStart[0]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-primary/60 pointer-events-none"></div>
        </div>
        <div data-clients-cell="1" class="col-span-1 row-span-1 relative overflow-hidden bg-secondary/20 img-frame-grid">
          <img data-layer="a" src={heroStart[1]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>
        <div data-clients-cell="2" class="col-span-1 row-span-1 relative overflow-hidden bg-primary-light img-frame-grid">
          <img data-layer="a" src={heroStart[2] ?? heroStart[0]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>
        <div data-clients-cell="3" class="col-span-1 row-span-1 relative overflow-hidden bg-secondary/40 img-frame-grid">
          <img data-layer="a" src={heroStart[3] ?? heroStart[1]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="eager" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>
        <div data-clients-cell="4" class="hidden lg:block col-span-1 row-span-1 relative overflow-hidden bg-secondary/20 img-frame-grid">
          <img data-layer="a" src={heroStart[4] ?? heroStart[0]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="lazy" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>
        <div data-clients-cell="5" class="hidden lg:block col-span-1 row-span-1 relative overflow-hidden bg-primary-light img-frame-grid">
          <img data-layer="a" src={heroStart[5] ?? heroStart[1]} alt="" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 1" loading="lazy" />
          <img data-layer="b" src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" style="transition: opacity 1500ms ease-in-out; opacity: 0" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/40 pointer-events-none"></div>
        </div>
      </div>

      <div class="absolute top-0 left-0 right-0 h-24 lg:h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, transparent 100%)"></div>
      <div class="absolute bottom-0 left-0 right-0 h-[65%] lg:h-[55%] pointer-events-none z-[5]"
           style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.15) 65%, transparent 100%)"></div>

      <div class="absolute inset-0 flex items-end justify-start px-6 lg:px-20 pb-10 sm:pb-14 lg:pb-16 pt-20 z-10">
        <div class="max-w-xl">
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3 text-bloom-sm">Their Words, Not Ours</p>
          <h1 class="font-heading text-white text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-semibold max-w-2xl leading-tight text-bloom">
            Client Experiences
          </h1>
          <p class="mt-4 lg:mt-5 font-body text-white/80 text-base sm:text-lg max-w-xl leading-relaxed text-bloom-sm">
            Style transformations don't show up in a single before-and-after photo. They show up in how you carry yourself. How you feel walking into a room.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ clientBannerImages }}>
    const IMAGES   = clientBannerImages;
    const HOLD_MS  = 12_000;
    const FADE_MS  = 1500;
    const STAGGER  = 2_200;
    const KB_SCALE = 1.08;

    if (IMAGES.length >= 2 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const inUse = new Array(IMAGES.length).fill(false);
      const fileIndex = {};
      IMAGES.forEach((path, i) => { fileIndex[path.split('/').pop()] = i; fileIndex[path] = i; });
      function srcToIndex(src) { if (!src) return -1; if (fileIndex[src] !== undefined) return fileIndex[src]; const n = src.split('/').pop(); return fileIndex[n] !== undefined ? fileIndex[n] : -1; }
      function checkOut() { const free = []; for (let i = 0; i < IMAGES.length; i++) { if (!inUse[i]) free.push(i); } if (!free.length) return -1; const pick = free[Math.floor(Math.random() * free.length)]; inUse[pick] = true; return pick; }
      function checkIn(idx) { if (idx >= 0 && idx < IMAGES.length) inUse[idx] = false; }

      const cells = [...document.querySelectorAll('[data-clients-cell]')];
      const cellIdx = [];
      cells.forEach((cell, i) => { const a = cell.querySelector('[data-layer="a"]'); const idx = srcToIndex(a?.getAttribute('src') ?? ''); if (idx >= 0) inUse[idx] = true; cellIdx[i] = idx; });

      requestAnimationFrame(() => { cells.forEach(cell => { const a = cell.querySelector('[data-layer="a"]'); if (a) { a.style.transition = `transform ${HOLD_MS}ms ease-in-out, opacity ${FADE_MS}ms ease-in-out`; a.style.transform = `scale(${KB_SCALE})`; } }); });

      function startCell(cell, ci, startDelay) {
        const layerA = cell.querySelector('[data-layer="a"]'), layerB = cell.querySelector('[data-layer="b"]');
        if (!layerA || !layerB) return;
        let frontIsA = true;
        function nextImage() {
          const front = frontIsA ? layerA : layerB, back = frontIsA ? layerB : layerA;
          const nextIdx = checkOut();
          if (nextIdx < 0) { setTimeout(nextImage, HOLD_MS); return; }
          back.style.transition = 'none'; back.style.transform = 'scale(1)'; back.offsetHeight;
          back.style.opacity = '0'; back.src = IMAGES[nextIdx];
          const doFade = () => {
            if (!back.naturalWidth) { checkIn(nextIdx); setTimeout(nextImage, 500); return; }
            back.style.transition = `transform ${HOLD_MS}ms ease-in-out, opacity ${FADE_MS}ms ease-in-out`;
            back.style.opacity = '1'; back.style.transform = `scale(${KB_SCALE})`; front.style.opacity = '0';
            checkIn(cellIdx[ci]); cellIdx[ci] = nextIdx; frontIsA = !frontIsA; setTimeout(nextImage, HOLD_MS);
          };
          if (back.complete && back.naturalWidth > 0) doFade(); else { back.onload = doFade; back.onerror = () => { checkIn(nextIdx); setTimeout(nextImage, 500); }; }
        }
        setTimeout(nextImage, startDelay + HOLD_MS);
      }
      requestAnimationFrame(() => { cells.forEach((cell, i) => { startCell(cell, i, i * STAGGER); }); });
    }
  </script>
  ) : (
  <section class="pt-16 pb-16 px-6 bg-primary" aria-label="Clients header">
    <div class="mx-auto max-w-7xl">
      <div class="w-8 h-px bg-accent mb-4"></div>
      <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">Their Words, Not Ours</p>
      <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-7xl font-semibold max-w-2xl leading-tight">
        Client Experiences
      </h1>
      <p class="mt-5 font-body text-white/60 text-lg max-w-xl leading-relaxed">
        Style transformations don't show up in a single before-and-after photo. They show up in how you carry yourself. How you feel walking into a room. What clients say below.
      </p>
    </div>
  </section>
  )}

  <!-- ── STAT BAR ───────────────────────────────────────── -->
  <section class="py-10 px-6 bg-surface border-b border-surface-dark" aria-label="Credentials">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { number: "52K+", label: "Instagram Followers" },
          { number: "500+", label: "LTK Products Curated" },
          { number: "6", label: "Style Guides Published" },
          { number: "7", label: "Style Archetypes" },
        ].map(({ number, label }) => (
          <div>
            <p class="font-heading text-4xl font-semibold text-accent-text">{number}</p>
            <p class="font-body text-xs tracking-widest uppercase text-text-muted mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VIP FEATURED TESTIMONIAL ────────────────────────── -->
  {rendered.filter(({ t }) => t.data.service === 'vip').map(({ t, Content }) => (
  <section class="py-16 sm:py-20 px-6 bg-primary relative overflow-hidden" aria-label="VIP Client Testimonial">
    {/* Warm radial spotlight behind the card */}
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(184, 151, 126, 0.08) 0%, rgba(184, 151, 126, 0.03) 40%, transparent 70%);"></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <div class="flex flex-col items-center text-center mb-10">
        <div class="w-8 h-px bg-accent mb-4"></div>
        <p class="font-body text-[10px] tracking-[0.3em] uppercase text-accent/60 mb-1">VIP Client</p>
      </div>

      <article class="relative bg-primary-light border border-accent/15 p-8 sm:p-12 lg:p-16 img-frame-card"
               style="box-shadow: 0 16px 64px rgba(184, 151, 126, 0.20), 0 4px 16px rgba(184, 151, 126, 0.12), inset 0 1px 0 rgba(184, 151, 126, 0.08);">

        {/* Subtle accent line top */}
        <div class="absolute top-0 left-8 right-8 sm:left-12 sm:right-12 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

        {/* Quote mark — large, elegant */}
        <div class="font-heading text-7xl sm:text-8xl text-accent/20 leading-none mb-6 select-none" aria-hidden="true">"</div>

        {/* Quote body — generous text */}
        <div class="font-body text-lg sm:text-xl lg:text-2xl text-white/85 leading-relaxed italic max-w-2xl">
          <Content />
        </div>

        {/* Attribution — avatar + name + service */}
        <div class="mt-8 sm:mt-10 pt-6 border-t border-accent/15 flex items-center gap-4">
          <div class="w-14 h-14 rounded-full overflow-hidden shrink-0 img-frame-circle" style="box-shadow: 0 0 0 2px rgba(184, 151, 126, 0.3), 0 4px 12px rgba(184, 151, 126, 0.2);">
            <img
              src={`/images/testimonials/${t.data.name.toLowerCase()}.webp`}
              alt={t.data.name}
              class="w-full h-full object-cover"
              loading="lazy"
              width="56" height="56"
              onerror="this.parentElement.style.display='none'"
            />
          </div>
          <div>
            <p class="font-heading text-2xl sm:text-3xl font-semibold text-white">{t.data.name}</p>
            <a href="/services/vip" class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors">
              VIP Styling →
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>
  ))}

  <!-- ── TESTIMONIALS GRID ─────────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="Testimonials">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {rendered.filter(({ t }) => t.data.service !== 'vip').map(({ t, Content }, index) => {
          const isDark = index % 2 !== 0;
          return (
          <article
            class:list={[
              "flex flex-col p-6 sm:p-10 img-frame-card",
              isDark ? "bg-primary" : "bg-surface",
            ]}
          >
            <!-- Quote mark -->
            <div class:list={[
              "font-heading text-5xl sm:text-6xl leading-none mb-4 sm:mb-5",
              isDark ? "text-accent/30" : "text-accent/20",
            ]}>
              "
            </div>

            <!-- Testimonial body -->
            <div class:list={[
              "font-body text-base leading-relaxed italic flex-1",
              isDark ? "text-white/70" : "text-text-muted",
            ]}>
              <Content />
            </div>

            <!-- Attribution -->
            <div class:list={[
              "mt-6 sm:mt-8 pt-5 sm:pt-6 border-t flex items-end justify-between gap-4",
              isDark ? "border-white/10" : "border-surface-dark",
            ]}>
              <div>
                <p class:list={[
                  "font-heading text-2xl font-semibold",
                  isDark ? "text-white" : "text-primary",
                ]}>
                  {t.data.name}
                </p>
                {t.data.service && servicesMap[t.data.service] && (
                  <a
                    href={`/services/${t.data.service}`}
                    class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors mt-1 inline-block"
                  >
                    {servicesMap[t.data.service]} →
                  </a>
                )}
              </div>

              <div class="w-12 h-12 rounded-full overflow-hidden shrink-0 img-frame-circle">
                <img
                  src={`/images/testimonials/${t.data.name.toLowerCase()}.webp`}
                  alt={`${t.data.name} — styling client`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="48" height="48"
                  onerror="this.parentElement.style.display='none'"
                />
              </div>
            </div>
          </article>
        )})}
      </div>
    </div>
  </section>

  <!-- ── PROCESS REMINDER ──────────────────────────────── -->
  <section class="py-16 px-6 bg-surface" aria-label="The process">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 text-center">
        {[
          {
            icon: "✦",
            heading: "Every journey starts free.",
            body: "A 20-minute consultation — no prep, no commitment — to understand your goals and identify the right service.",
          },
          {
            icon: "◉",
            heading: "Your session, your terms.",
            body: "In-person in San Diego or virtually via Zoom or FaceTime. Scheduled around your life, not the other way around.",
          },
          {
            icon: "♛",
            heading: "Results that last.",
            body: "Clients don't just leave with outfits. They leave with the knowledge to make better style decisions forever.",
          },
        ].map(({ icon, heading, body }) => (
          <div class="p-6">
            <div class="text-3xl text-accent-text mb-4">{icon}</div>
            <h3 class="font-heading text-xl font-semibold text-primary mb-3">{heading}</h3>
            <p class="font-body text-sm text-text-muted leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────── -->
  <section class="py-20 lg:py-28 px-6 bg-primary" aria-label="Book your transformation">
    <div class="mx-auto max-w-3xl flex flex-col items-center text-center">
      <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
      <p class="font-body text-xs tracking-widest uppercase text-accent mb-3 text-center">Your Turn</p>
      <h2 class="font-heading text-white text-4xl lg:text-5xl">
        Ready to be the next success story?
      </h2>
      <p class="mt-5 font-body text-white/60 text-lg leading-relaxed max-w-lg mx-auto">
        Join the clients who stopped settling for a wardrobe that doesn't quite fit — and invested in one that does.
      </p>
      <a
        href={calendlyURL}
        class="mt-10 inline-flex items-center justify-center px-10 py-5 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
      >
        Book Your Free Consultation
      </a>
    </div>
  </section>

</BaseLayout>
