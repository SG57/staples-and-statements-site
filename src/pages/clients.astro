---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allServices = await getCollection('services');
const servicesMap = Object.fromEntries(allServices.map(s => [s.data.slug, s.data.title]));

const calendlyURL = '/contact';

// Pre-render all testimonial bodies
const rendered = await Promise.all(
  testimonials.map(async (t) => {
    const { Content } = await render(t);
    return { t, Content };
  })
);
---

<BaseLayout
  title="Client Experiences — Staples & Statements"
  description="Real results from real clients. Read testimonials from Danielle Marie's wardrobe styling clients and discover what a styling transformation looks like."
>

  <!-- ── PAGE HEADER ────────────────────────────────────── -->
  <section class="pt-16 pb-16 px-6 bg-primary" aria-label="Clients header">
    <div class="mx-auto max-w-7xl">
      <p class="font-body text-xs tracking-widest uppercase text-accent mb-4">Their Words, Not Ours</p>
      <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-7xl font-semibold max-w-2xl leading-tight">
        Client Experiences
      </h1>
      <p class="mt-5 font-body text-white/60 text-lg max-w-xl leading-relaxed">
        Style transformations don't show up in a single before-and-after photo. They show up in how you carry yourself. How you feel walking into a room. What clients say below.
      </p>
    </div>
  </section>

  <!-- ── STAT BAR ───────────────────────────────────────── -->
  <section class="py-10 px-6 bg-surface border-b border-surface-dark" aria-label="Credentials">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { number: "52K+", label: "Instagram Followers" },
          { number: "500+", label: "LTK Products Curated" },
          { number: "6", label: "Style Guides Published" },
          { number: "7", label: "Style Archetypes" },
        ].map(({ number, label }) => (
          <div>
            <p class="font-heading text-4xl font-semibold text-accent">{number}</p>
            <p class="font-body text-xs tracking-widest uppercase text-text-muted mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS GRID ─────────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="Testimonials">
    <div class="mx-auto max-w-7xl">
      <!-- Sentinel -->
      <div class="section-sentinel" data-section="clients-testimonials" aria-hidden="true"></div>

      <!-- COMPACT sticky header -->
      <div class="section-header-compact sticky top-16 lg:top-20 z-30
                  bg-background/85 backdrop-blur-md border-b border-surface-dark/40
                  px-6 py-3 mb-4
                  opacity-0 pointer-events-none
                  transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
           data-section-compact="clients-testimonials">
        <div class="inline-flex items-center gap-3">
          <div class="w-6 h-px bg-accent"></div>
          <p class="font-body text-[10px] tracking-widest uppercase text-accent">Their Words</p>
          <span class="text-primary/20">|</span>
          <h2 class="font-heading text-primary text-lg font-semibold">Client Testimonials</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {rendered.map(({ t, Content }, index) => (
          <article
            class:list={[
              "flex flex-col p-10",
              index % 3 === 0 ? "bg-surface" : "bg-primary",
            ]}
          >
            <!-- Quote mark -->
            <div class:list={[
              "font-heading text-6xl leading-none mb-5",
              index % 3 === 0 ? "text-accent/20" : "text-accent/30",
            ]}>
              "
            </div>

            <!-- Testimonial body -->
            <div class:list={[
              "font-body text-base leading-relaxed italic flex-1",
              index % 3 === 0 ? "text-text-muted" : "text-white/70",
            ]}>
              <Content />
            </div>

            <!-- Attribution -->
            <div class:list={[
              "mt-8 pt-6 border-t flex items-end justify-between gap-4",
              index % 3 === 0 ? "border-surface-dark" : "border-white/10",
            ]}>
              <div>
                <p class:list={[
                  "font-heading text-2xl font-semibold",
                  index % 3 === 0 ? "text-primary" : "text-white",
                ]}>
                  {t.data.name}
                </p>
                {t.data.service && servicesMap[t.data.service] && (
                  <a
                    href={`/services/${t.data.service}`}
                    class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors mt-1 inline-block"
                  >
                    {servicesMap[t.data.service]} →
                  </a>
                )}
              </div>

              <!-- Avatar: always attempt — onerror hides if placeholder/missing -->
              <div class="w-12 h-12 rounded-full overflow-hidden shrink-0 img-frame-circle">
                <img
                  src={`/images/testimonials/${t.data.name.toLowerCase()}.webp`}
                  alt={`${t.data.name} — styling client`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="48"
                  height="48"
                  onerror="this.parentElement.style.display='none'"
                />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROCESS REMINDER ──────────────────────────────── -->
  <section class="py-16 px-6 bg-surface" aria-label="The process">
    <div class="mx-auto max-w-5xl">
      <!-- Sentinel -->
      <div class="section-sentinel" data-section="clients-process" aria-hidden="true"></div>

      <!-- COMPACT sticky header -->
      <div class="section-header-compact sticky top-16 lg:top-20 z-30
                  bg-surface/85 backdrop-blur-md border-b border-surface-dark/40
                  px-6 py-3 mb-4
                  opacity-0 pointer-events-none
                  transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
           data-section-compact="clients-process">
        <div class="inline-flex items-center gap-3">
          <div class="w-6 h-px bg-accent"></div>
          <p class="font-body text-[10px] tracking-widest uppercase text-accent">The Process</p>
          <span class="text-primary/20">|</span>
          <h2 class="font-heading text-primary text-lg font-semibold">How It Works</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        {[
          {
            icon: "✦",
            heading: "Every journey starts free.",
            body: "A 20-minute consultation — no prep, no commitment — to understand your goals and identify the right service.",
          },
          {
            icon: "◉",
            heading: "Your session, your terms.",
            body: "In-person in San Diego or virtually via Zoom or FaceTime. Scheduled around your life, not the other way around.",
          },
          {
            icon: "♛",
            heading: "Results that last.",
            body: "Clients don't just leave with outfits. They leave with the knowledge to make better style decisions forever.",
          },
        ].map(({ icon, heading, body }) => (
          <div class="p-6">
            <div class="text-3xl text-accent mb-4">{icon}</div>
            <h3 class="font-heading text-xl font-semibold text-primary mb-3">{heading}</h3>
            <p class="font-body text-sm text-text-muted leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────── -->
  <section class="py-20 lg:py-28 px-6 bg-primary" aria-label="Book your transformation">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Sentinel -->
      <div class="section-sentinel" data-section="clients-cta" aria-hidden="true"></div>

      <p class="font-body text-xs tracking-widest uppercase text-accent mb-4">Your Turn</p>
      <h2 class="font-heading text-white text-4xl lg:text-5xl">
        Ready to be the next success story?
      </h2>
      <!-- COMPACT sticky header -->
      <div class="section-header-compact sticky top-16 lg:top-20 z-30
                  bg-primary/85 backdrop-blur-md border-b border-white/8
                  px-6 py-3 mb-4
                  opacity-0 pointer-events-none
                  transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]
                  text-left"
           data-section-compact="clients-cta">
        <div class="inline-flex items-center gap-3">
          <div class="w-6 h-px bg-accent"></div>
          <p class="font-body text-[10px] tracking-widest uppercase text-accent">Your Turn</p>
          <span class="text-white/20">|</span>
          <h2 class="font-heading text-white text-lg font-semibold">Ready to Be Next?</h2>
        </div>
      </div>

      <p class="mt-5 font-body text-white/60 text-lg leading-relaxed max-w-lg mx-auto">
        Join the clients who stopped settling for a wardrobe that doesn't quite fit — and invested in one that does.
      </p>
      <a
        href={calendlyURL}
        class="mt-10 inline-flex items-center justify-center px-10 py-5 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
      >
        Book Your Free Consultation
      </a>
    </div>
  </section>

  <!-- ── Sticky section header observer ──────────────────── -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const sentinels = document.querySelectorAll<HTMLElement>('.section-sentinel');
      if (sentinels.length === 0) return;

      const seenSentinels = new Set<string>();

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const section = (entry.target as HTMLElement).dataset.section;
          if (!section) return;
          const compact = document.querySelector<HTMLElement>(`[data-section-compact="${section}"]`);
          if (!compact) return;
          if (entry.isIntersecting) {
            seenSentinels.add(section);
            compact.style.opacity = '0';
            compact.style.pointerEvents = 'none';
          } else if (seenSentinels.has(section)) {
            compact.style.opacity = '1';
            compact.style.pointerEvents = 'auto';
          }
        });
      }, { threshold: 0, rootMargin: '-30px 0px 0px 0px' });

      sentinels.forEach(s => observer.observe(s));
    });
  </script>

</BaseLayout>
