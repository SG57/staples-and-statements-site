---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.status === 'active');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

// Get related testimonial
const allTestimonials = await getCollection('testimonials');
const relatedTestimonial = allTestimonials.find(
  (t) => t.data.service === service.data.slug
);

// Get 2 related services (exclude current)
const allServices = await getCollection('services', ({ data }) => data.status === 'active');
const relatedServices = allServices
  .filter((s) => s.data.slug !== service.data.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const calendlyURL = '/contact';
---

<BaseLayout
  title={`${service.data.title} — Staples & Statements`}
  description={service.data.shortDescription ?? service.data.perfectFor}
  serviceSchema={{
    name: service.data.title,
    description: service.data.shortDescription ?? service.data.perfectFor,
    url: `https://staplesandstatements.com/services/${service.data.slug}`,
    price: service.data.price,
  }}
>

  <!-- ── SERVICE HERO ──────────────────────────────────── -->
  <section class="bg-primary overflow-hidden" aria-label="Service header">
    <div class="mx-auto max-w-7xl px-6 pt-16 pb-20 lg:pb-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <a
            href="/services"
            class="inline-flex items-center gap-2 font-body text-xs tracking-widest uppercase text-accent/80 hover:text-accent transition-colors mb-8"
          >
            ← All Services
          </a>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">
            {service.data.duration ?? 'Per session'}
          </p>
          <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight">
            {service.data.title}
          </h1>
          <div class="mt-6">
            <span class="font-heading text-3xl text-accent font-semibold">{service.data.price}</span>
            {service.data.priceNote && (
              <p class="font-body text-sm text-white/50 mt-1 italic">{service.data.priceNote}</p>
            )}
            {service.data.priceAlt && (
              <span class="font-heading text-3xl text-accent font-semibold block">{service.data.priceAlt}</span>
            )}
          </div>

          <!-- Perfect for callout -->
          <div class="mt-8 border-l-2 border-accent pl-5">
            <p class="font-body text-xs tracking-widest uppercase text-accent mb-1">Perfect For</p>
            <p class="font-body text-white/70 text-sm leading-relaxed">{service.data.perfectFor}</p>
          </div>

          <div class="mt-10">
            <a
              href={calendlyURL}
              class="inline-flex items-center justify-center px-10 py-5 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
            >
              Book Your Free Consultation
            </a>
          </div>
        </div>

        <!-- Hero image slot -->
        <div class="relative aspect-[4/3] lg:aspect-auto lg:h-96 overflow-hidden bg-primary-light img-frame">
          <!-- Add photo: public/images/services/{slug}.webp -->
          <img
            src={`/images/services/${service.data.slug}.webp`}
            alt={`${service.data.title} — Staples & Statements styling`}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            width="700"
            height="500"
            onerror="this.style.display='none'"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SERVICE DESCRIPTION ───────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="Service description">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-14">

        <!-- Main content -->
        <div class="lg:col-span-2">
          <div class="prose-content font-body text-text-muted text-base leading-relaxed space-y-5">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <!-- Quick facts -->
          <div class="bg-surface p-8 sticky top-24 img-frame-card">
            <h3 class="font-heading text-xl font-semibold text-primary mb-6">At a Glance</h3>
            <dl class="space-y-4">
              <div>
                <dt class="font-body text-xs tracking-widest uppercase text-accent-text mb-1">Price</dt>
                <dd class="font-heading text-2xl font-semibold text-primary">{service.data.price}</dd>
                {service.data.priceNote && (
                  <dd class="font-body text-xs text-text-light mt-1 italic">{service.data.priceNote}</dd>
                )}
                {service.data.priceAlt && (
                  <dd class="font-heading text-2xl font-semibold text-primary">{service.data.priceAlt}</dd>
                )}
              </div>
              {service.data.duration && (
                <div class="border-t border-surface-dark pt-4">
                  <dt class="font-body text-xs tracking-widest uppercase text-accent-text mb-1">Duration</dt>
                  <dd class="font-body text-sm text-text-muted">{service.data.duration}</dd>
                </div>
              )}
              <div class="border-t border-surface-dark pt-4">
                <dt class="font-body text-xs tracking-widest uppercase text-accent-text mb-2">Perfect For</dt>
                <dd class="font-body text-sm text-text-muted leading-relaxed">{service.data.perfectFor}</dd>
              </div>
            </dl>
            <div class="mt-8">
              <a
                href={calendlyURL}
                class="block w-full text-center px-6 py-4 bg-primary text-white font-body text-xs font-medium tracking-widest uppercase hover:bg-primary-light transition-colors duration-200"
              >
                Book Consultation
              </a>
              <a
                href="/services/consultation"
                class="block w-full text-center mt-3 px-6 py-3.5 border border-surface-dark text-text-muted font-body text-xs tracking-widest uppercase hover:border-secondary hover:text-primary transition-colors duration-200"
              >
                Not Sure This Is Right? →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIAL ───────────────────────────────────── -->
  {relatedTestimonial && (
    <section class="py-16 px-6 bg-surface border-t border-surface-dark" aria-label="Client testimonial">
      <div class="mx-auto max-w-3xl text-center">
        <div class="font-heading text-6xl text-accent/20 leading-none mb-4">"</div>
        <blockquote class="font-body text-text-muted text-lg leading-relaxed italic">
          {relatedTestimonial.body.trim().replace(/^"|"$/g, '')}
        </blockquote>
        <div class="mt-6 flex items-center justify-center gap-3">
          <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 img-frame-circle">
            <img
              src={`/images/testimonials/${relatedTestimonial.data.name.toLowerCase()}.webp`}
              alt={relatedTestimonial.data.name}
              class="w-full h-full object-cover"
              loading="lazy"
              width="40"
              height="40"
              onerror="this.parentElement.style.display='none'"
            />
          </div>
          <p class="font-heading text-xl font-semibold text-primary">{relatedTestimonial.data.name}</p>
        </div>
        <a
          href="/clients"
          class="mt-4 inline-block font-body text-xs tracking-widest uppercase text-accent hover:text-primary transition-colors"
        >
          Read All Client Stories →
        </a>
      </div>
    </section>
  )}

  <!-- ── RELATED SERVICES ──────────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="Related services" data-compact-title="You Might Also Consider" data-compact-theme="light">
    <div class="mx-auto max-w-7xl">
      <div class="w-8 h-px bg-accent mb-4"></div>
      <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3">Related Services</p>
      <h2 class="font-heading text-primary text-3xl mb-10">You Might Also Consider</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedServices.map((related, idx) => {
          const isDark = idx % 2 !== 0;
          return (
            <a
              href={`/services/${related.data.slug}`}
              class:list={[
                "group flex flex-col img-frame-card overflow-hidden transition-colors duration-200",
                isDark ? "bg-primary text-white" : "bg-background",
              ]}
            >
              {/* Top image banner */}
              <div class:list={[
                "h-[60px] w-full overflow-hidden relative",
                isDark ? "bg-gradient-to-r from-secondary/40 to-primary-light" : "bg-gradient-to-r from-surface-dark to-secondary/20",
              ]}>
                <img
                  src="/images/services/vip.webp"
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>

              <div class="flex flex-col flex-1 p-8">
                {/* Price badge */}
                <div class="flex items-start justify-between mb-5">
                  <div>
                    <span class:list={[
                      "font-body text-xs tracking-widest uppercase font-medium",
                      isDark ? "text-accent" : "text-accent-text",
                    ]}>
                      {related.data.price}
                    </span>
                    {related.data.priceNote && (
                      <p class:list={[
                        "font-body text-[11px] mt-1 italic normal-case tracking-normal",
                        isDark ? "text-white/50" : "text-primary/50",
                      ]}>{related.data.priceNote}</p>
                    )}
                    {related.data.priceAlt && (
                      <span class:list={[
                        "font-body text-xs tracking-widest uppercase font-medium block mt-0.5",
                        isDark ? "text-accent" : "text-accent-text",
                      ]}>
                        {related.data.priceAlt}
                      </span>
                    )}
                  </div>
                  {related.data.featured && (
                    <span class:list={[
                      "font-body text-xs tracking-widest uppercase px-2 py-1",
                      isDark ? "text-white/40 bg-white/10" : "text-primary/40 bg-surface-dark",
                    ]}>
                      Popular
                    </span>
                  )}
                </div>

                {/* Title */}
                <h3 class:list={[
                  "font-heading text-2xl font-semibold mb-3 group-hover:text-accent transition-colors",
                  isDark ? "text-white" : "text-primary",
                ]}>
                  {related.data.title}
                </h3>

                {/* Description */}
                <p class:list={[
                  "font-body text-sm leading-relaxed flex-1 mb-6",
                  isDark ? "text-white/60" : "text-text-muted",
                ]}>
                  {related.data.shortDescription ?? related.data.perfectFor}
                </p>

                {/* CTA */}
                <div class:list={[
                  "flex items-center gap-2 font-body text-xs tracking-widest uppercase",
                  isDark ? "text-accent" : "text-accent-text",
                ]}>
                  <span>View Details</span>
                  <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .prose-content :global(h2),
  .prose-content :global(h3) {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(h2) { font-size: clamp(1.375rem, 3vw, 1.875rem); }
  .prose-content :global(h3) { font-size: clamp(1.125rem, 2.5vw, 1.375rem); }
  .prose-content :global(p) { margin-bottom: 1.25rem; }
  .prose-content :global(strong) { color: var(--color-primary); font-weight: 600; }
  .prose-content :global(em) { font-style: italic; }
  .prose-content :global(ul) {
    list-style: none;
    margin: 1.25rem 0;
    padding: 0;
  }
  .prose-content :global(ul li) {
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .prose-content :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
