---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

// Formspree endpoint — confirmed in TRACK1-MANUAL-SETUP.md Step 7
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xwvrvgky';

// Calendly scheduling URL — update with actual URL from TRACK1 Step 6
const CALENDLY_URL = 'https://calendly.com/staplesandstatements/30min';

---

<BaseLayout
  title="Contact & Book — Staples & Statements"
  description="Book a free consultation with wardrobe stylist Danielle Marie. Available in San Diego and virtually nationwide."
  transparentNav={true}
>

  <!-- HERO -- Single static banner -->
  <section class="relative overflow-hidden bg-primary" aria-label="Contact hero">
    <div class="relative min-h-[60svh] lg:min-h-[50vh] flex flex-col">

      <!-- Hero image -->
      <img src="/images/service-banners/service-banner-3.webp" alt="Contact Staples and Statements"
           class="absolute inset-0 w-full h-full object-cover" loading="eager" width="1920" height="1080" />

      <!-- Top scrim for nav legibility -->
      <div class="absolute top-0 left-0 right-0 h-24 lg:h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, transparent 100%)"></div>

      <!-- Bottom scrim for text legibility -->
      <div class="absolute bottom-0 left-0 right-0 h-[65%] lg:h-[55%] pointer-events-none z-[5]"
           style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.15) 65%, transparent 100%)"></div>

      <!-- Hero text overlay -->
      <div class="absolute inset-0 flex items-end justify-start px-6 lg:px-20 pb-10 sm:pb-14 lg:pb-16 pt-20 z-10">
        <div class="max-w-xl">
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-white/70 mb-3 text-bloom-xs">Get in Touch</p>
          <h1 class="font-heading text-white text-[2.5rem] sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-bloom">
            Let's Connect.
          </h1>
          <p class="mt-4 lg:mt-6 font-body text-white/80 text-base sm:text-lg leading-relaxed max-w-md text-bloom-sm">
            Whether you're ready to book or just exploring — reach out. Danielle reads every message.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MAIN CONTENT ──────────────────────────────────── -->
  <section class="py-20 px-6 bg-background" aria-label="Booking and contact">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-14 lg:gap-20">

        <!-- Calendly embed — primary (takes 3 of 5 columns) -->
        <div class="lg:col-span-3">
          <div class="mb-8">
            <div class="w-8 h-px bg-accent mb-4"></div>
            <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-3">Book Your Free Consultation</p>
            <h2 class="font-heading text-primary text-3xl font-semibold">
              Schedule a 20-Minute Call
            </h2>
            <p class="mt-3 font-body text-text-muted text-sm leading-relaxed max-w-md">
              Select a day and time that works for you. Available via phone, Zoom, or FaceTime. No preparation required — just show up.
            </p>
          </div>

          <!--
            Calendly embed wrapper.
            The skeleton sits absolute inset-0 over the widget, fades out once
            Calendly's iframe renders. The widget itself has no border — the
            skeleton provides the visual container during load, and Calendly's
            own chrome takes over after.
          -->
          <!--
            Outer wrapper: position relative, height set by widget.
            Skeleton: absolute inset-0 z-10 — overlays the widget exactly.
            Widget: starts opacity:0, fades in when Calendly is ready.

            IMPORTANT: .s-sk (shimmer) must be on an INNER div, NOT on the
            absolute skeleton div. .s-sk has position:relative (unlayered CSS,
            higher cascade than Tailwind utilities) which would override
            absolute positioning if applied directly — causing the layout bug
            where skeleton and widget stack vertically instead of overlapping.
          -->
          <div class="relative img-frame-card" style="min-height:min(680px, calc(100dvh - 4rem));">

            <!-- Skeleton: absolute overlay, no s-sk on this element -->
            <div
              id="calendly-loading"
              class="absolute inset-0 z-10 pointer-events-none overflow-hidden"
              style="transition: opacity 600ms ease; background: var(--color-surface); border: 1px solid var(--color-surface-dark);"
              aria-hidden="true"
            >
              <!-- Inner div carries the shimmer animation — needs position:relative + overflow:hidden -->
              <div class="s-sk h-full p-6 flex flex-col gap-5">
                <!-- Month navigation row -->
                <div class="flex items-center justify-between px-1">
                  <div class="w-7 h-7 rounded-full bg-surface-dark"></div>
                  <div class="h-4 w-36 rounded bg-surface-dark"></div>
                  <div class="w-7 h-7 rounded-full bg-surface-dark"></div>
                </div>
                <!-- Day-of-week labels -->
                <div class="grid grid-cols-7 gap-1 px-1">
                  {[...Array(7)].map(() => (
                    <div class="h-3 rounded bg-surface-dark mx-auto w-5"></div>
                  ))}
                </div>
                <!-- 5 weeks of calendar days -->
                {[...Array(5)].map(() => (
                  <div class="grid grid-cols-7 gap-1 px-1">
                    {[...Array(7)].map(() => (
                      <div class="aspect-square rounded bg-surface-dark"></div>
                    ))}
                  </div>
                ))}
                <!-- Time-slot placeholders -->
                <div class="mt-auto space-y-2.5 px-1 pb-2">
                  <div class="h-3 w-28 bg-surface-dark rounded mb-3"></div>
                  <div class="h-10 bg-surface-dark rounded"></div>
                  <div class="h-10 bg-surface-dark rounded"></div>
                  <div class="h-10 w-2/3 bg-surface-dark rounded"></div>
                </div>
              </div>
            </div>

            <!-- Calendly widget: starts invisible, fades in when fully loaded -->
            <div
              id="calendly-widget"
              class="calendly-inline-widget"
              data-url={CALENDLY_URL}
              data-resize="true"
              style="min-width:280px; min-height:min(680px, calc(100dvh - 4rem)); opacity:0; transition: opacity 600ms ease;"
            ></div>

          </div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>

          <!-- Fallback: shown if Calendly fails to load (ad blocker, slow network, CDN issue).
               The MutationObserver + timeout below detects this and reveals the fallback. -->
          <div
            id="calendly-fallback"
            class="hidden border border-surface-dark bg-surface p-8 text-center"
            role="alert"
            aria-live="polite"
          >
            <div class="w-8 h-px bg-accent mx-auto mb-5"></div>
            <p class="font-heading text-primary text-xl font-semibold mb-2">
              Calendar not loading?
            </p>
            <p class="font-body text-text-muted text-sm leading-relaxed mb-6 max-w-xs mx-auto">
              This sometimes happens with ad blockers or slow connections.
              You can book directly on Calendly — same availability, same booking.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a
                href={CALENDLY_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-8 py-3.5 bg-accent text-white font-body text-xs font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
              >
                Book on Calendly →
              </a>
              <button
                id="calendly-retry"
                type="button"
                class="inline-flex items-center justify-center px-8 py-3.5 border border-surface-dark text-text-muted font-body text-xs tracking-widest uppercase hover:border-primary hover:text-primary transition-colors duration-200"
              >
                Try Again
              </button>
            </div>
          </div>
        </div>

        <!-- Contact form + info (takes 2 of 5 columns) -->
        <div class="lg:col-span-2 space-y-12">

          <!-- Quick info -->
          <div>
            <h3 class="font-heading text-xl font-semibold text-primary mb-5">Contact Info</h3>
            <ul class="space-y-4">
              <li>
                <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-1">Email</p>
                <a
                  href="mailto:hello@staplesandstatements.com"
                  class="font-body text-sm text-text-muted hover:text-primary transition-colors"
                >
                  hello@staplesandstatements.com
                </a>
              </li>
              <li>
                <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-1">Location</p>
                <p class="font-body text-sm text-text-muted">San Diego, CA — also available virtually nationwide</p>
              </li>
              <li class="pt-2">
                <p class="font-body text-xs tracking-widest uppercase text-accent-text mb-2">Follow Along</p>
                <SocialLinks variant="light" size="md" />
              </li>
            </ul>
          </div>

          <!-- Contact form -->
          <div>
            <div class="mb-6">
              <h3 class="font-heading text-xl font-semibold text-primary mb-2">Send a Message</h3>
              <p class="font-body text-sm text-text-muted leading-relaxed">
                Have a question before booking? Or not quite ready to schedule? Send a note — Danielle responds personally.
              </p>
            </div>

            <form
              action={FORMSPREE_ENDPOINT}
              method="POST"
              class="space-y-4 bg-surface border border-surface-dark p-6 sm:p-8 img-frame-card"
              aria-label="Contact form"
            >
              <!-- Honeypot spam protection -->
              <input type="text" name="_gotcha" style="display:none" />
              <!-- Redirect after submit (optional) -->
              <input type="hidden" name="_next" value="https://staplesandstatements.com/contact?success=true" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block font-body text-xs tracking-widest uppercase text-text-muted mb-2">
                    Name <span class="text-accent">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 bg-background border border-surface-dark text-primary font-body text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-primary transition-colors placeholder:text-text-light"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="email" class="block font-body text-xs tracking-widest uppercase text-text-muted mb-2">
                    Email <span class="text-accent">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 bg-background border border-surface-dark text-primary font-body text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-primary transition-colors placeholder:text-text-light"
                    placeholder="your@email.com"
                  />
                </div>
              </div>

              <div>
                <label for="phone" class="block font-body text-xs tracking-widest uppercase text-text-muted mb-2">
                  Phone <span class="text-text-light text-xs normal-case tracking-normal">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 bg-background border border-surface-dark text-primary font-body text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-primary transition-colors placeholder:text-text-light"
                  placeholder="(555) 000-0000"
                />
              </div>

              <div>
                <label for="how-heard" class="block font-body text-xs tracking-widest uppercase text-text-muted mb-2">
                  How did you hear about Staples & Statements?
                </label>
                <select
                  id="how-heard"
                  name="how_heard"
                  class="w-full px-4 py-3 bg-background border border-surface-dark text-primary font-body text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-primary transition-colors appearance-none"
                >
                  <option value="">Select an option</option>
                  <option value="instagram">Instagram</option>
                  <option value="tiktok">TikTok</option>
                  <option value="friend-referral">Friend / Referral</option>
                  <option value="google">Google Search</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="message" class="block font-body text-xs tracking-widest uppercase text-text-muted mb-2">
                  Message <span class="text-accent">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3 bg-background border border-surface-dark text-primary font-body text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-primary transition-colors resize-y placeholder:text-text-light"
                  placeholder="Tell Danielle what's on your mind — style goals, questions about services, anything at all."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full px-8 py-4 bg-primary text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-primary-light transition-colors duration-200"
              >
                Send Message
              </button>
            </form>

            <!-- Success message (shown when ?success=true in URL) -->
            <div id="form-success" class="hidden mt-4 p-4 bg-surface border border-accent/30 text-center">
              <p class="font-body text-sm text-text-muted">
                Message received. Danielle will be in touch within 1-2 business days.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // ── Calendly load detection ────────────────────────────────────────────
  // Calendly's widget.js inserts an <iframe> into .calendly-inline-widget.
  // We watch for that insertion. If no iframe appears within 12 seconds
  // (ad blocker, CDN down, slow network), we show an elegant fallback
  // with a direct booking link and a retry button.
  //
  // Why 12s? Calendly can be slow on first load. 8s was too aggressive
  // and showed false-positive fallbacks on legitimate slow connections.

  (function initCalendlyGuard() {
    const widget   = document.getElementById('calendly-widget')   as HTMLElement | null;
    const skeleton = document.getElementById('calendly-loading')  as HTMLElement | null;
    const fallback = document.getElementById('calendly-fallback') as HTMLElement | null;
    const retryBtn = document.getElementById('calendly-retry')    as HTMLButtonElement | null;

    if (!widget || !fallback) return;

    let revealed = false;
    const TIMEOUT_MS = 14_000;  // generous — Calendly can be slow

    // ── Crossfade: skeleton OUT, widget IN simultaneously ─────────────────
    // Both transitions happen at the same time (600ms ease each).
    // After the fade the skeleton is removed from the layout entirely.
    function revealCalendly() {
      if (revealed) return;
      revealed = true;
      clearTimeout(fallbackTimer);

      if (skeleton) {
        skeleton.style.opacity = '0';
        setTimeout(() => {
          if (skeleton) skeleton.style.display = 'none';
        }, 650);
      }
      widget.style.opacity = '1';
    }

    function showFallback() {
      if (skeleton) { skeleton.style.opacity = '0'; skeleton.style.display = 'none'; }
      widget.style.display = 'none';
      fallback.classList.remove('hidden');
    }

    function hideFallback() {
      widget.style.display = '';
      fallback.classList.add('hidden');
    }

    // ── Primary trigger: Calendly postMessage ─────────────────────────────
    // calendly.profile_page_viewed fires when the scheduling page is fully
    // rendered and "Select a Date & Time" is visible to the user.
    // This is the most accurate trigger — the iframe content is actually ready.
    function isCalendlyMsg(e: MessageEvent): boolean {
      return (
        e.origin === 'https://calendly.com' &&
        typeof e.data === 'object' &&
        typeof e.data.event === 'string' &&
        e.data.event.startsWith('calendly.')
      );
    }

    window.addEventListener('message', (e: MessageEvent) => {
      if (!isCalendlyMsg(e)) return;
      // Profile page viewed = "Select a Date & Time" is on screen
      if (e.data.event === 'calendly.profile_page_viewed') {
        revealCalendly();
      }
      // Event scheduled = hand off to booking-confirmed handler (existing logic below)
    });

    // ── Secondary trigger: iframe insertion (fallback for postMessage) ─────
    // If Calendly fires the iframe but doesn't send profile_page_viewed
    // (can happen in some embed configs), we reveal after a short delay
    // to let the iframe's content finish rendering before fading in.
    const observer = new MutationObserver(() => {
      if (widget.querySelector('iframe')) {
        observer.disconnect();
        // Wait 800ms after iframe insertion — gives Calendly's UI time to paint
        // before we reveal it. Avoids a flash of blank iframe content.
        setTimeout(revealCalendly, 800);
      }
    });
    observer.observe(widget, { childList: true, subtree: true });

    // ── Tertiary trigger: hard timeout ────────────────────────────────────
    // If neither postMessage nor iframe appear after TIMEOUT_MS, show fallback.
    const fallbackTimer = setTimeout(() => {
      observer.disconnect();
      if (!revealed && !widget.querySelector('iframe')) {
        showFallback();
      }
    }, TIMEOUT_MS);

    // ── Retry ─────────────────────────────────────────────────────────────
    retryBtn?.addEventListener('click', () => {
      hideFallback();
      revealed = false;
      widget.style.opacity = '0';
      if (skeleton) { skeleton.style.display = ''; skeleton.style.opacity = '1'; }

      if (typeof (window as any).Calendly !== 'undefined') {
        try {
          (window as any).Calendly.initInlineWidgets();
          observer.observe(widget, { childList: true, subtree: true });
          return;
        } catch {}
      }
      window.location.reload();
    });
  })();

  // Show Formspree success message if redirected back with ?success=true
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    const msg = document.getElementById('form-success');
    if (msg) msg.classList.remove('hidden');
    window.history.replaceState({}, '', '/contact');
  }

  // Intercept Calendly's post-booking redirect so we navigate ourselves.
  // This avoids Calendly's "You are leaving Calendly" warning page entirely.
  //
  // REQUIRED CALENDLY SETTING: In the event's Confirmation Page settings,
  // change "Redirect to external page" back to "Calendly's confirmation page"
  // (i.e. turn OFF the redirect). This script handles navigation instead.
  //
  // Calendly fires `calendly.event_scheduled` via postMessage immediately
  // after a booking is confirmed — before any redirect happens.
  function isCalendlyEvent(e: MessageEvent): boolean {
    return (
      e.origin === 'https://calendly.com' &&
      typeof e.data === 'object' &&
      typeof e.data.event === 'string' &&
      e.data.event.startsWith('calendly.')
    );
  }

  window.addEventListener('message', (e: MessageEvent) => {
    if (!isCalendlyEvent(e) || e.data.event !== 'calendly.event_scheduled') return;

    const payload = e.data.payload ?? {};
    const invitee = payload.invitee ?? {};
    const scheduledEvent = payload.event ?? {};

    // Build query string from whatever Calendly gives us in the postMessage payload
    const qs = new URLSearchParams();
    if (invitee.full_name)      qs.set('invitee_full_name', invitee.full_name);
    if (invitee.email)          qs.set('invitee_email', invitee.email);
    if (scheduledEvent.start_time) qs.set('event_start_time', scheduledEvent.start_time);
    if (scheduledEvent.end_time)   qs.set('event_end_time', scheduledEvent.end_time);

    window.location.href = '/booking-confirmed' + (qs.toString() ? '?' + qs.toString() : '');
  });
</script>
