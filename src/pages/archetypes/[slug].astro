          >
            All Archetypes
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200 min-h-[48px]"
          >
            Book a Consultation
          </a>
        </div>
      </div>

      <!-- Other archetypes from same gender as quick-nav cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-8">
        {otherArchetypes.map((other) => (
          <a
            href={`/archetypes/${other.data.slug}`}
