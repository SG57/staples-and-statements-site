    align-items: center;
    gap: 0.875rem;
    flex: 0 0 100%;
    scroll-snap-align: start;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.75rem 1rem 0.75rem 0.75rem;
    text-decoration: none;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .shade-ltk-card:hover {
    background: rgba(184,151,126,0.09);
    border-color: var(--color-accent);
  }

  /* Fixed-size image frame — covers transparent product shot backgrounds */
  .shade-ltk-img-frame {
    width: 84px;
    height: 112px;
    flex-shrink: 0;
    overflow: hidden;
    background: #1e1a1a;
  }
  .shade-ltk-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .shade-ltk-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .shade-ltk-name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
    line-height: 1.2;
    /* Allow wrapping on mobile — truncation loses too much context on small screens */
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    white-space: normal;
  }
  .shade-ltk-meta {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.35);
  }
  /* Text-only CTA — no box */
  .shade-ltk-cta {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }

  /* LTK cards on mobile: ensure minimum touch target height */
  @media (max-width: 767px) {
    .shade-ltk-card {
      min-height: 48px;
      padding: 0.875rem 1rem 0.875rem 0.875rem;
    }

    .shade-ltk-img-frame {
      width: 72px;
      height: 96px;
    }
  }

  /* Comparator image transition */
  #shade-comparison-img {
    transition: opacity 300ms ease;
  }

  #shade-comparison-img.is-transitioning {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-primary .gallery-img,
    .gallery-secondary-1 .gallery-img,
    .gallery-secondary-2 .gallery-img {
      animation: none !important;
    }

    .style-icon-group > div:first-child,
    .style-icon-label,
    .gallery-img,
    .gallery-overlay,
    .gallery-overlay-inner,
    .gallery-expand-hint,
    .gallery-lightbox,
    .gallery-lightbox-img,
    .gallery-lightbox-bullets,
    #shade-comparison-img {
      transition: none !important;
    }
  }
</style>


<script>
  document.addEventListener('astro:page-load', () => {

  // ── Style icon image fallback ──────────────────────────────
  document.querySelectorAll<HTMLImageElement>('.icon-img').forEach((img) => {
    img.addEventListener('error', () => {
      img.classList.add('is-hidden');
    });
  });

  // ── Gallery parallax on scroll ─────────────────────────────
  const parallaxImgs = document.querySelectorAll<HTMLImageElement>('[data-parallax]');
  let ticking = false;

  const applyParallax = () => {
    parallaxImgs.forEach((img) => {
      const strength = parseFloat(img.dataset.parallax ?? '0.08');
      const item = img.closest<HTMLElement>('.gallery-item');
      if (!item) return;
      const rect = item.getBoundingClientRect();
      const viewH = window.innerHeight;
      // Only apply while item intersects viewport
      if (rect.bottom < 0 || rect.top > viewH) return;
      const center = rect.top + rect.height / 2 - viewH / 2;
      const offset = (center * strength).toFixed(1);
      // Use individual `translate` CSS property so it composes with the
      // animation's `transform` rather than overriding it.
      img.style.translate = `0 ${offset}px`;
    });
    ticking = false;
  };

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(applyParallax);
      ticking = true;
    }
  }, { passive: true });

  // Initial call
  applyParallax();

  // ── Gallery lightbox ───────────────────────────────────────
  const lightbox    = document.getElementById('gallery-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxTitle   = document.getElementById('lightbox-title');
  const lightboxBullets = document.getElementById('lightbox-bullets');
  const lightboxClose   = document.getElementById('lightbox-close');

  const openLightbox = (src: string, title: string, bullets: string[]) => {
    if (!lightbox || !lightboxImg || !lightboxTitle || !lightboxBullets) return;
    lightboxImg.src = src;
    lightboxTitle.textContent = title;
    lightboxBullets.innerHTML = bullets.map((b) => `<li>${b}</li>`).join('');
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  // Detect touch device — first tap reveals overlay, second opens lightbox
  const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

  document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
    item.addEventListener('click', (e) => {
      const src     = item.dataset.lookSrc ?? '';
      const title   = item.dataset.lookTitle ?? '';
      const bullets = JSON.parse(item.dataset.lookBullets ?? '[]') as string[];

      if (isTouchDevice && !item.classList.contains('is-tapped')) {
        // First tap: reveal overlay, clear sibling tapped states
        e.preventDefault();
        document.querySelectorAll<HTMLElement>('.gallery-item.is-tapped').forEach((el) => {
          if (el !== item) el.classList.remove('is-tapped');
        });
        item.classList.add('is-tapped');
        return;
      }

      openLightbox(src, title, bullets);
    });
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.querySelector('.gallery-lightbox-backdrop')?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox?.classList.contains('is-open')) closeLightbox();
  });

  // ── Blend comparator ──────────────────────────────────────
  const comparatorImg   = document.getElementById('shade-comparison-img') as HTMLImageElement | null;
  const comparatorLabel = document.getElementById('comparator-shade-label');

  document.querySelectorAll<HTMLElement>('.shade-thumb').forEach((thumb, _idx, allThumbs) => {
    thumb.addEventListener('click', () => {
      const slug  = thumb.dataset.shadeSlug!;
      const name  = thumb.dataset.shadeName!;
      const image = thumb.dataset.shadeImage!;
      const color = thumb.dataset.shadeColor ?? '#b8977e';

      // Crossfade the comparator image
      if (comparatorImg) {
        comparatorImg.classList.add('is-transitioning');
        setTimeout(() => {
          comparatorImg.src = image;
          comparatorImg.alt = name;
          comparatorImg.classList.remove('is-transitioning');
        }, 150);
      }

      if (comparatorLabel) comparatorLabel.textContent = name;

      // Update active thumbnail rings + aria-checked + roving tabindex
      allThumbs.forEach((t) => {
        const isActive = t === thumb;
        t.setAttribute('aria-checked', String(isActive));
        t.tabIndex = isActive ? 0 : -1;
        const ring = t.querySelector<HTMLElement>('.shade-thumb-ring');
        if (ring) {
          ring.style.boxShadow = isActive
            ? `inset 0 0 0 2px ${color}`
            : 'inset 0 0 0 1px rgba(255,255,255,0.12)';
        }
      });

      // Show matching shade description, hide others
      document.querySelectorAll<HTMLElement>('.shade-content').forEach((content) => {
        const isMatch = content.dataset.shadeFor === slug;
        content.classList.toggle('hidden', !isMatch);
        content.classList.toggle('block', isMatch);
      });

      // ── LTK blend widget ──────────────────────────────────────────────────
      updateLtkBlendWidget(slug);
    });
  });

  function updateLtkBlendWidget(secondarySlug: string) {
    const section = document.getElementById('shade-ltk-section');
    if (!section) return;
    const groups = Array.from(section.querySelectorAll<HTMLElement>('.shade-ltk-group'));
    const current = groups.find(g => g.classList.contains('is-active'));
    const next = groups.find(g => g.dataset.secondarySlug === secondarySlug);
    if (current === next) return;
    if (current) current.classList.remove('is-active');
    if (next) { next.classList.add('is-active'); section.classList.add('has-content'); }
    else { section.classList.remove('has-content'); }
  }

  // Initialize widget for the default selected shade on page load
  updateLtkBlendWidget(document.querySelector<HTMLElement>('.shade-thumb[aria-checked="true"]')?.dataset.shadeSlug ?? '');

  // Arrow-key navigation for shade thumb radiogroup
  const thumbGroup = document.querySelector<HTMLElement>('[role="radiogroup"]');
  thumbGroup?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) return;
    e.preventDefault();
    const thumbs = Array.from(thumbGroup.querySelectorAll<HTMLButtonElement>('.shade-thumb'));
    const currentIdx = thumbs.findIndex((t) => t === document.activeElement);
    if (currentIdx === -1) return;
    const dir     = (e.key === 'ArrowRight' || e.key === 'ArrowDown') ? 1 : -1;
    const nextIdx = (currentIdx + dir + thumbs.length) % thumbs.length;
    thumbs[currentIdx].tabIndex = -1;
    thumbs[nextIdx].tabIndex = 0;
    thumbs[nextIdx].focus();
    thumbs[nextIdx].click();
  });

  }); // astro:page-load
</script>
