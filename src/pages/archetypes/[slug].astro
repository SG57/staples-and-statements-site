---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getShadesForPrimary } from '../../data/archetype-shades';
import { getVisualsForSlug, iconPaths } from '../../data/archetype-visuals';
import { guides } from '../../data/guides';

export async function getStaticPaths() {
  const archetypes = await getCollection('archetypes');
  return archetypes.map((archetype) => ({
    params: { slug: archetype.data.slug },
    props: { archetype },
  }));
}

const { archetype } = Astro.props;
const data = archetype.data;

/* Visual data for this archetype */
const visuals = getVisualsForSlug(data.slug);

/* Get all archetypes of the same gender for the shades selector */
const allArchetypes = await getCollection('archetypes', ({ data: d }) => d.gender === data.gender);
const otherArchetypes = allArchetypes
  .filter((a) => a.data.slug !== data.slug)
  .sort((a, b) => a.data.order - b.data.order);

/* Get shade descriptions for this archetype as primary */
const shades = getShadesForPrimary(data.slug);

/* The first "other" archetype is the default shade selection */
const defaultShadeSlug = otherArchetypes[0]?.data.slug ?? '';

/* Hero image: use wallpaper if it exists, fall back to card image */
const fallbackSrc = `/images/archetypes/${data.slug}-1.webp`;

/* Determine gender label for cross-linking */
const isFeminine = data.gender === 'feminine';

/* Style guide upsell: match the guide to this archetype's gender */
const genderGuide = isFeminine
  ? guides.find((g) => g.slug === '7-feminine-archetypes')
  : guides.find((g) => g.slug === 'mens-edition');
---

<BaseLayout
  title={`${data.name} — Style Archetype | Staples & Statements`}
  description={data.description}
  transparentNav={true}
>

  <!-- ── HERO: Full-viewport wallpaper ────────────────────── -->
  <section class="relative min-h-screen flex items-end overflow-hidden bg-primary">
    <!-- Wallpaper image (falls back to card image until AI wallpaper generated) -->
    <img
      src={fallbackSrc}
      alt={`${data.name} archetype atmosphere`}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Gradient overlays for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/50 to-primary/10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/40 via-transparent to-transparent pointer-events-none"></div>
    <!-- Nav-hood scrim -->
    <div class="absolute top-0 left-0 right-0 h-40 pointer-events-none z-[5]"
         style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 55%, transparent 100%)"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 pb-20 pt-36 lg:pt-44 w-full">
      <!-- Archetype badge -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 flex items-center justify-center rounded-full border border-accent/40 bg-accent/10 backdrop-blur-sm">
          <span class="text-lg text-accent">{data.icon}</span>
        </div>
        <p class="font-body text-xs tracking-widest uppercase text-accent">
          {isFeminine ? 'Feminine' : 'Masculine'} Archetype
        </p>
      </div>

      <!-- Archetype name -->
      <h1 class="font-heading text-white text-5xl md:text-7xl lg:text-8xl font-semibold leading-[0.95] max-w-3xl mb-4">
        {data.name}
      </h1>

      <!-- Tagline as subtitle -->
      {visuals && (
        <p class="font-heading text-white/60 text-xl md:text-2xl italic max-w-xl leading-relaxed mb-6">
          {visuals.tagline}
        </p>
      )}

      <!-- Accent line in archetype color -->
      <div class="w-16 h-1 mb-10" style={`background-color: ${data.color}`}></div>

      <!-- Hero CTAs -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="/archetypes#archetypes"
          class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
        >
          Find Your Archetype
        </a>
        {data.guideLink && (
          <a
            href={data.guideLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200"
          >
            Shop This Style
          </a>
        )}
      </div>
    </div>

    <!-- Sentinel: when this leaves viewport, compact header appears -->
    <div class="section-sentinel" data-section="archetype-hero" aria-hidden="true"></div>
  </section>

  <!-- ── COMPACT STICKY HEADER ─────────────────────────────── -->
  <div class="section-header-compact fixed top-16 lg:top-20 left-0 right-0 z-30
              bg-primary/85 backdrop-blur-md border-b border-white/8
              px-6 py-3
              opacity-0 pointer-events-none
              transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
       data-section-compact="archetype-hero">
    <div class="mx-auto max-w-7xl flex items-center gap-3">
      <span class="text-lg" style={`color: ${data.color}`}>{data.icon}</span>
      <h2 class="font-heading text-white text-lg font-semibold">{data.name}</h2>
      <span class="text-white/20">|</span>
      <p class="font-body text-[10px] tracking-widest uppercase text-white/50">
        {isFeminine ? 'Feminine' : 'Masculine'}
      </p>
    </div>
  </div>


  <!-- ── DEEP DIVE: Visual archetype content ─────────────────── -->
  <section class="py-24 px-6 bg-primary" aria-label={`About ${data.name}`}>
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-[45fr_55fr] gap-16 lg:gap-20">

        <!-- LEFT COLUMN: Image Collage + Style Icons -->
        <div class="h-fit lg:sticky lg:top-28">
          <!-- Cascaded image collage -->
          <div class="archetype-collage relative flex flex-col items-center px-6 pt-4 pb-8">
            <!-- Image 1: slight left rotate, back -->
            <div class="archetype-collage-img relative z-10 w-[85%] aspect-[3/4] overflow-hidden rounded-sm border border-white/10"
                 style="transform: rotate(-2deg);">
              <img src={`/images/archetypes/${data.slug}-1.webp`} alt={`${data.name} — look 1`}
                   class="w-full h-full object-cover object-top" loading="lazy" />
            </div>
            <!-- Image 2: center, front, larger -->
            <div class="archetype-collage-img relative z-20 w-[90%] aspect-[3/4] overflow-hidden rounded-sm border border-white/10 -mt-[35%] scale-105"
                 style="transform: rotate(0deg) scale(1.05);">
              <img src={`/images/archetypes/${data.slug}-2.webp`} alt={`${data.name} — look 2`}
                   class="w-full h-full object-cover object-top" loading="lazy" />
            </div>
            <!-- Image 3: slight right rotate, back -->
            <div class="archetype-collage-img relative z-10 w-[85%] aspect-[3/4] overflow-hidden rounded-sm border border-white/10 -mt-[35%]"
                 style="transform: rotate(1deg);">
              <img src={`/images/archetypes/${data.slug}-3.webp`} alt={`${data.name} — look 3`}
                   class="w-full h-full object-cover object-top" loading="lazy" />
            </div>
          </div>

          <!-- Style Icons (below collage) -->
          {visuals && visuals.styleIcons.length > 0 && (
            <div class="mt-8">
              <p class="font-body text-[11px] tracking-widest uppercase text-accent mb-4 text-center lg:text-left">
                Style Icons
              </p>
              <div class="flex flex-wrap justify-center lg:justify-start gap-6">
                {visuals.styleIcons.map((icon) => (
                  <div class="group flex flex-col items-center">
                    <div class="relative w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden
                                border-2 border-white/15 group-hover:border-accent/50
                                transition-all duration-300">
                      <!-- Actual image (hidden if load fails) -->
                      <img
                        src={icon.image}
                        alt={icon.name}
                        class="icon-img absolute inset-0 w-full h-full object-cover"
                        loading="lazy"
                      />
                      <!-- Letter fallback (shown when image fails) -->
                      <div class="icon-fallback absolute inset-0 w-full h-full bg-white/10
                                  flex items-center justify-center
                                  font-heading text-2xl text-white/30">
                        {icon.name[0]}
                      </div>
                    </div>
                    <span class="mt-2 font-body text-xs text-white/50
                                 group-hover:text-white/80 transition-colors duration-200">
                      {icon.name}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- RIGHT COLUMN: Description + Color Palette + Signature Pieces + Guide Upsell -->
        <div>
          {visuals ? (
            <>
              <!-- Core description -->
              <div class="font-body text-white/75 text-base md:text-lg leading-relaxed">
                {visuals.bodyText.split('\n\n').map((paragraph) => (
                  <p class="mb-4 max-w-none">{paragraph}</p>
                ))}
              </div>

              <!-- Color palette swatches -->
              <div class="flex flex-wrap gap-2 mt-8 mb-2 justify-center lg:justify-start">
                {visuals.palette.map((color) => (
                  <div class="group relative">
                    <div
                      class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/15
                             cursor-default transition-transform duration-200
                             hover:scale-110"
                      style={`background-color: ${color.hex};
                              box-shadow: inset 0 2px 4px rgba(0,0,0,0.3),
                                          inset 0 -1px 2px rgba(255,255,255,0.1);`}
                      title={color.name}
                    />
                    <span class="absolute -bottom-7 left-1/2 -translate-x-1/2
                                 font-body text-[10px] text-white/60 whitespace-nowrap
                                 opacity-0 group-hover:opacity-100 transition-opacity duration-200
                                 pointer-events-none">
                      {color.name}
                    </span>
                  </div>
                ))}
              </div>

              <!-- ── Divider ── -->
              <div class="w-full h-px bg-white/8 my-10"></div>

              <!-- Signature Pieces (first two only) -->
              <div>
                <p class="font-body text-[11px] tracking-widest uppercase text-accent mb-5">
                  Signature Pieces
                </p>
                <div class="grid grid-cols-2 gap-2.5">
                  {visuals.signaturePieces.slice(0, 2).map((piece) => (
                    <div class="flex flex-col items-center text-center p-4
                                bg-white/[0.03] backdrop-blur-sm border border-white/[0.07]
                                rounded-sm hover:bg-white/[0.06] transition-all duration-200">
                      <svg
                        class="w-8 h-8 text-accent/70 mb-2"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d={iconPaths[piece.icon]} />
                      </svg>
                      <span class="font-body text-xs text-white/70 leading-snug">{piece.name}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Style Guide Upsell Card -->
              {genderGuide && (
                <div class="mt-6 bg-white/[0.03] backdrop-blur-sm border border-white/[0.07] rounded-sm p-5 md:p-6
                            hover:bg-white/[0.05] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]">
                  <div class="flex gap-5 items-start">
                    <!-- Guide cover thumbnail -->
                    <div class="shrink-0 w-20 md:w-24 aspect-[3/4] overflow-hidden rounded-sm border border-white/10">
                      <img
                        src={`/images/guides/${genderGuide.slug}-cover.webp`}
                        alt={genderGuide.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                    <!-- Guide info + CTAs -->
                    <div class="flex-1 min-w-0">
                      <p class="font-body text-[10px] tracking-widest uppercase text-accent mb-1.5">
                        Style Guide
                      </p>
                      <h3 class="font-heading text-white text-base md:text-lg font-semibold leading-snug mb-1.5">
                        {genderGuide.title}
                      </h3>
                      <p class="font-body text-white/50 text-sm leading-relaxed mb-4 max-w-none">
                        Your complete archetype wardrobe blueprint — from {genderGuide.price}
                      </p>
                      <div class="flex flex-col sm:flex-row gap-2.5">
                        <a
                          href={genderGuide.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center justify-center px-5 py-2.5 bg-accent text-white font-body text-xs font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
                        >
                          Get the Full Guide
                          <svg class="w-3.5 h-3.5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                          </svg>
                        </a>
                        <a
                          href="/shop#style-guides"
                          class="inline-flex items-center justify-center px-5 py-2.5 text-white/60 font-body text-xs tracking-widest uppercase hover:text-white transition-colors duration-200"
                        >
                          View Style Guides
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </>
          ) : (
            /* Fallback if no visuals data exists for this archetype */
            <div class="archetype-prose font-body text-white/75 text-base leading-relaxed space-y-4">
              <p class="text-white/50 italic">Visual data coming soon.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>


  <!-- ── WITH SHADES OF: Permutation explorer ─────────────── -->
  {shades.length > 0 && (
    <section id="shades" class="py-24 px-6 bg-primary border-t border-white/8" aria-label="Explore archetype blends">
      <div class="mx-auto max-w-4xl">
        <div class="text-center mb-12">
          <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">Your Unique Blend</p>
          <h2 class="font-heading text-white text-3xl md:text-4xl font-semibold mb-4">
            {data.name} <span class="text-white/40">with shades of...</span>
          </h2>
          <p class="font-body text-white/55 text-base max-w-lg mx-auto leading-relaxed">
            Most people are a blend of two archetypes. Select a secondary to explore what your unique combination means.
          </p>
        </div>

        <!-- Secondary selector chips -->
        <div class="flex flex-wrap justify-center gap-3 mb-10" role="radiogroup" aria-label="Select secondary archetype">
          {otherArchetypes.map((other, i) => (
            <button
              type="button"
              class="shade-chip font-body text-sm px-5 py-2.5
                     bg-white/5 border border-white/15 text-white/60
                     hover:bg-white/10 hover:border-white/25 hover:text-white
                     transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]
                     focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2
                     cursor-pointer select-none"
              data-shade-slug={other.data.slug}
              data-shade-name={other.data.name}
              role="radio"
              aria-checked={i === 0 ? 'true' : 'false'}
            >
              <span class="mr-1.5" style={`color: ${other.data.color}`}>{other.data.icon}</span>
              {other.data.name}
            </button>
          ))}
        </div>

        <!-- Shade description display -->
        <div class="shade-display bg-white/3 border border-white/10 rounded-sm p-8 md:p-10 backdrop-blur-sm">
          {shades.map((shade) => (
            <div
              class:list={[
                'shade-content transition-opacity duration-300',
                shade.secondary === defaultShadeSlug ? 'block' : 'hidden',
              ]}
              data-shade-for={shade.secondary}
            >
              <div class="flex items-center gap-2 mb-4">
                <span class="text-accent text-lg">{data.icon}</span>
                <span class="font-heading text-white text-xl font-semibold">{data.name}</span>
                <span class="text-white/30 mx-1">&times;</span>
                <span class="font-heading text-white/70 text-xl">{shade.secondaryName}</span>
              </div>
              <p class="font-body text-white/70 text-base leading-relaxed italic">
                {shade.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ── EXPLORE MORE ─────────────────────────────────────── -->
  <section class="py-20 px-6 bg-primary border-t border-white/8" aria-label="Explore more archetypes">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 py-10">
        <div>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-2">Keep Exploring</p>
          <h2 class="font-heading text-white text-3xl font-semibold">Discover More Archetypes</h2>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a
            href="/archetypes"
            class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            All Archetypes
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200"
          >
            Book a Consultation
          </a>
        </div>
      </div>

      <!-- Other archetypes from same gender as quick-nav cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-8">
        {otherArchetypes.map((other) => (
          <a
            href={`/archetypes/${other.data.slug}`}
            class="group relative overflow-hidden aspect-[3/4] block"
          >
            <img
              src={`/images/archetypes/${other.data.slug}-1.webp`}
              alt={other.data.name}
              class="absolute inset-0 w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent pointer-events-none"></div>
            <div class="absolute top-0 left-0 right-0 h-0.5" style={`background-color: ${other.data.color}`}></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 z-10">
              <div class="flex items-center gap-2">
                <span class="text-accent/70">{other.data.icon}</span>
                <h3 class="font-heading text-white text-lg font-semibold leading-tight">{other.data.name}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  /* ── Active shade chip ─────────────────────────────────── */
  .shade-chip[aria-checked="true"] {
    background: rgba(184, 151, 126, 0.15);
    border-color: rgba(184, 151, 126, 0.4);
    color: white;
  }

  /* ── Style icon image/fallback layering ────────────────── */
  .icon-img {
    z-index: 1;
  }
  .icon-fallback {
    z-index: 0;
  }
  .icon-img.is-hidden {
    display: none;
  }

  /* ── Image collage: cascaded magazine layout ────────────── */
  .archetype-collage-img {
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1),
                z-index 0ms;
  }
  .archetype-collage-img:hover {
    transform: scale(1.08) rotate(0deg) !important;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    z-index: 30;
  }
</style>


<script>
  // ── Style icon image fallback ──────────────────────────────
  // Hide broken images so the letter-initial fallback shows through.

  document.querySelectorAll<HTMLImageElement>('.icon-img').forEach((img) => {
    img.addEventListener('error', () => {
      img.classList.add('is-hidden');
    });
  });

  // ── "With Shades Of" selector ─────────────────────────────
  // Toggles shade descriptions when user clicks a secondary archetype chip.

  document.querySelectorAll<HTMLElement>('.shade-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const slug = chip.dataset.shadeSlug!;
      const container = chip.closest('section');
      if (!container) return;

      // Update chip states
      container.querySelectorAll<HTMLElement>('.shade-chip').forEach((c) => {
        const isActive = c === chip;
        c.setAttribute('aria-checked', String(isActive));
      });

      // Show matching shade description, hide others
      container.querySelectorAll<HTMLElement>('.shade-content').forEach((content) => {
        const isMatch = content.dataset.shadeFor === slug;
        content.classList.toggle('hidden', !isMatch);
        content.classList.toggle('block', isMatch);
      });
    });
  });

  // ── Compact sticky header (sentinel observer) ──────────────
  // Shows a compact archetype name bar when the hero scrolls out of view.

  document.addEventListener('astro:page-load', () => {
    const sentinels = document.querySelectorAll<HTMLElement>('.section-sentinel');
    if (sentinels.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const section = (entry.target as HTMLElement).dataset.section;
        if (!section) return;

        const compact = document.querySelector<HTMLElement>(`[data-section-compact="${section}"]`);
        if (!compact) return;

        // Only show compact when sentinel scrolled ABOVE viewport (not when still below)
        const aboveViewport = entry.boundingClientRect.top < 0;
        const shouldShow = !entry.isIntersecting && aboveViewport;
        compact.style.opacity = shouldShow ? '1' : '0';
        compact.style.pointerEvents = shouldShow ? 'auto' : 'none';
      });
    }, { threshold: 0, rootMargin: '-30px 0px 0px 0px' });

    sentinels.forEach(s => observer.observe(s));
  });
</script>
