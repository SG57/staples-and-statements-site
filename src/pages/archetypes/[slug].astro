              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent pointer-events-none"></div>
            <div class="absolute top-0 left-0 right-0 h-0.5" style={`background-color: ${other.data.color}`}></div>
