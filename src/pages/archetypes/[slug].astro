---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getShadesForPrimary } from '../../data/archetype-shades';
import { getVisualsForSlug, iconPaths } from '../../data/archetype-visuals';
import { guides } from '../../data/guides';
import { getCardImages, getWallpaper } from '../../data/archetype-images';
import { fetchLtkCollections, getBlendCollections, getCollectionsForArchetype } from '../../data/ltk-api';

export async function getStaticPaths() {
  const archetypes = await getCollection('archetypes');
  return archetypes.map((archetype) => ({
    params: { slug: archetype.data.slug },
    props: { archetype },
  }));
}

const { archetype } = Astro.props;
const data = archetype.data;

/* Visual data for this archetype */
const visuals = getVisualsForSlug(data.slug);

/* Get all archetypes of the same gender for the shades selector */
const allArchetypes = await getCollection('archetypes', ({ data: d }) => d.gender === data.gender);
const otherArchetypes = allArchetypes
  .filter((a) => a.data.slug !== data.slug)
  .sort((a, b) => a.data.order - b.data.order);

/* Get shade descriptions for this archetype as primary */
const shades = getShadesForPrimary(data.slug);

/* The first "other" archetype is the default shade selection */
const defaultShadeSlug = otherArchetypes[0]?.data.slug ?? '';

/* Hero wallpaper + card images for gallery */
const cardImages  = getCardImages(data.slug);
const wallpaperSrc = getWallpaper(data.slug) ?? cardImages[0] ?? `/images/archetypes/${data.slug}-1.webp`;

/* Primary card image used in comparator */
const primaryCardImage = cardImages[0] ?? wallpaperSrc;

/* Other archetypes enriched with their first card image (for comparator thumbnails) */
const otherArchetypesWithImages = otherArchetypes.map((a) => ({
  archetype: a,
  image: getCardImages(a.data.slug)[0] ?? `/images/archetypes/${a.data.slug}-1.webp`,
}));

/* ── LTK blend map ── */
const _ltkAll = await fetchLtkCollections();
// blendMap: secondarySlug → array of collections matching BOTH primary + secondary
type LtkCardData = { title: string; url: string; cover: string; count: number };
const blendMap: Record<string, LtkCardData[]> = {};
for (const other of otherArchetypes) {
  const matches = getBlendCollections(_ltkAll, data.slug, other.data.slug);
  if (matches.length > 0) {
    blendMap[other.data.slug] = matches.map((c) => ({
      title: c.title,
      url:   c.collection_url,
      cover: c.cover,
      count: c.product_count,
    }));
  }
}
// Single-archetype collections for this page (non-blend)
const archetypeCollections = getCollectionsForArchetype(_ltkAll, data.slug)
  .filter((c) => !c.isBlend)
  .map((c) => ({ title: c.title, url: c.collection_url, cover: c.cover, count: c.product_count }));

/* Determine gender label for cross-linking */
const isFeminine = data.gender === 'feminine';

/* Style guide upsell: match the guide to this archetype's gender */
const genderGuide = isFeminine
  ? guides.find((g) => g.slug === '7-feminine-archetypes')
  : guides.find((g) => g.slug === 'mens-edition');
---

<BaseLayout
  title={`${data.name} — Style Archetype | Staples & Statements`}
  description={data.description}
  transparentNav={true}
>

  <!-- ── HERO: Full-viewport wallpaper ────────────────────── -->
  <section class="relative min-h-screen flex items-end overflow-hidden bg-primary">
    <!-- Wallpaper hero (scanned at build time; falls back to first card image) -->
    <img
      src={wallpaperSrc}
      alt={`${data.name} archetype atmosphere`}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Gradient overlays for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/50 to-primary/10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/40 via-transparent to-transparent pointer-events-none"></div>
    <!-- Nav-hood scrim -->
    <div class="absolute top-0 left-0 right-0 h-40 pointer-events-none z-[5]"
         style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 55%, transparent 100%)"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 pb-16 sm:pb-20 pt-32 sm:pt-36 lg:pt-44 w-full">
      <!-- Archetype badge -->
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <div class="w-10 h-10 flex items-center justify-center rounded-full border border-accent/40 bg-accent/10 backdrop-blur-sm">
          <span class="text-lg text-accent">{data.icon}</span>
        </div>
        <p class="font-body text-xs tracking-widest uppercase text-accent text-bloom-sm">
          {isFeminine ? 'Feminine' : 'Masculine'} Archetype
        </p>
      </div>

      <!-- Archetype name -->
      <h1 class="font-heading text-white text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-semibold leading-[0.95] max-w-3xl mb-3 sm:mb-4 text-bloom">
        {data.name}
      </h1>

      <!-- Tagline as subtitle -->
      {visuals && (
        <p class="font-heading text-white/60 text-lg sm:text-xl md:text-2xl italic max-w-xl leading-relaxed mb-5 sm:mb-6 text-bloom-sm">
          {visuals.tagline}
        </p>
      )}

      <!-- Accent line in archetype color -->
      <div class="w-12 sm:w-16 h-1 mb-8 sm:mb-10" style={`background-color: ${data.color}`}></div>

      <!-- Hero CTAs -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="/archetypes#archetypes"
          class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200 min-h-[48px]"
        >
          Find Your Archetype
        </a>
        {data.guideLink && (
          <a
            href={data.guideLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200 min-h-[48px]"
          >
            Shop This Style
          </a>
        )}
      </div>
    </div>

  </section>


  <!-- ── SIGNATURE GALLERY: flows directly from hero, full-bleed ── -->
  {visuals?.galleryLooks && cardImages.length >= 1 && (
    <section
      class="relative bg-primary overflow-hidden"
      aria-label={`${data.name} signature looks`}
      data-compact-super="Editorial"
      data-compact-title={`Signature ${data.name} Looks`}
      data-compact-theme="dark"
    >
      <!-- Section header — tight top padding so it reads as hero continuation -->
      <div class="mx-auto max-w-7xl px-6 pt-8 sm:pt-10 pb-8 sm:pb-10">
        <div class="w-8 h-px bg-accent mb-4"></div>
        <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">— Editorial</p>
        <h2 class="font-heading text-white text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight">
          Signature {data.name} Looks
        </h2>
      </div>

      <!-- Editorial mosaic: 60% primary left, 40% right column with 2 stacked -->
      <div class="gallery-mosaic">

        <!-- Primary image (card index 0) -->
        <div
          class="gallery-item gallery-primary group cursor-pointer"
          data-look-title={visuals.galleryLooks[0].title}
          data-look-src={cardImages[0]}
          data-look-bullets={JSON.stringify(visuals.galleryLooks[0].bullets)}
        >
          <div class="gallery-img-wrap">
            <img
              src={cardImages[0]}
              alt={`${data.name} — ${visuals.galleryLooks[0].title}`}
              class="gallery-img"
              loading="lazy"
              data-parallax="0.08"
            />
          </div>
          <div class="gallery-overlay">
            <div class="gallery-overlay-inner">
              <p class="gallery-look-tag">{visuals.galleryLooks[0].title}</p>
              <ul class="gallery-bullets">
                {visuals.galleryLooks[0].bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          </div>
          <div class="gallery-expand-hint" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </div>

        <!-- Secondary image 1 (card index 1) -->
        {cardImages[1] && visuals.galleryLooks[1] && (
          <div
            class="gallery-item gallery-secondary-1 group cursor-pointer"
            data-look-title={visuals.galleryLooks[1].title}
            data-look-src={cardImages[1]}
            data-look-bullets={JSON.stringify(visuals.galleryLooks[1].bullets)}
          >
            <div class="gallery-img-wrap">
              <img
                src={cardImages[1]}
                alt={`${data.name} — ${visuals.galleryLooks[1].title}`}
                class="gallery-img"
                loading="lazy"
                data-parallax="0.12"
              />
            </div>
            <div class="gallery-overlay">
              <div class="gallery-overlay-inner">
                <p class="gallery-look-tag">{visuals.galleryLooks[1].title}</p>
                <ul class="gallery-bullets">
                  {visuals.galleryLooks[1].bullets.map((b) => <li>{b}</li>)}
                </ul>
              </div>
            </div>
            <div class="gallery-expand-hint" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
              </svg>
            </div>
          </div>
        )}

        <!-- Secondary image 2 (card index 2) -->
        {cardImages[2] && visuals.galleryLooks[2] && (
          <div
            class="gallery-item gallery-secondary-2 group cursor-pointer"
            data-look-title={visuals.galleryLooks[2].title}
            data-look-src={cardImages[2]}
            data-look-bullets={JSON.stringify(visuals.galleryLooks[2].bullets)}
          >
            <div class="gallery-img-wrap">
              <img
                src={cardImages[2]}
                alt={`${data.name} — ${visuals.galleryLooks[2].title}`}
                class="gallery-img"
                loading="lazy"
                data-parallax="0.05"
              />
            </div>
            <div class="gallery-overlay">
              <div class="gallery-overlay-inner">
                <p class="gallery-look-tag">{visuals.galleryLooks[2].title}</p>
                <ul class="gallery-bullets">
                  {visuals.galleryLooks[2].bullets.map((b) => <li>{b}</li>)}
                </ul>
              </div>
            </div>
            <div class="gallery-expand-hint" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
              </svg>
            </div>
          </div>
        )}

      </div>

      <!-- Bottom blend: gallery images dissolve into the next section background -->
      <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-40"
           style="background: linear-gradient(to top, var(--color-primary, #0a0806) 0%, transparent 100%)"></div>

      <!-- Lightbox -->
      <div
        id="gallery-lightbox"
        class="gallery-lightbox"
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        aria-label="Image lightbox"
      >
        <div class="gallery-lightbox-backdrop"></div>
        <div class="gallery-lightbox-content">
          <!-- Left: image fills available height -->
          <div class="gallery-lightbox-img-panel">
            <img id="lightbox-img" src="" alt="" class="gallery-lightbox-img" />
          </div>
          <!-- Right: title + bullets -->
          <div class="gallery-lightbox-info-panel">
            <button id="lightbox-close" class="gallery-lightbox-close" aria-label="Close lightbox">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18M6 6l12 12"/>
              </svg>
            </button>
            <div class="gallery-lightbox-info">
              <h3 id="lightbox-title" class="gallery-lightbox-title"></h3>
              <ul id="lightbox-bullets" class="gallery-lightbox-bullets"></ul>
            </div>
          </div>
        </div>
      </div>

    </section>
  )}


  <!-- ── DEEP DIVE: Description + visuals ─────────────────── -->
  <section class="py-14 sm:py-20 px-6 bg-primary" aria-label={`About ${data.name}`}>
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-[40fr_60fr] gap-10 sm:gap-14 lg:gap-20">

        <!-- LEFT COLUMN (sticky): Color palette + Signature Pieces + Style Icons -->
        <div class="h-fit lg:sticky lg:top-28 flex flex-col gap-10" style="overflow: visible;">

          {visuals && (
            <>
              <!-- Color palette swatches -->
              <div>
                <p class="font-body text-[11px] tracking-widest uppercase text-accent mb-5">
                  Palette
                </p>
                <div class="flex flex-wrap gap-2.5">
                  {visuals.palette.map((color) => (
                    <div class="group relative">
                      <div
                        class="w-10 h-10 md:w-11 md:h-11 rounded-full border border-white/15
                               cursor-default transition-transform duration-200 hover:scale-110"
                        style={`background-color: ${color.hex};
                                box-shadow: inset 0 2px 4px rgba(26,22,19,0.3),
                                            inset 0 -1px 2px rgba(255,255,255,0.1);`}
                        title={color.name}
                      />
                      <span class="absolute -bottom-7 left-1/2 -translate-x-1/2
                                   font-body text-[10px] text-white/60 whitespace-nowrap
                                   opacity-0 group-hover:opacity-100 transition-opacity duration-200
                                   pointer-events-none">
                        {color.name}
                      </span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Divider -->
              <div class="w-full h-px bg-white/8"></div>

              <!-- Signature Pieces — teaser (2 shown, rest behind the guide) -->
              <div>
                <p class="font-body text-[11px] tracking-widest uppercase text-accent mb-5">
                  Signature Pieces
                </p>
                <div class="grid grid-cols-2 gap-2 mb-3">
                  {visuals.signaturePieces.slice(0, 2).map((piece) => (
                    <div class="flex flex-col items-center text-center p-3.5
                                bg-white/[0.03] backdrop-blur-sm border border-white/[0.07]
                                rounded-sm hover:bg-white/[0.06] transition-all duration-200">
                      <svg
                        class="w-7 h-7 text-accent/70 mb-2"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d={iconPaths[piece.icon]} />
                      </svg>
                      <span class="font-body text-[11px] text-white/65 leading-snug">{piece.name}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Style Guide card — lives here so the teaser is immediately adjacent -->
              {genderGuide && (
                <div class="bg-white/[0.03] backdrop-blur-sm border border-white/[0.07] rounded-sm p-4
                            hover:bg-white/[0.05] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]">
                  <div class="flex gap-4 items-start">
                    <div class="shrink-0 w-14 aspect-[3/4] overflow-hidden rounded-sm border border-white/10">
                      <img
                        src={`/images/guides/${genderGuide.slug}-cover.webp`}
                        alt={genderGuide.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-body text-[10px] tracking-widest uppercase text-accent mb-1">
                        Style Guide
                      </p>
                      <h3 class="font-heading text-white text-base md:text-lg font-semibold leading-snug mb-2">
                        {genderGuide.title}
                      </h3>
                      <a
                        href={genderGuide.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-accent/70 hover:text-accent transition-colors duration-200 group"
                      >
                        <span class="font-body text-[10px] tracking-widest uppercase">Get the full guide</span>
                        <svg class="w-2.5 h-2.5 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              )}

              <!-- Divider -->
              <div class="w-full h-px bg-white/8"></div>

              <!-- Style Icons -->
              {visuals.styleIcons.length > 0 && (
                <div class="relative" style="overflow: visible; z-index: 60;">
                  <p class="font-body text-[11px] tracking-widest uppercase text-accent mb-5">
                    Style Icons
                  </p>
                  <div class="flex flex-wrap gap-6" style="overflow: visible;">
                    {visuals.styleIcons.map((icon) => (
                      <div class="style-icon-group group flex flex-col items-center">
                        <div class="relative w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden
                                    border-2 border-white/15 group-hover:border-accent/50
                                    transition-colors duration-300">
                          <img
                            src={icon.image}
                            alt={icon.name}
                            class="icon-img absolute inset-0 w-full h-full object-cover object-top"
                            loading="lazy"
                          />
                          <div class="icon-fallback absolute inset-0 w-full h-full bg-white/10
                                      flex items-center justify-center
                                      font-heading text-2xl text-white/30">
                            {icon.name[0]}
                          </div>
                        </div>
                        <span class="style-icon-label mt-2 font-body text-[10px] text-white/50 whitespace-nowrap">
                          {icon.name}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </>
          )}
        </div>

        <!-- RIGHT COLUMN: Description text -->
        <div>
          {visuals ? (
            <div class="description-prose">
              {visuals.bodyText.split('\n\n').map((paragraph, i) => (
                i === 0
                  ? <p class="description-lede">{paragraph}</p>
                  : <p class="description-body">{paragraph}</p>
              ))}
            </div>
          ) : (
            <div class="font-body text-white/50 italic">Visual data coming soon.</div>
          )}
        </div>

      </div>
    </div>
  </section>


  <!-- ── YOUR UNIQUE BLEND: Visual comparator ──────────────── -->
  {shades.length > 0 && (
    <section
      id="shades"
      class="py-16 sm:py-24 px-6 bg-primary border-t border-white/8"
      aria-label="Explore archetype blends"
      data-compact-super="Your Unique Blend"
      data-compact-title="Discover Your Blend"
      data-compact-theme="dark"
    >
      <div class="mx-auto max-w-7xl">

        <!-- Section header -->
        <div class="text-center mb-10 sm:mb-14">
          <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">— Your Unique Blend</p>
          <h2 class="font-heading text-white text-3xl md:text-4xl font-semibold mb-4">
            {data.name} <span class="text-white/40">with shades of...</span>
          </h2>
          <p class="font-body text-white/55 text-base max-w-lg mx-auto leading-relaxed">
            Most people are a blend of two archetypes. Select a secondary to explore what your unique combination means.
          </p>
        </div>

        <!-- Two-column comparator layout -->
        <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-start">

          <!-- LEFT: Split-screen blend comparator -->
          <div class="w-full lg:w-1/2">
            <div class="comparator-split-wrap">
              <!-- Left half: primary archetype image (always fixed) -->
              <div class="comparator-half comparator-half-left">
                <img
                  src={primaryCardImage}
                  alt={data.name}
                  class="comparator-half-img"
                  loading="lazy"
                />
              </div>
              <!-- Right half: selected shade image (updated via JS) -->
              <div class="comparator-half comparator-half-right">
                <img
                  id="shade-comparison-img"
                  src={otherArchetypesWithImages[0]?.image ?? ''}
                  alt={otherArchetypes[0]?.data.name ?? ''}
                  class="comparator-half-img"
                  loading="lazy"
                />
              </div>
              <!-- Blend gradient in center -->
              <div class="comparator-blend-overlay" aria-hidden="true"></div>
              <!-- Center divider line -->
              <div class="comparator-divider" aria-hidden="true"></div>
              <!-- Bottom labels -->
              <div class="comparator-labels" aria-hidden="true">
                <div class="comparator-label-left">
                  <span class="font-body text-[10px] tracking-widest uppercase text-white/60">{data.name}</span>
                </div>
                <div class="comparator-label-right">
                  <span id="comparator-shade-label" class="font-body text-[10px] tracking-widest uppercase text-white/60">
                    {otherArchetypes[0]?.data.name ?? ''}
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- RIGHT: Thumbnail selector + description -->
          <div class="w-full lg:w-1/2 flex flex-col gap-6">

            <!-- Shade thumbnail selector -->
            <div>
              <p class="font-body text-[11px] tracking-widest uppercase text-white/35 mb-4">
                Choose your shade
              </p>
              <div
                class="shade-thumb-grid"
                role="radiogroup"
                aria-label="Select secondary archetype"
              >
                {otherArchetypesWithImages.map((item, i) => (
                  <button
                    type="button"
                    class="shade-thumb cursor-pointer overflow-hidden relative group"
                    data-shade-slug={item.archetype.data.slug}
                    data-shade-name={item.archetype.data.name}
                    data-shade-image={item.image}
                    data-shade-color={item.archetype.data.color}
                    role="radio"
                    aria-checked={i === 0 ? 'true' : 'false'}
                    tabindex={i === 0 ? 0 : -1}
                  >
                    <img
                      src={item.image}
                      alt={item.archetype.data.name}
                      class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent pointer-events-none"></div>
                    <div
                      class="shade-thumb-ring absolute inset-0 transition-all duration-300 pointer-events-none"
                      style={i === 0 ? `box-shadow: inset 0 0 0 2px ${item.archetype.data.color}` : 'box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12)'}
                    ></div>
                    <div class="absolute bottom-0 inset-x-0 p-2 text-center pointer-events-none">
                      <span class="font-body text-[10px] tracking-widest uppercase text-white/75 leading-none">
                        {item.archetype.data.name.replace(/^The\s+/i, '')}
                      </span>
                    </div>
                  </button>
                ))}
              </div>
            </div>

            <!-- Shade description -->
            <div class="shade-display bg-white/3 border border-white/10 rounded-sm p-5 sm:p-6 md:p-8 backdrop-blur-sm">
              {shades.map((shade) => (
                <div
                  class:list={[
                    'shade-content transition-opacity duration-300',
                    shade.secondary === defaultShadeSlug ? 'block' : 'hidden',
                  ]}
                  data-shade-for={shade.secondary}
                >
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-4">
                    <span class="text-accent text-lg">{data.icon}</span>
                    <span class="font-heading text-white text-lg sm:text-xl font-semibold">{data.name}</span>
                    <span class="text-white/30 mx-0.5 sm:mx-1">&times;</span>
                    <span class="font-heading text-white/70 text-lg sm:text-xl">{shade.secondaryName}</span>
                  </div>
                  <p class="font-body text-white/70 text-[0.95rem] sm:text-base leading-relaxed italic">
                    {shade.description}
                  </p>
                </div>
              ))}
            </div>

            <!-- ── LTK Blend Collection Widget ──────────────────────────────
                 Pre-rendered per secondary slug so Astro scoped CSS works.
                 JS only toggles .is-active / has-content — no innerHTML.     -->
            {Object.keys(blendMap).length > 0 && (
              <div
                id="shade-ltk-section"
                class:list={[
                  'shade-ltk-section',
                  defaultShadeSlug in blendMap ? 'has-content' : '',
                ]}
                aria-live="polite"
              >
                <p class="shade-ltk-eyebrow">Shop this pairing on LTK</p>
                {Object.entries(blendMap).map(([secondarySlug, cards]) => (
                  <div
                    class:list={[
                      'shade-ltk-group',
                      secondarySlug === defaultShadeSlug ? 'is-active' : '',
                    ]}
                    data-secondary-slug={secondarySlug}
                  >
                    <div class="shade-ltk-carousel">
                      {cards.map((card) => (
                        <a
                          href={card.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="shade-ltk-card"
                          aria-label={`${card.title} — ${card.count} items on LTK`}
                        >
                          <div class="shade-ltk-img-frame">
                            {card.cover && (
                              <img src={card.cover} alt={card.title} loading="lazy" />
                            )}
                          </div>
                          <div class="shade-ltk-info">
                            <span class="shade-ltk-name">{card.title}</span>
                            <span class="shade-ltk-meta">{card.count} items</span>
                            <span class="shade-ltk-cta">Shop on LTK →</span>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )}

          </div>
        </div>

      </div>
    </section>
  )}


  <!-- ── EXPLORE MORE ─────────────────────────────────────── -->
  <section class="py-14 sm:py-20 px-6 bg-primary border-t border-white/8" aria-label="Explore more archetypes" data-compact-super="Keep Exploring" data-compact-title="Discover More Archetypes" data-compact-theme="dark">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 py-10">
        <div>
