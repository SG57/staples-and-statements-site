  /* Auto-pan: simple from/to + ease-in-out + alternate = perfect sine drift.
     No explicit keyframe pauses — those were causing the robotic lurch. */
  @keyframes gallery-pan {
    from { transform: translateY(0%); }
    to   { transform: translateY(-30%); }
  }

  .gallery-img {
    width: 100%;
    height: 160%;         /* extra headroom for pan travel */
