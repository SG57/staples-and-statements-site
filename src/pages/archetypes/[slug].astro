  .gallery-primary     .gallery-img { animation: gallery-pan 34s ease-in-out infinite alternate; }
  .gallery-secondary-1 .gallery-img { animation: gallery-pan 42s ease-in-out infinite alternate; animation-delay: -18s; }
  .gallery-secondary-2 .gallery-img { animation: gallery-pan 28s ease-in-out infinite alternate; animation-delay: -8s; }

