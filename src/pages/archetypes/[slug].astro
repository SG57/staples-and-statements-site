    transition: z-index 0s; /* instant on hover-in */
  }

  /* Only the avatar circle scales — expands upward, label stays clear below */
  .style-icon-group > div:first-child {
    transform-origin: bottom center;
    transition:
      transform  500ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 500ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 1;
  }

  .style-icon-group:hover > div:first-child {
