---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const feminineArchetypes = await getCollection('archetypes', ({ data }) => data.gender === 'feminine');
const feminineSorted = feminineArchetypes.sort((a, b) => a.data.order - b.data.order);

const masculineArchetypes = await getCollection('archetypes', ({ data }) => data.gender === 'masculine');
const masculineSorted = masculineArchetypes.sort((a, b) => a.data.order - b.data.order);

const calendlyURL = '/contact';
---

<BaseLayout
  title="Style Archetypes — Staples & Statements"
  description="Discover your style archetype with Danielle Marie's framework. Seven distinct aesthetic identities — find yours and transform how you dress."
  transparentNav={true}
>

  <!-- ── PAGE WRAPPER — data-active-gender drives CSS visibility ── -->
  <div id="archetypes-page" data-active-gender="feminine">

    <!-- Gender toggle — absolute overlay, sits in the dead zone between nav and hero headline -->
    <div id="hero-gender-toggle" class="absolute top-0 left-0 right-0 z-20 pointer-events-none">
      <div class="mx-auto max-w-7xl px-6 pt-24 lg:pt-28 flex justify-end">
        <div class="inline-flex pointer-events-auto" role="group" aria-label="Select archetype gender">
          <button
            id="toggle-feminine"
            type="button"
            aria-pressed="true"
            class="gender-btn font-body text-xs tracking-widest uppercase px-6 py-2.5
                   transition-all duration-300 text-white bg-white/15 backdrop-blur-sm border border-white/25"
          >
            Feminine
          </button>
          <button
            id="toggle-masculine"
            type="button"
            aria-pressed="false"
            class="gender-btn font-body text-xs tracking-widest uppercase px-6 py-2.5
                   transition-all duration-300 text-white/40 bg-transparent border border-white/15 hover:text-white/70"
          >
            Masculine
          </button>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         FEMININE CONTENT BLOCKS
         ═══════════════════════════════════════════ -->

    <!-- FEMININE HERO -->
    <section
      data-gender="feminine"
      class="gender-block relative min-h-screen flex items-center overflow-hidden bg-primary"
      aria-label="Feminine style archetypes hero"
    >
      <img
        src="/images/archetypes/ensemble-feminine-hero.webp"
        alt="The 7 Feminine Style Archetypes"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        width="1376"
        height="768"
      />
      <!-- Gradients: heavy bottom for grounding, right-side for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/55 to-primary/15 pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-primary/65 via-primary/20 to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-6 pt-36 lg:pt-44 pb-20">
        <p class="font-body text-xs tracking-widest uppercase text-accent mb-4">The Framework</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-8xl font-semibold leading-tight max-w-2xl">
          Find Your<br /><em class="not-italic text-accent">Style Archetype</em>
        </h1>
        <p class="mt-6 font-body text-white/70 text-lg max-w-xl leading-relaxed">
          Seven distinct aesthetic identities. One is yours. Understanding it changes how you shop, how you dress, and how you feel every single morning.
        </p>
        <div class="mt-10">
          <a
            href="#archetypes"
            class="inline-flex items-center justify-center px-10 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Explore the Archetypes ↓
          </a>
        </div>
      </div>
    </section>

    <!-- FEMININE ARCHETYPE GRID — full-bleed portrait image cards -->
    <section
      id="archetypes"
      data-gender="feminine"
      class="gender-block relative py-28 px-6 overflow-hidden bg-primary"
      aria-label="The 7 feminine archetypes"
    >
      <!-- Cards background image -->
      <img
        src="/images/archetypes/ensemble-feminine-cards.webp"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="lazy"
        width="1376"
        height="768"
      />
      <!-- Dark overlay — heavy enough for card legibility, light enough to feel the image -->
      <div class="absolute inset-0 bg-gradient-to-b from-primary/72 via-primary/78 to-primary/88 pointer-events-none"></div>
      <!--
        Seam blends — dissolve the hard edges where sections meet.
        Top: fades from solid primary into transparency, bridging the hero's solid-dark
             bottom into this section's image. Covers the padding zone (py-28 = 112px)
             so no image shows through at the join line.
        Bottom: fades from transparency back to solid primary, merging cleanly into
                the dark section below. No hard cut-off.
        z-index: auto (above background image via DOM order, below z-10 content).
      -->
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-primary to-transparent pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-primary to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl">
        <div class="text-center mb-14">
          <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">The Seven Types</p>
          <h2 class="font-heading text-white text-4xl lg:text-5xl">The Feminine Archetypes</h2>
          <p class="mt-4 font-body text-white/60 text-base max-w-xl mx-auto leading-relaxed">
            Every woman is a blend — but most have one dominant archetype. Which one resonates with you?
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {feminineSorted.map((archetype) => (
            <div
              class="archetype-card group relative overflow-hidden cursor-pointer aspect-[3/4]"
              data-slug={archetype.data.slug}
              data-images={JSON.stringify([
                `/images/archetypes/${archetype.data.slug}-1.webp`,
                `/images/archetypes/${archetype.data.slug}-2.webp`,
                `/images/archetypes/${archetype.data.slug}-3.webp`,
              ])}
            >
              <!-- Image layer A (starts visible) -->
              <img
                data-layer="a"
                src={`/images/archetypes/${archetype.data.slug}-1.webp`}
                alt={archetype.data.name}
                class="absolute inset-0 w-full h-full object-cover object-top"
                style="transition: opacity 1000ms ease-in-out; opacity: 1"
                loading="lazy"
              />
              <!-- Image layer B (starts invisible, transitions in) -->
              <img
                data-layer="b"
                src=""
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover object-top"
                style="transition: opacity 1000ms ease-in-out; opacity: 0"
                loading="lazy"
              />

              <!-- Gradient overlay: always-on dark bottom for text legibility -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-transparent pointer-events-none"></div>

              <!-- Archetype color accent line at top of card -->
              <div
                class="absolute top-0 left-0 right-0 h-0.5"
                style={`background-color: ${archetype.data.color ?? '#b8977e'}`}
              ></div>

              <!-- Always-visible bottom label -->
              <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-lg text-accent/70">{archetype.data.icon ?? '✦'}</span>
                  <h3 class="font-heading text-white text-xl font-semibold leading-tight">
                    {archetype.data.name}
                  </h3>
                </div>
              </div>

              <!-- Hover reveal panel: slides up from bottom on hover -->
              <div class="archetype-reveal absolute inset-x-0 bottom-0 p-5 z-20
                          bg-gradient-to-t from-black/95 via-black/85 to-transparent
                          translate-y-full group-hover:translate-y-0
                          transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-lg text-accent/80">{archetype.data.icon ?? '✦'}</span>
                  <h3 class="font-heading text-white text-xl font-semibold">{archetype.data.name}</h3>
                </div>
                <p class="font-body text-sm text-white/70 leading-relaxed mb-4">
                  {archetype.data.description}
                </p>
                <div class="flex flex-col gap-2">
                  {archetype.data.guideLink && (
                    <a href={archetype.data.guideLink} target="_blank" rel="noopener noreferrer"
                       class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors">
                      Get the Style Guide →
                    </a>
                  )}
                  {archetype.data.ltkLink && (
                    <a href={archetype.data.ltkLink} target="_blank" rel="noopener noreferrer"
                       class="font-body text-xs tracking-widest uppercase text-white/40 hover:text-accent transition-colors">
                      Shop This Look →
                    </a>
                  )}
                </div>
              </div>

            </div>
          ))}

          <!-- "Still Not Sure?" card — accent-tinted, portrait aspect to match archetype cards -->
          <div class="relative overflow-hidden bg-accent/12 backdrop-blur-sm border border-accent/25 aspect-[3/4]
                      flex flex-col justify-end p-5 hover:bg-accent/18 transition-all duration-300">
            <div class="w-8 h-0.5 bg-accent mb-4"></div>
            <h3 class="font-heading text-xl font-semibold text-white mb-3">Still Not Sure?</h3>
            <p class="font-body text-sm text-white/60 leading-relaxed mb-4">
              Most women are a blend of two or three archetypes. Work through the quiz reel to find your dominant type — then bring that clarity to a consultation and Danielle builds your wardrobe strategy from minute one.
            </p>
            <a
              href={calendlyURL}
              class="inline-flex items-center justify-center px-6 py-3 border border-accent text-accent font-body text-xs font-medium tracking-widest uppercase hover:bg-accent hover:text-white transition-colors duration-200"
            >
              Book a Consultation
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         MASCULINE CONTENT BLOCKS
         ═══════════════════════════════════════════ -->

    <!-- MASCULINE HERO -->
    <section
      data-gender="masculine"
      class="gender-block relative min-h-screen flex items-center overflow-hidden bg-primary"
      aria-label="Masculine style archetypes hero"
    >
      <!-- Placeholder until masculine ensemble image is AI-generated -->
      <img
        src="/images/archetypes/ensemble-masculine-hero.webp"
        alt="The Masculine Style Archetypes"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/55 to-primary/15 pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-primary/65 via-primary/20 to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-6 pt-36 lg:pt-44 pb-20">
        <p class="font-body text-xs tracking-widest uppercase text-accent mb-4">The Framework</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-8xl font-semibold leading-tight max-w-2xl">
          Find Your<br /><em class="not-italic text-accent">Style Archetype</em>
        </h1>
        <p class="mt-6 font-body text-white/70 text-lg max-w-xl leading-relaxed">
          Distinct aesthetic identities for the modern man. Understanding yours changes how you dress, how you present, and how the world reads you.
        </p>
        <div class="mt-10">
          <a
            href="#masculine-archetypes"
            class="inline-flex items-center justify-center px-10 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Explore the Archetypes ↓
          </a>
        </div>
      </div>
    </section>

    <!-- MASCULINE ARCHETYPE GRID — full-bleed portrait image cards -->
    <section
      id="masculine-archetypes"
      data-gender="masculine"
      class="gender-block relative py-28 px-6 overflow-hidden bg-primary"
      aria-label="The masculine archetypes"
    >
      <img
        src="/images/archetypes/ensemble-masculine-cards.webp"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="lazy"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/72 via-primary/78 to-primary/88 pointer-events-none"></div>
      <!-- Seam blends — same treatment as feminine cards section -->
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-primary to-transparent pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-primary to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl">
        <div class="text-center mb-14">
          <div class="w-8 h-px bg-accent mx-auto mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">The Archetypes</p>
          <h2 class="font-heading text-white text-4xl lg:text-5xl">The Masculine Archetypes</h2>
          <p class="mt-4 font-body text-white/60 text-base max-w-xl mx-auto leading-relaxed">
            Every man's style is rooted in an archetype. Find the one that captures how you move through the world.
          </p>
        </div>

        {masculineSorted.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {masculineSorted.map((archetype) => (
              <div
                class="archetype-card group relative overflow-hidden cursor-pointer aspect-[3/4]"
                data-slug={archetype.data.slug}
                data-images={JSON.stringify([
                  `/images/archetypes/${archetype.data.slug}-1.webp`,
                  `/images/archetypes/${archetype.data.slug}-2.webp`,
                  `/images/archetypes/${archetype.data.slug}-3.webp`,
                ])}
              >
                <!-- Image layer A (starts visible) -->
                <img
                  data-layer="a"
                  src={`/images/archetypes/${archetype.data.slug}-1.webp`}
                  alt={archetype.data.name}
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  style="transition: opacity 1000ms ease-in-out; opacity: 1"
                  loading="lazy"
                />
                <!-- Image layer B (starts invisible, transitions in) -->
                <img
                  data-layer="b"
                  src=""
                  alt=""
                  aria-hidden="true"
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  style="transition: opacity 1000ms ease-in-out; opacity: 0"
                  loading="lazy"
                />

                <!-- Gradient overlay: always-on dark bottom for text legibility -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-transparent pointer-events-none"></div>

                <!-- Archetype color accent line at top of card -->
                <div
                  class="absolute top-0 left-0 right-0 h-0.5"
                  style={`background-color: ${archetype.data.color ?? '#b8977e'}`}
                ></div>

                <!-- Always-visible bottom label -->
                <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-lg text-accent/70">{archetype.data.icon ?? '▲'}</span>
                    <h3 class="font-heading text-white text-xl font-semibold leading-tight">
                      {archetype.data.name}
                    </h3>
                  </div>
                </div>

                <!-- Hover reveal panel: slides up from bottom on hover -->
                <div class="archetype-reveal absolute inset-x-0 bottom-0 p-5 z-20
                            bg-gradient-to-t from-black/95 via-black/85 to-transparent
                            translate-y-full group-hover:translate-y-0
                            transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-lg text-accent/80">{archetype.data.icon ?? '▲'}</span>
                    <h3 class="font-heading text-white text-xl font-semibold">{archetype.data.name}</h3>
                  </div>
                  <p class="font-body text-sm text-white/70 leading-relaxed mb-4">
                    {archetype.data.description}
                  </p>
                  <div class="flex flex-col gap-2">
                    {archetype.data.guideLink && (
                      <a href={archetype.data.guideLink} target="_blank" rel="noopener noreferrer"
                         class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors">
                        Get the Style Guide →
                      </a>
                    )}
                    {archetype.data.ltkLink && (
                      <a href={archetype.data.ltkLink} target="_blank" rel="noopener noreferrer"
                         class="font-body text-xs tracking-widest uppercase text-white/40 hover:text-accent transition-colors">
                        Shop This Look →
                      </a>
                    )}
                  </div>
                </div>

              </div>
            ))}

            <!-- "Still Not Sure?" card — accent-tinted, portrait aspect to match archetype cards -->
            <div class="relative overflow-hidden bg-accent/12 backdrop-blur-sm border border-accent/25 aspect-[3/4]
                        flex flex-col justify-end p-5 hover:bg-accent/18 transition-all duration-300">
              <div class="w-8 h-0.5 bg-accent mb-4"></div>
              <h3 class="font-heading text-xl font-semibold text-white mb-3">Still Not Sure?</h3>
              <p class="font-body text-sm text-white/60 leading-relaxed mb-4">
                Most men lean into one dominant archetype. Watch the quiz reel, then bring that clarity to a consultation — Danielle will build your wardrobe strategy from minute one.
              </p>
              <a
                href={calendlyURL}
                class="inline-flex items-center justify-center px-6 py-3 border border-accent text-accent font-body text-xs font-medium tracking-widest uppercase hover:bg-accent hover:text-white transition-colors duration-200"
              >
                Book a Consultation
              </a>
            </div>
          </div>
        ) : (
          <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-8 h-0.5 bg-accent mx-auto mb-8"></div>
            <h3 class="font-heading text-white text-3xl font-semibold mb-4">Coming Soon</h3>
            <p class="font-body text-white/55 text-base max-w-md leading-relaxed mb-10">
              The masculine archetype framework is being developed. Check back soon — or book a consultation and Danielle will walk you through it personally.
            </p>
            <a
              href={calendlyURL}
              class="inline-flex items-center justify-center px-10 py-4 border border-accent text-accent font-body text-sm font-medium tracking-widest uppercase hover:bg-accent hover:text-white transition-colors duration-200"
            >
              Book a Consultation
            </a>
          </div>
        )}
      </div>
    </section>


  </div><!-- /archetypes-page -->

  <!-- ── STYLE GUIDES CTA ──────────────────────────────── -->
  <section class="py-20 px-6 bg-primary" aria-label="Style guides">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 py-10 border-t border-b border-white/10">
        <div>
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-2">Digital Guides</p>
          <h2 class="font-heading text-white text-3xl font-semibold">Take Your Archetype Home</h2>
          <p class="mt-2 font-body text-white/55 text-base max-w-md leading-relaxed">
            In-depth style guides for your archetype — from $15. Instant download.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a
            href="/shop"
            class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Shop Style Guides
          </a>
          <a
            href={calendlyURL}
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200"
          >
            Book Personalized Styling
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /*
   * Gender toggle visibility system
   * Default: feminine shown, masculine hidden.
   * JS sets data-active-gender on #archetypes-page.
   *
   * Inactive blocks are moved off-screen with position:absolute + left:-9999px
   * so they take up no space in the layout. Active blocks are position:static.
   * Opacity + transform transitions are applied via the Web Animations API in JS
   * to allow async await on their completion (display/position can't be transitioned).
   */

  /* Active blocks: normal flow */
  #archetypes-page[data-active-gender="feminine"] .gender-block[data-gender="feminine"],
  #archetypes-page[data-active-gender="masculine"] .gender-block[data-gender="masculine"] {
    position: static;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    height: auto;
    overflow: visible;
  }

  /* Inactive blocks: out of layout, invisible, not interactive */
  #archetypes-page[data-active-gender="feminine"] .gender-block[data-gender="masculine"],
  #archetypes-page[data-active-gender="masculine"] .gender-block[data-gender="feminine"] {
    position: absolute;
    left: -9999px;
    top: 0;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  /* Ensure the wrapper can contain the absolutely-positioned off-screen blocks */
  #archetypes-page {
    position: relative;
  }

  /*
   * Archetype card: the reveal panel slides UP from the bottom on hover.
   * The bottom label (z-10) sits BELOW the reveal panel (z-20) in stacking order,
   * so the panel slides over it cleanly without needing to hide the label.
   *
   * overflow-hidden on the card clips the panel when it is fully translated down.
   */
  .archetype-card .archetype-reveal {
    /* Ensure the panel background extends past the card bottom edge during transition */
    padding-bottom: max(1.25rem, env(safe-area-inset-bottom));
  }
</style>

<script>
  // ── Gender Toggle ────────────────────────────────────────────
  // Reads/writes localStorage for persistence across page visits.
  // Animates out the old gender set, swaps data-active-gender,
  // then animates in the new gender set.
  // All durations derived from --dur so the global knob controls everything.

  const STORAGE_KEY = 'archetypes-gender';
  const DEFAULT_GENDER = 'feminine';

  const page   = document.getElementById('archetypes-page') as HTMLElement | null;
  const btnFem = document.getElementById('toggle-feminine')  as HTMLButtonElement | null;
  const btnMas = document.getElementById('toggle-masculine') as HTMLButtonElement | null;

  if (!page || !btnFem || !btnMas) throw new Error('Archetypes toggle: required elements not found');

  function getDur(mult = 1): number {
    const raw = getComputedStyle(document.documentElement).getPropertyValue('--dur').trim();
    return parseFloat(raw) * (raw.endsWith('ms') ? 1 : 1000) * mult;
  }

  const EASE_OUT = 'cubic-bezier(0.16, 1, 0.3, 1)';
  const EASE_IN  = 'cubic-bezier(0.5, 0, 0.85, 0)';

  let switching = false;

  function getBlocks(gender: string): HTMLElement[] {
    return Array.from(
      page!.querySelectorAll<HTMLElement>(`.gender-block[data-gender="${gender}"]`)
    );
  }

  function setButtonState(btn: HTMLButtonElement, active: boolean) {
    btn.setAttribute('aria-pressed', String(active));
    if (active) {
      btn.classList.add('bg-white/15', 'backdrop-blur-sm', 'border-white/25', 'text-white');
      btn.classList.remove('bg-transparent', 'border-white/15', 'text-white/40', 'hover:text-white/70');
    } else {
      btn.classList.remove('bg-white/15', 'backdrop-blur-sm', 'border-white/25', 'text-white');
      btn.classList.add('bg-transparent', 'border-white/15', 'text-white/40', 'hover:text-white/70');
    }
  }

  async function switchGender(targetGender: string) {
    if (switching) return;
    const current = page!.getAttribute('data-active-gender') ?? DEFAULT_GENDER;
    if (current === targetGender) return;
    switching = true;

    // Update button states immediately (feels responsive)
    setButtonState(targetGender === 'feminine' ? btnFem! : btnMas!, true);
    setButtonState(targetGender === 'feminine' ? btnMas! : btnFem!, false);

    // Animate OUT the currently-active blocks (they are in static flow right now)
    const outBlocks = getBlocks(current);
    await Promise.all(
      outBlocks.map(el =>
        el.animate(
          [
            { opacity: 1, transform: 'translateY(0)'    },
            { opacity: 0, transform: 'translateY(12px)' },
          ],
          { duration: getDur(0.5), easing: EASE_IN, fill: 'forwards' }
        ).finished
      )
    );
    // Cancel fill-forwards — CSS will immediately take over and clip them off-screen
    outBlocks.forEach(el => el.getAnimations().forEach(a => a.cancel()));

    // Swap the data attribute — CSS moves inactive blocks off-screen, active into flow
    page!.setAttribute('data-active-gender', targetGender);

    // Lazy-load masculine video on first reveal
    if (targetGender === 'masculine') {
      const vid = document.getElementById('video-masculine') as HTMLVideoElement | null;
      if (vid && vid.readyState === 0) vid.load();
    }

    // Scroll to the top of the page so the hero + toggle are visible after switching
    if (window.scrollY > window.innerHeight * 0.5) {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Animate IN the incoming blocks with a light stagger (magazine reveal feel)
    const inBlocks = getBlocks(targetGender);
    await Promise.all(
      inBlocks.map((el, i) =>
        el.animate(
          [
            { opacity: 0, transform: 'translateY(18px)' },
            { opacity: 1, transform: 'translateY(0)'    },
          ],
          {
            duration: getDur(1.25),
            easing: EASE_OUT,
            fill: 'forwards',
            delay: i * getDur(0.06),
          }
        ).finished
      )
    );
    inBlocks.forEach(el => el.getAnimations().forEach(a => a.cancel()));

    // Persist preference
    try { localStorage.setItem(STORAGE_KEY, targetGender); } catch {}

    switching = false;
  }

  // ── Restore saved preference on load ──────────────────────
  // Applied synchronously before first paint to avoid a flash of wrong gender.
  function restorePreference() {
    let saved: string | null = null;
    try { saved = localStorage.getItem(STORAGE_KEY); } catch {}
    const gender = (saved === 'masculine' || saved === 'feminine') ? saved : DEFAULT_GENDER;

    // Set attribute directly — no animation needed for initial load
    page!.setAttribute('data-active-gender', gender);

    if (gender === 'masculine') {
      setButtonState(btnMas!, true);
      setButtonState(btnFem!, false);
    }
    // Feminine is the HTML default — no changes needed if gender === 'feminine'
  }

  restorePreference();

  btnFem!.addEventListener('click', () => switchGender('feminine'));
  btnMas!.addEventListener('click', () => switchGender('masculine'));
</script>

<script>
  // ── Per-card image carousel with global deduplication ────────
  // Each archetype card cycles through 3 images (slug-1.webp, slug-2.webp, slug-3.webp).
  // A shared registry ensures no two cards show the same image simultaneously.
  // Two stacked <img> layers (data-layer="a" / "b") crossfade with opacity transitions.
  // Respects prefers-reduced-motion.

  (function initArchetypeCarousel() {
    const HOLD_MS = 8_000;  // 8 seconds per image
    const FADE_MS = 1_000;  // 1 second fade (matches inline transition on <img>)

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Global active-images registry — Maps imagePath -> count of cards currently showing it
    const activeImages = new Map<string, number>();

    function register(src: string) {
      if (!src) return;
      activeImages.set(src, (activeImages.get(src) ?? 0) + 1);
    }
    function unregister(src: string) {
      if (!src) return;
      const count = (activeImages.get(src) ?? 1) - 1;
      if (count <= 0) activeImages.delete(src);
      else activeImages.set(src, count);
    }
    function isActive(src: string) {
      return (activeImages.get(src) ?? 0) > 0;
    }

    function pickUnique(pool: string[], currentSrc: string): string {
      // Prefer images not shown on ANY card right now, excluding the card's own current image
      const available = pool.filter(s => !isActive(s) || s === currentSrc);
      if (available.length === 0) {
        // Fallback: just avoid the card's own current image
        const fallback = pool.filter(s => s !== currentSrc);
        return fallback.length > 0 ? fallback[Math.floor(Math.random() * fallback.length)] : pool[0];
      }
      const choices = available.filter(s => s !== currentSrc);
      if (choices.length === 0) return available[0];
      return choices[Math.floor(Math.random() * choices.length)];
    }

    function startCard(card: HTMLElement, startDelay: number) {
      const images: string[] = JSON.parse(card.dataset.images ?? '[]');
      if (images.length < 2) return;

      const layerA = card.querySelector<HTMLImageElement>('[data-layer="a"]');
      const layerB = card.querySelector<HTMLImageElement>('[data-layer="b"]');
      if (!layerA || !layerB) return;

      let frontIsA    = true;
      let timer: ReturnType<typeof setTimeout> | null = null;
      let transitioning = false;  // true while a fade is in progress — blocks re-entry

      // Register starting image
      const initialSrc = layerA.getAttribute('src') ?? '';
      register(initialSrc);

      function nextImage() {
        if (transitioning) return;
        transitioning = true;
        if (timer) { clearTimeout(timer); timer = null; }

        const front = frontIsA ? layerA! : layerB!;
        const back  = frontIsA ? layerB! : layerA!;
        const currentSrc = front.getAttribute('src') ?? '';

        const nextSrc = pickUnique(images, currentSrc);

        // Reserve immediately to prevent other cards from picking the same image
        register(nextSrc);
        back.src = nextSrc;

        const doFade = () => {
          back.style.opacity  = '1';
          front.style.opacity = '0';
          unregister(currentSrc);
          frontIsA = !frontIsA;
          // Release the transitioning lock after the CSS fade completes
          setTimeout(() => { transitioning = false; }, FADE_MS);
          timer = setTimeout(nextImage, HOLD_MS);
        };

        if (back.complete && back.naturalWidth > 0) {
          doFade();
        } else {
          back.onload  = doFade;
          back.onerror = () => {
            unregister(nextSrc); // failed to load — release reservation
            transitioning = false;
            timer = setTimeout(nextImage, HOLD_MS);
          };
        }
      }

      // Expose an advance function on the card element so click handlers can trigger it
      (card as any)._advanceCarousel = () => { if (!transitioning) nextImage(); };

      timer = setTimeout(nextImage, startDelay + HOLD_MS);
    }

    function initVisible() {
      const activePage = document.getElementById('archetypes-page') as HTMLElement | null;
      if (!activePage) return;
      const activeGender = activePage.getAttribute('data-active-gender') ?? 'feminine';

      let cardIndex = 0;
      document.querySelectorAll<HTMLElement>('.archetype-card').forEach((card) => {
        // Only cycle cards in the currently visible gender block
        const genderBlock = card.closest<HTMLElement>('[data-gender]');
        if (genderBlock && genderBlock.dataset.gender !== activeGender) return;
        startCard(card, cardIndex * 600); // 600ms stagger between cards
        cardIndex++;

        // Click anywhere on the card body (not on links/buttons) advances to next image.
        // This lets curious users explore all 3 images without waiting for auto-cycle.
        if (!(card as any)._clickBound) {
          (card as any)._clickBound = true;
          card.addEventListener('click', (e) => {
            if ((e.target as Element).closest('a, button')) return; // let links work normally
            const advance = (card as any)._advanceCarousel;
            if (advance) advance();
          });
        }
      });
    }

    requestAnimationFrame(initVisible);

    // Re-init carousels when gender switches (MutationObserver on data-active-gender)
    const pageEl = document.getElementById('archetypes-page');
    if (pageEl) {
      const observer = new MutationObserver(() => {
        // Reset registry and re-register all layer-A starting images
        activeImages.clear();
        document.querySelectorAll<HTMLImageElement>('.archetype-card [data-layer="a"]').forEach(img => {
          const src = img.getAttribute('src');
          if (src) register(src);
        });
        initVisible();
      });
      observer.observe(pageEl, { attributes: true, attributeFilter: ['data-active-gender'] });
    }
  })();
</script>
