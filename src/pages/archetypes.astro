---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchetypeQuiz from '../components/ArchetypeQuiz.astro';
import { getCollection } from 'astro:content';
import { getCardImages } from '../data/archetype-images';

const feminineArchetypes = await getCollection('archetypes', ({ data }) => data.gender === 'feminine');
const feminineSorted = feminineArchetypes.sort((a, b) => a.data.order - b.data.order);

const masculineArchetypes = await getCollection('archetypes', ({ data }) => data.gender === 'masculine');
const masculineSorted = masculineArchetypes.sort((a, b) => a.data.order - b.data.order);

const calendlyURL = '/contact';
---

<BaseLayout
  title="Style Archetypes — Staples & Statements"
  description="Discover your style archetype with Danielle Marie's framework. Seven distinct aesthetic identities — find yours and transform how you dress."
  transparentNav={true}
>

  <!-- ── PAGE WRAPPER — data-active-gender drives CSS visibility ── -->
  <div id="archetypes-page" data-active-gender="feminine">

    <!-- Gender toggle — absolute overlay, sits in the dead zone between nav and hero headline -->
    <div id="hero-gender-toggle" class="absolute top-0 left-0 right-0 z-20 pointer-events-none">
      <div class="mx-auto max-w-7xl px-6 pt-24 lg:pt-28 flex justify-end">
        <div class="inline-flex pointer-events-auto" role="group" aria-label="Select archetype gender">
          <button
            id="toggle-feminine"
            type="button"
            aria-pressed="true"
            class="gender-btn font-body text-xs tracking-widest uppercase px-6 py-2.5
                   transition-all duration-300 text-white bg-white/15 backdrop-blur-sm border border-white/25"
          >
            Feminine
          </button>
          <button
            id="toggle-masculine"
            type="button"
            aria-pressed="false"
            class="gender-btn font-body text-xs tracking-widest uppercase px-6 py-2.5
                   transition-all duration-300 text-white/40 bg-transparent border border-white/15 hover:text-white/70"
          >
            Masculine
          </button>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         FEMININE CONTENT BLOCKS
         ═══════════════════════════════════════════ -->

    <!-- FEMININE HERO -->
    <section
      data-gender="feminine"
      class="gender-block relative min-h-screen flex items-center overflow-hidden bg-primary"
      aria-label="Feminine style archetypes hero"
    >
      <img
        src="/images/archetypes/ensemble-feminine-hero.webp"
        alt="The 7 Feminine Style Archetypes"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        width="1376"
        height="768"
      />
      <!-- Gradients: heavy bottom for grounding, right-side for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/55 to-primary/15 pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-primary/65 via-primary/20 to-transparent pointer-events-none"></div>
      <!-- Nav-hood scrim -->
      <div class="absolute top-0 left-0 right-0 h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 55%, transparent 100%)"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-6 pt-36 lg:pt-44 pb-20">
        <div class="hero-cin-item w-8 h-px bg-accent mb-4" style="--item-delay: 0"></div>
        <p class="hero-cin-item font-body text-xs tracking-widest uppercase text-accent mb-4" style="--item-delay: 0">The Framework</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-8xl font-semibold leading-tight max-w-2xl">
          <span class="hero-cin-line block" style="--line-delay: 0">Find Your</span>
          <em class="hero-cin-line not-italic text-accent block" style="--line-delay: 1">Style Archetype</em>
        </h1>
        <p class="hero-cin-item mt-6 font-body text-white/70 text-lg max-w-xl leading-relaxed" style="--item-delay: 7">
          Seven distinct aesthetic identities. One is yours. Understanding it changes how you shop, how you dress, and how you feel every single morning.
        </p>
        <div class="hero-cin-item mt-10" style="--item-delay: 10">
          <a
            href="#archetypes"
            class="inline-flex items-center justify-center px-10 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Explore the Archetypes ↓
          </a>
        </div>
      </div>
    </section>

    <!-- FEMININE ARCHETYPE GRID — full-bleed portrait image cards -->
    <section
      id="archetypes"
      data-gender="feminine"
      class="gender-block relative py-28 px-6 overflow-hidden bg-primary"
      aria-label="The 7 feminine archetypes"
      data-compact-super="The Seven Types"
      data-compact-title="The Feminine Archetypes"
      data-compact-tagline="Every woman is a blend — but most have one dominant archetype."
      data-compact-theme="dark"
    >
      <!-- Cards background image -->
      <img
        src="/images/archetypes/ensemble-feminine-cards.webp"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="lazy"
        width="1376"
        height="768"
      />
      <!-- Dark overlay — heavy enough for card legibility, light enough to feel the image -->
      <div class="absolute inset-0 bg-gradient-to-b from-primary/72 via-primary/78 to-primary/88 pointer-events-none"></div>
      <!--
        Seam blends — dissolve the hard edges where sections meet.
        Top: fades from solid primary into transparency, bridging the hero's solid-dark
             bottom into this section's image. Covers the padding zone (py-28 = 112px)
             so no image shows through at the join line.
        Bottom: fades from transparency back to solid primary, merging cleanly into
                the dark section below. No hard cut-off.
        z-index: auto (above background image via DOM order, below z-10 content).
      -->
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-primary to-transparent pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-primary to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl">
        <!-- FULL header (normal flow — the "large and in charge" version) -->
        <div class="section-header-full mb-10 transition-opacity duration-500" data-section-full="feminine">
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">The Seven Types</p>
          <h2 class="font-heading text-white text-4xl lg:text-5xl">The Feminine Archetypes</h2>
          <p class="mt-4 font-body text-white/60 text-base max-w-xl leading-relaxed">
            Every woman is a blend — but most have one dominant archetype. Which one resonates with you?
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {feminineSorted.map((archetype) => (
            <div
              class="archetype-card group relative overflow-hidden cursor-pointer aspect-[3/4] max-h-[374px]"
              data-slug={archetype.data.slug}
              data-images={JSON.stringify(getCardImages(archetype.data.slug))}
            >
              <!-- Image layer A (starts visible) -->
              <img
                data-layer="a"
                src={`/images/archetypes/${archetype.data.slug}-1.webp`}
                alt={archetype.data.name}
                class="absolute inset-0 w-full h-full object-cover object-top"
                style="transition: opacity 1000ms ease-in-out; opacity: 1"
                loading="lazy"
              />
              <!-- Image layer B (starts invisible, transitions in) -->
              <img
                data-layer="b"
                src=""
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover object-top"
                style="transition: opacity 1000ms ease-in-out; opacity: 0"
                loading="lazy"
              />

              <!-- Gradient overlay: always-on dark bottom for text legibility -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-transparent pointer-events-none"></div>

              <!-- Archetype color accent line at top of card -->
              <div
                class="absolute top-0 left-0 right-0 h-0.5"
                style={`background-color: ${archetype.data.color ?? '#b8977e'}`}
              ></div>

              <!-- God ray bloom on hover -->
              <div class="archetype-hover-ray absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-[5]"></div>

              <!-- Always-visible bottom label -->
              <div class="archetype-bottom-label absolute bottom-0 left-0 right-0 p-5 z-10">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-lg text-accent/70">{archetype.data.icon ?? '✦'}</span>
                  <h3 class="font-heading text-white text-xl font-semibold leading-tight">
                    {archetype.data.name}
                  </h3>
                </div>
              </div>

              <!-- Hover reveal panel: slides up from bottom on hover -->
              <!-- Outer div = gradient only (full card width, no counter-scale) -->
              <!-- Inner div = text content (counter-scaled to original pixel size) -->
              <div class="archetype-reveal absolute inset-x-0 bottom-0 z-20
                          bg-gradient-to-t from-black/50 via-black/40 to-transparent">
                <div class="archetype-reveal-content p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-lg text-accent/80">{archetype.data.icon ?? '✦'}</span>
                    <h3 class="font-heading text-white text-xl font-semibold">{archetype.data.name}</h3>
                  </div>
                  <p class="font-body text-sm text-white/70 leading-relaxed mb-4">
                    {archetype.data.description}
                  </p>
                  <div class="flex flex-col gap-2">
                    <a href={`/archetypes/${archetype.data.slug}`}
                       class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors">
                      Deep Dive →
                    </a>
                    {archetype.data.guideLink && (
                      <a href={archetype.data.guideLink} target="_blank" rel="noopener noreferrer"
                         class="font-body text-xs tracking-widest uppercase text-white/60 hover:text-accent transition-colors">
                        Get the Style Guide →
                      </a>
                    )}
                    {archetype.data.ltkLink && (
                      <a href={archetype.data.ltkLink} target="_blank" rel="noopener noreferrer"
                         class="font-body text-xs tracking-widest uppercase text-white/60 hover:text-accent transition-colors">
                        Shop This Look →
                      </a>
                    )}
                  </div>
                </div>
              </div>

            </div>
          ))}

          <!-- "Find Your Archetype" quiz CTA card -->
          <div class="quiz-cta-card relative overflow-hidden bg-accent/12 backdrop-blur-sm border border-accent/25 aspect-[3/4] max-h-[374px]
                      flex flex-col justify-end p-5 hover:bg-accent/18 transition-all duration-300 cursor-pointer"
               data-quiz-trigger="fem">
            <div class="w-8 h-0.5 bg-accent mb-4"></div>
            <h3 class="font-heading text-xl font-semibold text-white mb-3">Not sure which one is you?</h3>
            <p class="font-body text-sm text-white/60 leading-relaxed mb-4">
              Find your archetype in under 2 minutes.
            </p>
            <button
              type="button"
              class="quiz-cta-btn inline-flex items-center justify-center px-6 py-3 bg-accent text-white font-body text-xs font-medium tracking-widest uppercase whitespace-nowrap hover:bg-accent-light transition-colors duration-200
                     focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
              data-quiz-trigger="fem"
            >
              Find Your Archetype &rarr;
            </button>
          </div>
        </div>

        <!-- Quiz container (hidden until CTA clicked) -->
        <div id="fem-quiz-container" class="hidden mt-10">
          <ArchetypeQuiz gender="feminine" quizId="fem" />
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         MASCULINE CONTENT BLOCKS
         ═══════════════════════════════════════════ -->

    <!-- MASCULINE HERO -->
    <section
      data-gender="masculine"
      class="gender-block relative min-h-screen flex items-center overflow-hidden bg-primary"
      aria-label="Masculine style archetypes hero"
    >
      <!-- Placeholder until masculine ensemble image is AI-generated -->
      <img
        src="/images/archetypes/ensemble-masculine-hero.webp"
        alt="The Masculine Style Archetypes"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/55 to-primary/15 pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-primary/65 via-primary/20 to-transparent pointer-events-none"></div>
      <!-- Nav-hood scrim -->
      <div class="absolute top-0 left-0 right-0 h-40 pointer-events-none z-[5]"
           style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 55%, transparent 100%)"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-6 pt-36 lg:pt-44 pb-20">
        <div class="hero-cin-item w-8 h-px bg-accent mb-4" style="--item-delay: 0"></div>
        <p class="hero-cin-item font-body text-xs tracking-widest uppercase text-accent mb-4" style="--item-delay: 0">The Framework</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl lg:text-8xl font-semibold leading-tight max-w-2xl">
          <span class="hero-cin-line block" style="--line-delay: 0">Find Your</span>
          <em class="hero-cin-line not-italic text-accent block" style="--line-delay: 1">Style Archetype</em>
        </h1>
        <p class="hero-cin-item mt-6 font-body text-white/70 text-lg max-w-xl leading-relaxed" style="--item-delay: 7">
          Distinct aesthetic identities for the modern man. Understanding yours changes how you dress, how you present, and how the world reads you.
        </p>
        <div class="hero-cin-item mt-10" style="--item-delay: 10">
          <a
            href="#masculine-archetypes"
            class="inline-flex items-center justify-center px-10 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Explore the Archetypes ↓
          </a>
        </div>
      </div>
    </section>

    <!-- MASCULINE ARCHETYPE GRID — full-bleed portrait image cards -->
    <section
      id="masculine-archetypes"
      data-gender="masculine"
      class="gender-block relative py-28 px-6 overflow-hidden bg-primary"
      aria-label="The masculine archetypes"
      data-compact-super="The Archetypes"
      data-compact-title="The Masculine Archetypes"
      data-compact-tagline="Every man's style is rooted in an archetype."
      data-compact-theme="dark"
    >
      <img
        src="/images/archetypes/ensemble-masculine-cards.webp"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="lazy"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/72 via-primary/78 to-primary/88 pointer-events-none"></div>
      <!-- Seam blends — same treatment as feminine cards section -->
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-primary to-transparent pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-primary to-transparent pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl">
        <!-- FULL header -->
        <div class="section-header-full mb-10 transition-opacity duration-500" data-section-full="masculine">
          <div class="w-8 h-px bg-accent mb-4"></div>
          <p class="font-body text-xs tracking-widest uppercase text-accent mb-3">The Archetypes</p>
          <h2 class="font-heading text-white text-4xl lg:text-5xl">The Masculine Archetypes</h2>
          <p class="mt-4 font-body text-white/60 text-base max-w-xl leading-relaxed">
            Every man's style is rooted in an archetype. Find the one that captures how you move through the world.
          </p>
        </div>

        {masculineSorted.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {masculineSorted.map((archetype) => (
              <div
                class="archetype-card group relative overflow-hidden cursor-pointer aspect-[3/4] max-h-[374px]"
                data-slug={archetype.data.slug}
                data-images={JSON.stringify(getCardImages(archetype.data.slug))}
              >
                <!-- Image layer A (starts visible) -->
                <img
                  data-layer="a"
                  src={`/images/archetypes/${archetype.data.slug}-1.webp`}
                  alt={archetype.data.name}
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  style="transition: opacity 1000ms ease-in-out; opacity: 1"
                  loading="lazy"
                />
                <!-- Image layer B (starts invisible, transitions in) -->
                <img
                  data-layer="b"
                  src=""
                  alt=""
                  aria-hidden="true"
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  style="transition: opacity 1000ms ease-in-out; opacity: 0"
                  loading="lazy"
                />

                <!-- Gradient overlay: always-on dark bottom for text legibility -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-transparent pointer-events-none"></div>

                <!-- Archetype color accent line at top of card -->
                <div
                  class="absolute top-0 left-0 right-0 h-0.5"
                  style={`background-color: ${archetype.data.color ?? '#b8977e'}`}
                ></div>

                <!-- God ray bloom on hover -->
                <div class="archetype-hover-ray absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-[5]"></div>

                <!-- Always-visible bottom label -->
                <div class="archetype-bottom-label absolute bottom-0 left-0 right-0 p-5 z-10">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-lg text-accent/70">{archetype.data.icon ?? '▲'}</span>
                    <h3 class="font-heading text-white text-xl font-semibold leading-tight">
                      {archetype.data.name}
                    </h3>
                  </div>
                </div>

                <!-- Hover reveal panel: slides up from bottom on hover -->
                <div class="archetype-reveal absolute inset-x-0 bottom-0 z-20
                            bg-gradient-to-t from-black/50 via-black/40 to-transparent">
                  <div class="archetype-reveal-content p-5">
                    <div class="flex items-center gap-2 mb-3">
                      <span class="text-lg text-accent/80">{archetype.data.icon ?? '▲'}</span>
                      <h3 class="font-heading text-white text-xl font-semibold">{archetype.data.name}</h3>
                    </div>
                    <p class="font-body text-sm text-white/70 leading-relaxed mb-4">
                      {archetype.data.description}
                    </p>
                    <div class="flex flex-col gap-2">
                      <a href={`/archetypes/${archetype.data.slug}`}
                         class="font-body text-xs tracking-widest uppercase text-accent hover:text-accent-light transition-colors">
                        Deep Dive →
                      </a>
                      {archetype.data.guideLink && (
                        <a href={archetype.data.guideLink} target="_blank" rel="noopener noreferrer"
                           class="font-body text-xs tracking-widest uppercase text-white/60 hover:text-accent transition-colors">
                          Get the Style Guide →
                        </a>
                      )}
                      {archetype.data.ltkLink && (
                        <a href={archetype.data.ltkLink} target="_blank" rel="noopener noreferrer"
                           class="font-body text-xs tracking-widest uppercase text-white/60 hover:text-accent transition-colors">
                          Shop This Look →
                        </a>
                      )}
                    </div>
                  </div>
                </div>

              </div>
            ))}

            <!-- "Find Your Archetype" quiz CTA card -->
            <div class="quiz-cta-card relative overflow-hidden bg-accent/12 backdrop-blur-sm border border-accent/25 aspect-[3/4] max-h-[374px]
                        flex flex-col justify-end p-5 hover:bg-accent/18 transition-all duration-300 cursor-pointer"
                 data-quiz-trigger="masc">
              <div class="w-8 h-0.5 bg-accent mb-4"></div>
              <h3 class="font-heading text-xl font-semibold text-white mb-3">Not sure which one is you?</h3>
              <p class="font-body text-sm text-white/60 leading-relaxed mb-4">
                Find your archetype in under 2 minutes.
              </p>
              <button
                type="button"
                class="quiz-cta-btn inline-flex items-center justify-center px-6 py-3 bg-accent text-white font-body text-xs font-medium tracking-widest uppercase whitespace-nowrap hover:bg-accent-light transition-colors duration-200
                       focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
                data-quiz-trigger="masc"
              >
                Find Your Archetype &rarr;
              </button>
            </div>
          </div>

          <!-- Quiz container (hidden until CTA clicked) -->
          <div id="masc-quiz-container" class="hidden mt-10">
            <ArchetypeQuiz gender="masculine" quizId="masc" />
          </div>
        ) : (
          <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-8 h-0.5 bg-accent mx-auto mb-8"></div>
            <h3 class="font-heading text-white text-3xl font-semibold mb-4">Coming Soon</h3>
            <p class="font-body text-white/55 text-base max-w-md leading-relaxed mb-10">
              The masculine archetype framework is being developed. Check back soon — or book a consultation and Danielle will walk you through it personally.
            </p>
            <a
              href={calendlyURL}
              class="inline-flex items-center justify-center px-10 py-4 border border-accent text-accent font-body text-sm font-medium tracking-widest uppercase hover:bg-accent hover:text-white transition-colors duration-200"
            >
              Book a Consultation
            </a>
          </div>
        )}
      </div>
    </section>


  </div><!-- /archetypes-page -->

  <!-- ── STYLE GUIDES CTA ──────────────────────────────── -->
  <section class="py-20 px-6 bg-primary" aria-label="Style guides" data-compact-super="Digital Guides" data-compact-title="Take Your Archetype Home" data-compact-tagline="In-depth style guides for your archetype — from $15." data-compact-theme="dark">
    <div class="mx-auto max-w-7xl">
      <!-- FULL header -->
      <div class="section-header-full transition-opacity duration-500" data-section-full="guides">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 py-10 border-t border-b border-white/10">
          <div>
            <div class="w-8 h-px bg-accent mb-4"></div>
            <p class="font-body text-xs tracking-widest uppercase text-accent mb-2">Digital Guides</p>
            <h2 class="font-heading text-white text-3xl font-semibold">Take Your Archetype Home</h2>
            <p class="mt-2 font-body text-white/55 text-base max-w-md leading-relaxed">
              In-depth style guides for your archetype — from $15. Instant download.
            </p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 shrink-0 py-6">
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a
            href="/shop"
            class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-body text-sm font-medium tracking-widest uppercase hover:bg-accent-light transition-colors duration-200"
          >
            Shop Style Guides
          </a>
          <a
            href={calendlyURL}
            class="inline-flex items-center justify-center px-8 py-4 border border-white/25 text-white font-body text-sm font-medium tracking-widest uppercase hover:border-white hover:bg-white/8 transition-colors duration-200"
          >
            Book Personalized Styling
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /*
   * Gender toggle visibility system
   * Default: feminine shown, masculine hidden.
   * JS sets data-active-gender on #archetypes-page.
   *
   * Inactive blocks are moved off-screen with position:absolute + left:-9999px
   * so they take up no space in the layout. Active blocks are position:static.
   * Opacity + transform transitions are applied via the Web Animations API in JS
   * to allow async await on their completion (display/position can't be transitioned).
   */

  /* Active blocks: normal flow */
  #archetypes-page[data-active-gender="feminine"] .gender-block[data-gender="feminine"],
  #archetypes-page[data-active-gender="masculine"] .gender-block[data-gender="masculine"] {
    position: static;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    height: auto;
    overflow: visible;
  }

  /* Inactive blocks: out of layout, invisible, not interactive */
  #archetypes-page[data-active-gender="feminine"] .gender-block[data-gender="masculine"],
  #archetypes-page[data-active-gender="masculine"] .gender-block[data-gender="feminine"] {
    position: absolute;
    left: -9999px;
    top: 0;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  /* Ensure the wrapper can contain the absolutely-positioned off-screen blocks */
  #archetypes-page {
    position: relative;
  }

  /* Click ripple — immediate visual confirmation that click registered */
  .card-click-ripple {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    transform: translate(-50%, -50%) scale(0);
    animation: card-click-ripple 550ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    pointer-events: none;
    z-index: 50;
  }
  @keyframes card-click-ripple {
    to { transform: translate(-50%, -50%) scale(45); opacity: 0; }
  }

  /* ── Cinematic hero entrance ────────────────────────────────────
   *
   * Elements start invisible (opacity: 0, shifted down) and transition
   * to their natural position when .cin-active is added by JS.
   *
   * Stagger math:
   *   hero-cin-item  → base 800ms  + (--item-delay  * 100ms)
   *   hero-cin-line  → base 1000ms + (--line-delay   * 120ms)
   *
   * On gender switch: .cin-reset removes all transitions for an
   * instant invisible reset, then cin-active re-applies them.
   */

  /* Lines: headline words — expo-out slide up */
  .hero-cin-line {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity   600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--line-delay, 0) * 120ms + 1000ms);
  }

  /* Items: eyebrow / subtitle / CTA — softer fade-up */
  .hero-cin-item {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity   500ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 550ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--item-delay, 0) * 100ms + 800ms);
  }

  /* Active: elements snap to their final position via the transitions above */
  .hero-cin-line.cin-active,
  .hero-cin-item.cin-active {
    opacity: 1;
    transform: none;
  }

  /* Reset: instant hide with no transition (JS removes this immediately after) */
  .hero-cin-line.cin-reset,
  .hero-cin-item.cin-reset {
    opacity: 0;
    transform: translateY(22px);
    transition: none;
  }

  /* Honour the OS reduced-motion preference — show everything immediately */
  @media (prefers-reduced-motion: reduce) {
    .hero-cin-line,
    .hero-cin-item {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /*
   * Archetype card: the reveal panel slides UP from the bottom on hover.
   * The bottom label (z-10) sits BELOW the reveal panel (z-20) in stacking order,
   * so the panel slides over it cleanly without needing to hide the label.
   *
   * overflow-hidden on the card clips the panel when it is fully translated down.
   */
  .archetype-card .archetype-reveal {
    /* Ensure the panel background extends past the card bottom edge during transition */
    padding-bottom: max(1.25rem, env(safe-area-inset-bottom));
  }

  /* ── Reveal panel transitions (fully CSS-controlled) ──────── */
  /* Base: hidden below card. Transition managed here so we can combine
     translateY + counter-scale in a single transform declaration. */
  .archetype-reveal {
    transform: translateY(100%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Hover: slide up only — gradient stays full card width */
  .archetype-card:hover .archetype-reveal {
    transform: translateY(0);
  }
  /* Keyboard focus: slide up (card doesn't scale on focus) */
  .archetype-card:focus-within .archetype-reveal {
    transform: translateY(0);
  }

  /* ── Counter-scale text-only layers ──────────────────────── */
  /* Gradient div (.archetype-reveal) is NOT counter-scaled so it spans
     the full width of the zoomed card. Only the text content wrapper
     and always-visible label shrink back to original pixel size. */
  .archetype-reveal-content,
  .archetype-bottom-label {
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
                opacity 300ms ease-out;
  }
  .archetype-card:hover .archetype-reveal-content,
  .archetype-card:hover .archetype-bottom-label {
    transform: scale(0.6667);
    transform-origin: bottom left;
  }
  /* Hide the always-visible name label once the reveal panel is shown */
  .archetype-card:hover .archetype-bottom-label,
  .archetype-card:focus-within .archetype-bottom-label {
    opacity: 0;
  }

  /* ── Hover expansion ───────────────────────────────────────── */
  /* Card scales 1.5× on hover; vertical growth fits within py-28 section padding.
     Edge cards may clip at section boundary (overflow-hidden on section) —
     acceptable since users focus on center cards. */
  .archetype-card {
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .archetype-card:hover {
    transform: scale(1.5);
    z-index: 50;
  }

  /* ── Hover lockout — prevents scale from firing when cursor is
     already over a card (e.g. on page load or after quiz closes).
     Removed on mouseleave so subsequent intentional hovers work. ── */
  .archetype-card.hover-locked:hover {
    transform: none;
    z-index: auto;
  }
  .archetype-card.hover-locked:hover .archetype-reveal {
    transform: translateY(100%);
  }
  .archetype-card.hover-locked:hover .archetype-reveal-content,
  .archetype-card.hover-locked:hover .archetype-bottom-label {
    transform: none;
    opacity: 1;
  }
  .archetype-card.hover-locked .archetype-hover-ray {
    opacity: 0 !important;
  }

  /* ── God ray bloom on hover ────────────────────────────────── */
  /* Feminine: warm gold from top-center */
  .archetype-hover-ray {
    background: radial-gradient(ellipse 120% 80% at 50% -10%, rgba(184, 151, 126, 0.5) 0%, transparent 55%);
  }
  /* Masculine: angelic silver-white from top-center */
  [data-gender="masculine"] .archetype-hover-ray {
    background: radial-gradient(ellipse 120% 80% at 50% -10%, rgba(255, 255, 255, 0.22) 0%, transparent 55%);
  }
</style>

<script>
  // ── Gender Toggle + Cinematic Hero ────────────────────────────
  // ViewTransitions-compatible: all init happens inside astro:page-load
  // so it re-runs on every navigation (initial + soft VT navigations).
  //
  // triggerHeroCinematic lives at module scope so both the page-load
  // handler and the pageshow/IntersectionObserver failsafes can call it.

  const STORAGE_KEY = 'archetypes-gender';
  const DEFAULT_GENDER = 'feminine';

  // ── Module-scope: cinematic hero entrance ─────────────────────
  // Shared across astro:page-load, pageshow, and IntersectionObserver.
  function triggerHeroCinematic(genderValue: string) {
    const page = document.getElementById('archetypes-page');
    if (!page) return;

    const heroSection = page.querySelector<HTMLElement>(
      `.gender-block[data-gender="${genderValue}"]`
    );
    if (!heroSection) return;

    const els = Array.from(
      heroSection.querySelectorAll<HTMLElement>('.hero-cin-line, .hero-cin-item')
    );
    if (els.length === 0) return;

    // Step 1: force everything invisible immediately
    els.forEach(el => {
      el.classList.remove('cin-active');
      el.classList.add('cin-reset');
    });

    // Step 2: re-enable transitions and animate in
    requestAnimationFrame(() => {
      els.forEach(el => el.classList.remove('cin-reset'));
      requestAnimationFrame(() => {
        els.forEach(el => el.classList.add('cin-active'));
      });
    });
  }

  // ── Failsafe: IntersectionObserver ────────────────────────────
  // If the hero section becomes visible but the animation hasn't fired,
  // trigger it. Catches bfcache, tab switches, any unknown edge case.
  let heroAnimationFired = false;

  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !heroAnimationFired) {
        heroAnimationFired = true;
        const page = document.getElementById('archetypes-page');
        if (page) {
          triggerHeroCinematic(page.getAttribute('data-active-gender') ?? DEFAULT_GENDER);
        }
      }
    });
  }, { threshold: 0.1 });

  // ── Failsafe: bfcache restore ────────────────────────────────
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      const page = document.getElementById('archetypes-page');
      if (!page) return;
      triggerHeroCinematic(page.getAttribute('data-active-gender') ?? DEFAULT_GENDER);
    }
  });

  // ── Main init: runs on every page load (initial + VT nav) ────
  document.addEventListener('astro:page-load', () => {
    // Guard: only run on the archetypes page
    const page = document.getElementById('archetypes-page') as HTMLElement | null;
    if (!page) return;

    const btnFem = document.getElementById('toggle-feminine')  as HTMLButtonElement | null;
    const btnMas = document.getElementById('toggle-masculine') as HTMLButtonElement | null;
    if (!btnFem || !btnMas) return;

    // Reset failsafe observer for this page load
    heroAnimationFired = false;
    heroObserver.disconnect();
    const heroBlock = page.querySelector('.gender-block');
    if (heroBlock) heroObserver.observe(heroBlock);

    function getDur(mult = 1): number {
      const raw = getComputedStyle(document.documentElement).getPropertyValue('--dur').trim();
      return parseFloat(raw) * (raw.endsWith('ms') ? 1 : 1000) * mult;
    }

    const EASE_OUT = 'cubic-bezier(0.16, 1, 0.3, 1)';
    const EASE_IN  = 'cubic-bezier(0.5, 0, 0.85, 0)';

    let switching = false;

    function getBlocks(gender: string): HTMLElement[] {
      return Array.from(
        page!.querySelectorAll<HTMLElement>(`.gender-block[data-gender="${gender}"]`)
      );
    }

    function setButtonState(btn: HTMLButtonElement, active: boolean) {
      btn.setAttribute('aria-pressed', String(active));
      if (active) {
        btn.classList.add('bg-white/15', 'backdrop-blur-sm', 'border-white/25', 'text-white');
        btn.classList.remove('bg-transparent', 'border-white/15', 'text-white/40', 'hover:text-white/70');
      } else {
        btn.classList.remove('bg-white/15', 'backdrop-blur-sm', 'border-white/25', 'text-white');
        btn.classList.add('bg-transparent', 'border-white/15', 'text-white/40', 'hover:text-white/70');
      }
    }

    async function switchGender(targetGender: string) {
      if (switching) return;
      const current = page!.getAttribute('data-active-gender') ?? DEFAULT_GENDER;
      if (current === targetGender) return;
      switching = true;

      // Update button states immediately (feels responsive)
      setButtonState(targetGender === 'feminine' ? btnFem! : btnMas!, true);
      setButtonState(targetGender === 'feminine' ? btnMas! : btnFem!, false);

      // Animate OUT the currently-active blocks
      const outBlocks = getBlocks(current);
      await Promise.all(
        outBlocks.map(el =>
          el.animate(
            [
              { opacity: 1, transform: 'translateY(0)'    },
              { opacity: 0, transform: 'translateY(12px)' },
            ],
            { duration: getDur(0.5), easing: EASE_IN, fill: 'forwards' }
          ).finished
        )
      );
      outBlocks.forEach(el => el.getAnimations().forEach(a => a.cancel()));

      // Swap the data attribute
      page!.setAttribute('data-active-gender', targetGender);

      // Lazy-load masculine video on first reveal
      if (targetGender === 'masculine') {
        const vid = document.getElementById('video-masculine') as HTMLVideoElement | null;
        if (vid && vid.readyState === 0) vid.load();
      }

      // Scroll to the top if user has scrolled past the hero
      if (window.scrollY > window.innerHeight * 0.5) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Animate IN the incoming blocks
      const inBlocks = getBlocks(targetGender);
      await Promise.all(
        inBlocks.map((el, i) =>
          el.animate(
            [
              { opacity: 0, transform: 'translateY(18px)' },
              { opacity: 1, transform: 'translateY(0)'    },
            ],
            {
              duration: getDur(1.25),
              easing: EASE_OUT,
              fill: 'forwards',
              delay: i * getDur(0.06),
            }
          ).finished
        )
      );
      inBlocks.forEach(el => el.getAnimations().forEach(a => a.cancel()));

      // Fire cinematic hero text entrance for the incoming gender
      heroAnimationFired = true;
      triggerHeroCinematic(targetGender);

      // Persist preference
      try { localStorage.setItem(STORAGE_KEY, targetGender); } catch {}

      switching = false;
    }

    // ── Restore saved preference ──────────────────────────────
    function restorePreference() {
      let saved: string | null = null;
      try { saved = localStorage.getItem(STORAGE_KEY); } catch {}
      const gender = (saved === 'masculine' || saved === 'feminine') ? saved : DEFAULT_GENDER;

      page!.setAttribute('data-active-gender', gender);

      if (gender === 'masculine') {
        setButtonState(btnMas!, true);
        setButtonState(btnFem!, false);
      }
    }

    restorePreference();

    // Fire cinematic entrance for the initially-active gender
    heroAnimationFired = true;
    triggerHeroCinematic(page!.getAttribute('data-active-gender') ?? DEFAULT_GENDER);

    // Attach button listeners (fresh DOM elements each VT navigation)
    btnFem!.addEventListener('click', () => switchGender('feminine'));
    btnMas!.addEventListener('click', () => switchGender('masculine'));
  });
</script>

<script>
  // ── Archetype card image carousel ─────────────────────────────
  // ViewTransitions-compatible: wrapped in astro:page-load so it
  // re-initializes on fresh DOM elements after every VT navigation.
  //
  // With ViewTransitions, DOM elements are NEW each navigation, so
  // _carouselStarted is never set on them — carousel naturally
  // re-initializes on fresh DOM.

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('archetypes-page')) return;

    const HOLD_MS         = 8_000;
    const FADE_MS         = 1_000;
    const LOAD_TIMEOUT_MS = 6_000;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ── Shared registry: no two cards ever show the same image ────
    const activeImages = new Map<string, number>();

    function register(src: string) {
      if (!src) return;
      activeImages.set(src, (activeImages.get(src) ?? 0) + 1);
    }
    function unregister(src: string) {
      if (!src) return;
      const n = (activeImages.get(src) ?? 1) - 1;
      if (n <= 0) activeImages.delete(src); else activeImages.set(src, n);
    }
    function isActive(src: string) { return (activeImages.get(src) ?? 0) > 0; }

    function pickUnique(pool: string[], currentSrc: string): string {
      const free = pool.filter(s => !isActive(s));
      if (free.length > 0) {
        const choices = free.filter(s => s !== currentSrc);
        return choices.length > 0
          ? choices[Math.floor(Math.random() * choices.length)]
          : free[0];
      }
      const fallback = pool.filter(s => s !== currentSrc);
      return fallback.length > 0
        ? fallback[Math.floor(Math.random() * fallback.length)]
        : pool[0];
    }

    // ── Per-card cycle ─────────────────────────────────────────────
    function startCard(card: HTMLElement, startDelay: number) {
      const images: string[] = JSON.parse(card.dataset.images ?? '[]');
      if (images.length < 2) return;

      const layerA = card.querySelector<HTMLImageElement>('[data-layer="a"]');
      const layerB = card.querySelector<HTMLImageElement>('[data-layer="b"]');
      if (!layerA || !layerB) return;

      let frontIsA    = true;
      let timer: ReturnType<typeof setTimeout> | null = null;
      let transitioning = false;

      register(layerA.getAttribute('src') ?? '');

      function nextImage() {
        if (transitioning) return;
        transitioning = true;
        if (timer) { clearTimeout(timer); timer = null; }

        const front = frontIsA ? layerA! : layerB!;
        const back  = frontIsA ? layerB! : layerA!;
        const currentSrc = front.getAttribute('src') ?? '';
        const nextSrc    = pickUnique(images, currentSrc);

        register(nextSrc);
        back.src = nextSrc;

        const loadTimer = setTimeout(() => {
          back.onload = back.onerror = null;
          unregister(nextSrc);
          transitioning = false;
          timer = setTimeout(nextImage, HOLD_MS);
        }, LOAD_TIMEOUT_MS);

        const doFade = () => {
          clearTimeout(loadTimer);
          back.style.opacity  = '1';
          front.style.opacity = '0';
          unregister(currentSrc);
          frontIsA = !frontIsA;
          setTimeout(() => { transitioning = false; }, FADE_MS);
          timer = setTimeout(nextImage, HOLD_MS);
        };

        if (back.complete && back.naturalWidth > 0) {
          doFade();
        } else {
          back.onload  = doFade;
          back.onerror = () => {
            clearTimeout(loadTimer);
            unregister(nextSrc);
            transitioning = false;
            timer = setTimeout(nextImage, HOLD_MS);
          };
        }
      }

      (card as any)._advanceCarousel = () => { if (!transitioning) nextImage(); };
      timer = setTimeout(nextImage, startDelay + HOLD_MS);
    }

    // ── Ripple helper ─────────────────────────────────────────────
    function spawnRipple(card: HTMLElement, e: MouseEvent) {
      const ripple = document.createElement('span');
      ripple.className = 'card-click-ripple';
      const r = card.getBoundingClientRect();
      ripple.style.left = `${e.clientX - r.left}px`;
      ripple.style.top  = `${e.clientY - r.top}px`;
      card.appendChild(ripple);
      ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
    }

    // ── Init ALL cards — fresh DOM each VT navigation ─────────────
    requestAnimationFrame(() => {
      let i = 0;
      document.querySelectorAll<HTMLElement>('.archetype-card').forEach((card) => {
        if ((card as any)._carouselStarted) return;
        (card as any)._carouselStarted = true;

        startCard(card, i * 350);
        i++;

        // Keyboard accessibility: make card focusable and navigable via Enter/Space
        const heading = card.querySelector<HTMLElement>('h3');
        card.setAttribute('tabindex', '0');
        card.setAttribute('role', 'article');
        if (heading) card.setAttribute('aria-label', heading.textContent?.trim() ?? '');
        card.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key !== 'Enter' && e.key !== ' ') return;
          if ((e.target as Element).closest('a, button')) return;
          e.preventDefault();
          const slug = card.dataset.slug;
          if (slug) window.location.href = `/archetypes/${slug}`;
        });

        card.addEventListener('click', (e: MouseEvent) => {
          if ((e.target as Element).closest('a, button')) return;
          spawnRipple(card, e);
          const advance = (card as any)._advanceCarousel;
          if (advance) advance();
        });
      });
    });
  });
</script>

<script>
  // ── Quiz entry/exit animations ──────────────────────────────────
  // ViewTransitions-compatible: wrapped in astro:page-load so it
  // re-initializes on fresh DOM elements after every VT navigation.
  //
  // Custom events (quiz:exit, quiz:switch-gender) use event delegation
  // on `document` — these are re-attached each page-load, but since
  // ViewTransitions replaces DOM, duplicate listeners on OLD documents
  // are garbage collected. We use an AbortController to be extra safe.

  let quizAbortController: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('archetypes-page')) return;

    // Tear down previous document-level listeners if re-running
    quizAbortController?.abort();
    quizAbortController = new AbortController();
    const signal = quizAbortController.signal;

    const EASE_OUT = 'cubic-bezier(0.16, 1, 0.3, 1)';
    const EASE_IN  = 'cubic-bezier(0.5, 0, 0.85, 0)';
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function getDur(mult = 1): number {
      const raw = getComputedStyle(document.documentElement).getPropertyValue('--dur').trim();
      return parseFloat(raw) * (raw.endsWith('ms') ? 1 : 1000) * mult;
    }

    const quizConfigs: Record<string, { gridSelector: string; containerId: string; headerSelector: string }> = {
      fem:  { gridSelector: '#archetypes .grid', containerId: 'fem-quiz-container', headerSelector: '#archetypes .section-header-full' },
      masc: { gridSelector: '#masculine-archetypes .grid', containerId: 'masc-quiz-container', headerSelector: '#masculine-archetypes .section-header-full' },
    };

    async function openQuiz(quizId: string) {
      const config = quizConfigs[quizId];
      if (!config) return;

      const grid = document.querySelector<HTMLElement>(config.gridSelector);
      const container = document.getElementById(config.containerId);
      if (!grid || !container) return;

      const cards = Array.from(grid.children) as HTMLElement[];

      if (!reducedMotion) {
        await Promise.all(
          cards.map((card, i) =>
            card.animate(
              [
                { opacity: 1, transform: 'translateY(0)' },
                { opacity: 0, transform: 'translateY(12px)' },
              ],
              {
                duration: getDur(0.5),
                easing: EASE_IN,
                fill: 'forwards',
                delay: i * 50,
              }
            ).finished
          )
        );
      }

      grid.classList.add('hidden');
      container.classList.remove('hidden');

      cards.forEach(card => card.getAnimations().forEach(a => a.cancel()));

      if (!reducedMotion) {
        container.animate(
          [
            { opacity: 0, transform: 'translateY(18px)' },
            { opacity: 1, transform: 'translateY(0)' },
          ],
          { duration: getDur(1), easing: EASE_OUT, fill: 'forwards' }
        ).finished.then(() => {
          container.getAnimations().forEach(a => a.cancel());
          // Move focus into the quiz after the entrance animation so keyboard users
          // know the quiz has opened and where they are
          const firstChip = container.querySelector<HTMLElement>('.quiz-chip');
          if (firstChip) firstChip.focus({ preventScroll: true });
        });
      } else {
        // No animation — focus immediately
        const firstChip = container.querySelector<HTMLElement>('.quiz-chip');
        if (firstChip) firstChip.focus({ preventScroll: true });
      }

      // Smooth-scroll so the section headline is perfectly framed at the top
      const header = document.querySelector<HTMLElement>(config.headerSelector);
      if (header) {
        const headerRect = header.getBoundingClientRect();
        const targetY = window.scrollY + headerRect.top - 32; // 32px breathing room
        window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
      } else {
        container.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    async function closeQuiz(quizId: string) {
      const config = quizConfigs[quizId];
      if (!config) return;

      const grid = document.querySelector<HTMLElement>(config.gridSelector);
      const container = document.getElementById(config.containerId);
      if (!grid || !container) return;

      if (!reducedMotion) {
        await container.animate(
          [
            { opacity: 1, transform: 'translateY(0)' },
            { opacity: 0, transform: 'translateY(12px)' },
          ],
          { duration: getDur(0.5), easing: EASE_IN, fill: 'forwards' }
        ).finished;
        container.getAnimations().forEach(a => a.cancel());
      }

      container.classList.add('hidden');
      grid.classList.remove('hidden');

      const cards = Array.from(grid.children) as HTMLElement[];

      if (!reducedMotion) {
        await Promise.all(
          cards.map((card, i) =>
            card.animate(
              [
                { opacity: 0, transform: 'translateY(18px)' },
                { opacity: 1, transform: 'translateY(0)' },
              ],
              {
                duration: getDur(1),
                easing: EASE_OUT,
                fill: 'forwards',
                delay: i * 50,
              }
            ).finished
          )
        );
        cards.forEach(card => card.getAnimations().forEach(a => a.cancel()));
      }

      // Hover lockout: cursor may already be over a re-emerged card
      cards.forEach(card => {
        if (!card.classList.contains('archetype-card')) return;
        card.classList.add('hover-locked');
        card.addEventListener('mouseleave', () => card.classList.remove('hover-locked'), { once: true });
      });

      const section = grid.closest('section');
      const header = section?.querySelector('.section-header-full');
      if (header) {
        const rect = header.getBoundingClientRect();
        window.scrollTo({ top: Math.max(0, window.scrollY + rect.top - 24), behavior: 'smooth' });
      } else if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    // ── CTA click handlers (fresh DOM elements each navigation) ────
    document.querySelectorAll<HTMLElement>('[data-quiz-trigger]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const quizId = el.dataset.quizTrigger!;
        openQuiz(quizId);
      });
    });

    // ── "Explore the Archetypes" CTA — scroll to section header ──
    document.querySelectorAll<HTMLAnchorElement>('a[href="#archetypes"], a[href="#masculine-archetypes"]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href')!.slice(1);
        const section = document.getElementById(targetId);
        const header = section?.querySelector('.section-header-full');
        if (header) {
          const headerRect = header.getBoundingClientRect();
          const targetY = window.scrollY + headerRect.top - 24;
          window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
        } else {
          section?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // ── Quiz exit event (document-level — use AbortController) ─────
    document.addEventListener('quiz:exit', (e) => {
      const quizRoot = (e.target as HTMLElement).closest('.quiz-root');
      if (!quizRoot) return;
      const quizId = (quizRoot as HTMLElement).dataset.quizId;
      if (quizId) closeQuiz(quizId);
    }, { signal });

    // ── Gender switch from quiz results ────────────────────────────
    document.addEventListener('quiz:switch-gender', async (e) => {
      const detail = (e as CustomEvent).detail;
      if (!detail?.targetGender) return;

      const quizRoot = (e.target as HTMLElement).closest('.quiz-root');
      if (!quizRoot) return;
      const currentQuizId = (quizRoot as HTMLElement).dataset.quizId;

      if (currentQuizId) {
        await closeQuiz(currentQuizId);
      }

      const targetGender = detail.targetGender;
      const btnFem = document.getElementById('toggle-feminine') as HTMLButtonElement | null;
      const btnMas = document.getElementById('toggle-masculine') as HTMLButtonElement | null;

      if (targetGender === 'feminine') {
        btnFem?.click();
      } else {
        btnMas?.click();
      }

      setTimeout(() => {
        const otherQuizId = targetGender === 'feminine' ? 'fem' : 'masc';
        openQuiz(otherQuizId);
      }, 1500);
    }, { signal });

    // ── Hash-based auto-open on page load ──────────────────────────
    function checkHashOnLoad() {
      const hash = window.location.hash;
      if (!hash) return;

      const match = hash.match(/^#quiz\/(feminine|masculine)\//);
      if (!match) return;

      const hashGender = match[1];
      const quizId = hashGender === 'feminine' ? 'fem' : 'masc';

      const page = document.getElementById('archetypes-page');
      const activeGender = page?.getAttribute('data-active-gender');

      if (activeGender !== hashGender) {
        const btn = hashGender === 'feminine'
          ? document.getElementById('toggle-feminine')
          : document.getElementById('toggle-masculine');
        if (btn) btn.click();

        setTimeout(() => openQuiz(quizId), 1500);
      } else {
        setTimeout(() => openQuiz(quizId), 500);
      }
    }

    requestAnimationFrame(() => requestAnimationFrame(checkHashOnLoad));
  });
</script>

